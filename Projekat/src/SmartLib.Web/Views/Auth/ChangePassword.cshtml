@model SmartLib.Core.DTOs.ChangePasswordRequest
@{
    ViewData["Title"] = "Promjena lozinke";
}

<div class="page-shell">
    <div class="details-topbar">
        <a asp-controller="Korisnik" asp-action="Profil" class="btn btn-secondary">← Nazad na profil</a>
    </div>

    <div class="card book-form-card">
        <div class="details-header">
            <div>
                <h2>Promjena lozinke</h2>
                <p class="details-autor">Unesite trenutnu lozinku i postavite novu.</p>
            </div>
        </div>

        <form asp-controller="Auth" asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-error mb-3"></div>

            <div class="form-group">
                <label asp-for="TrenutnaLozinka">Trenutna lozinka</label>
                <input asp-for="TrenutnaLozinka" type="password" />
                <span asp-validation-for="TrenutnaLozinka" class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="NovaLozinka">Nova lozinka</label>
                <input asp-for="NovaLozinka" type="password" />
                <span asp-validation-for="NovaLozinka" class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="PotvrdaLozinke">Potvrdi novu lozinku</label>
                <input asp-for="PotvrdaLozinke" type="password" />
                <span asp-validation-for="PotvrdaLozinke" class="validation-message"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Spremi lozinku</button>
                <a asp-controller="Korisnik" asp-action="Profil" class="btn btn-secondary">Odustani</a>
            </div>
        </form>
    </div>
</div>
