@model SmartLib.Core.DTOs.ChangePasswordRequest
@{
    ViewData["Title"] = "Promjena lozinke";
}

<div class="page-shell">
    <div class="details-topbar">
        <a asp-controller="Korisnik" asp-action="Profil" class="btn btn-secondary">← Nazad na profil</a>
    </div>

    <div class="card book-form-card">
        <div class="details-header">
            <div>
                <h2>Promjena lozinke</h2>
                <p class="details-autor">Unesite trenutnu lozinku i postavite novu.</p>
            </div>
        </div>

        <form asp-controller="Auth" asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-error mb-3"></div>

            <div class="form-group">
                <label asp-for="TrenutnaLozinka">Trenutna lozinka</label>
                <div class="password-field">
                    <input asp-for="TrenutnaLozinka" type="password" class="password-input" />
                    <button type="button" class="password-toggle" aria-label="Prikazi lozinku" aria-pressed="false">
                        <svg class="icon-eye" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M2.5 12s3.5-6.5 9.5-6.5 9.5 6.5 9.5 6.5-3.5 6.5-9.5 6.5S2.5 12 2.5 12z" fill="none" stroke="currentColor" stroke-width="1.7" />
                            <circle cx="12" cy="12" r="3.5" fill="none" stroke="currentColor" stroke-width="1.7" />
                        </svg>
                        <svg class="icon-eye-off" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M4 4l16 16" fill="none" stroke="currentColor" stroke-width="1.7" />
                            <path d="M7.5 7.5C9 6.4 10.8 5.5 12.5 5.5c6 0 9.5 6.5 9.5 6.5a17.9 17.9 0 0 1-3.2 4.3" fill="none" stroke="currentColor" stroke-width="1.7" />
                            <path d="M15.6 15.6a3.5 3.5 0 0 1-4.95-4.95" fill="none" stroke="currentColor" stroke-width="1.7" />
                            <path d="M5.7 13.9C3.7 12 2.5 10 2.5 10s.7-1.4 2.1-3.1" fill="none" stroke="currentColor" stroke-width="1.7" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="TrenutnaLozinka" class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="NovaLozinka">Nova lozinka</label>
                <div class="password-field">
                    <input asp-for="NovaLozinka" type="password" class="password-input" />
                    <button type="button" class="password-toggle" aria-label="Prikazi lozinku" aria-pressed="false">
                        <svg class="icon-eye" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M2.5 12s3.5-6.5 9.5-6.5 9.5 6.5 9.5 6.5-3.5 6.5-9.5 6.5S2.5 12 2.5 12z" fill="none" stroke="currentColor" stroke-width="1.7" />
                            <circle cx="12" cy="12" r="3.5" fill="none" stroke="currentColor" stroke-width="1.7" />
                        </svg>
                        <svg class="icon-eye-off" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M4 4l16 16" fill="none" stroke="currentColor" stroke-width="1.7" />
                            <path d="M7.5 7.5C9 6.4 10.8 5.5 12.5 5.5c6 0 9.5 6.5 9.5 6.5a17.9 17.9 0 0 1-3.2 4.3" fill="none" stroke="currentColor" stroke-width="1.7" />
                            <path d="M15.6 15.6a3.5 3.5 0 0 1-4.95-4.95" fill="none" stroke="currentColor" stroke-width="1.7" />
                            <path d="M5.7 13.9C3.7 12 2.5 10 2.5 10s.7-1.4 2.1-3.1" fill="none" stroke="currentColor" stroke-width="1.7" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="NovaLozinka" class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="PotvrdaLozinke">Potvrdi novu lozinku</label>
                <div class="password-field">
                    <input asp-for="PotvrdaLozinke" type="password" class="password-input" />
                    <button type="button" class="password-toggle" aria-label="Prikazi lozinku" aria-pressed="false">
                        <svg class="icon-eye" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M2.5 12s3.5-6.5 9.5-6.5 9.5 6.5 9.5 6.5-3.5 6.5-9.5 6.5S2.5 12 2.5 12z" fill="none" stroke="currentColor" stroke-width="1.7" />
                            <circle cx="12" cy="12" r="3.5" fill="none" stroke="currentColor" stroke-width="1.7" />
                        </svg>
                        <svg class="icon-eye-off" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M4 4l16 16" fill="none" stroke="currentColor" stroke-width="1.7" />
                            <path d="M7.5 7.5C9 6.4 10.8 5.5 12.5 5.5c6 0 9.5 6.5 9.5 6.5a17.9 17.9 0 0 1-3.2 4.3" fill="none" stroke="currentColor" stroke-width="1.7" />
                            <path d="M15.6 15.6a3.5 3.5 0 0 1-4.95-4.95" fill="none" stroke="currentColor" stroke-width="1.7" />
                            <path d="M5.7 13.9C3.7 12 2.5 10 2.5 10s.7-1.4 2.1-3.1" fill="none" stroke="currentColor" stroke-width="1.7" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="PotvrdaLozinke" class="validation-message"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Spremi lozinku</button>
                <a asp-controller="Korisnik" asp-action="Profil" class="btn btn-secondary">Odustani</a>
            </div>
        </form>
    </div>
</div>
