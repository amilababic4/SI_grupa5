@model SmartLib.Core.DTOs.ForgotPasswordRequest
@{
    ViewData["Title"] = "Zaboravljena lozinka";
}

<div class="card" style="max-width: 400px; margin: 4rem auto;">
    <h2>Zaboravljena lozinka</h2>
    <p style="margin-bottom: 1.5rem; color: var(--text-muted);">Unesite vašu email adresu kako bismo vam poslali link za resetovanje lozinke.</p>

    <form asp-controller="Auth" asp-action="ForgotPassword" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-message" style="margin-bottom: 1rem;"></div>

        <div class="form-group">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" type="email" placeholder="vas@email.com" />
            <span asp-validation-for="Email" class="validation-message"></span>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%;">Pošalji link za resetovanje</button>
    </form>
    
    <div style="margin-top: 1.5rem; text-align: center; border-top: 1px solid var(--sl-border); padding-top: 1rem;">
        <a asp-action="Login" style="font-size: 0.9rem; color: var(--sl-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: color 0.2s;" onmouseover="this.style.color='var(--sl-blue)'" onmouseout="this.style.color='var(--sl-muted)'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Nazad na prijavu
        </a>
    </div>
</div>
