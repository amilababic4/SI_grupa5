@model SmartLib.Core.DTOs.ResetPasswordRequest
@{
    ViewData["Title"] = "Resetovanje lozinke";
    var email = ViewData["Email"] as string;
}

<div class="card" style="max-width: 400px; margin: 4rem auto;">
    <h2>Resetovanje lozinke</h2>
    <p style="margin-bottom: 1.5rem; color: var(--text-muted);">Unesite vašu novu lozinku.</p>

    <form asp-controller="Auth" asp-action="ResetPassword" method="post">
        <input type="hidden" asp-for="Token" />
        <input type="hidden" name="email" value="@email" />

        <div asp-validation-summary="ModelOnly" class="validation-message" style="margin-bottom: 1rem;"></div>

        <div class="form-group">
            <label asp-for="NovaLozinka">Nova lozinka</label>
            <input asp-for="NovaLozinka" type="password" />
            <span asp-validation-for="NovaLozinka" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="PotvrdaLozinke">Potvrdite lozinku</label>
            <input asp-for="PotvrdaLozinke" type="password" />
            <span asp-validation-for="PotvrdaLozinke" class="validation-message"></span>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%;">Sačuvaj novu lozinku</button>
    </form>
</div>
