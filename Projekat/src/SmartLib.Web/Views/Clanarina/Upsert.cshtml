@model SmartLib.Core.DTOs.ClanarinaUpsertDto
@{
    bool postoji = (bool)(ViewBag.Postoji ?? false);
    string naslov = postoji ? "Upravljanje članarinom" : "Evidentiraj novu članarinu";
    ViewData["Title"] = naslov;
}

<div class="page-shell">

    <div class="details-topbar">
        <a asp-controller="Korisnik" asp-action="ProfilClana"
           asp-route-id="@Model.KorisnikId"
           class="btn btn-secondary">← Profil člana</a>
    </div>

    <div class="card book-form-card">

        <div class="details-header">
            <div>
                <h2>@naslov</h2>
                <p class="details-autor">
                    @(postoji ? "Izmijeni datume važenja članarine" : "Unesite datume važenja nove članarine")
                </p>
            </div>
        </div>

        <form asp-action="Upsert" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="KorisnikId" />

            <div asp-validation-summary="ModelOnly" class="alert alert-error mb-3"></div>

            <div class="form-group">
                <label asp-for="DatumPocetka">Datum početka</label>
                <input asp-for="DatumPocetka" type="date" />
                <span asp-validation-for="DatumPocetka" class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="DatumIsteka">Datum isteka</label>
                <input asp-for="DatumIsteka" type="date" />
                <span asp-validation-for="DatumIsteka" class="validation-message"></span>
                <span class="form-help">Datum isteka mora biti nakon datuma početka.</span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    @(postoji ? "Spremi izmjene" : "Evidentiraj članarinu")
                </button>
                <a asp-controller="Korisnik" asp-action="ProfilClana"
                   asp-route-id="@Model.KorisnikId"
                   class="btn btn-secondary">
                    Odustani
                </a>
            </div>

        </form>
    </div>
</div>
