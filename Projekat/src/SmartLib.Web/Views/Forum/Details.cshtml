@model SmartLib.Core.DTOs.ForumObjavaDto
@{
    ViewData["Title"] = Model.Naslov;
    bool jeOsoblje = User.IsInRole("Bibliotekar") || User.IsInRole("Administrator");
}

<style>
    .forum-detail-title {
        color: var(--sl-text);
    }

    .forum-detail-meta {
        color: var(--sl-muted);
    }

    .forum-detail-card {
        background: var(--sl-card);
        border: 1px solid var(--sl-border);
        border-radius: 12px;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    }

    .reaction-button {
        border-radius: 999px;
        padding: 0.6rem 1.2rem;
        font-weight: 600;
        font-size: 0.98rem;
    }

    .reaction-button .badge {
        font-size: 0.85rem;
        padding: 0.3rem 0.55rem;
        border-radius: 999px;
    }

    .comments-section h3 {
        color: var(--sl-text);
        margin-bottom: 1rem;
    }

    .comment-form-card {
        background: var(--sl-card);
        border: 1px solid var(--sl-border);
        border-radius: 12px;
    }

    .comment-card {
        background: rgba(255, 255, 255, 0.8);
        border: 1px solid var(--sl-border);
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.06);
    }

    .comment-meta {
        color: var(--sl-muted);
        font-size: 0.9rem;
    }

    .comment-body {
        color: var(--sl-text);
        font-size: 0.98rem;
        line-height: 1.6;
    }

    [data-theme="dark"] .comment-card {
        background: rgba(17, 28, 46, 0.85);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
    }
</style>

<div class="page-header" style="margin-bottom: 2rem;">
    <div class="header-content">
        <a asp-action="Index" style="text-decoration: none; color: var(--sl-muted);">&larr; Nazad na forum</a>
        <h1 class="forum-detail-title" style="margin-top: 1rem;">@Model.Naslov</h1>
        <div class="post-meta forum-detail-meta" style="display: flex; gap: 1rem; font-size: 0.9rem; margin-top: 0.5rem;">
            <span class="badge" style="background: var(--sl-blue-soft); padding: 0.2rem 0.5rem; border-radius: 4px;">@Model.Kategorija</span>
            <span>Objavio: <strong>@Model.AutorIme</strong> (@Model.AutorUloga)</span>
            <span>@Model.DatumKreiranja.ToString("dd.MM.yyyy HH:mm")</span>
            @if(Model.Zakljucana)
            {
                <span class="text-danger">🔒 Zaključano</span>
            }
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card forum-detail-card" style="padding: 2rem; margin-bottom: 2rem;">
    <div style="white-space: pre-wrap; font-size: 1.1rem; line-height: 1.6; color: var(--sl-text);">@Model.Sadrzaj</div>
    
    <div style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--sl-border); display: flex; align-items: center; gap: 1rem;">
        <form asp-action="ToggleReaction" method="post" id="reactionForm">
            <input type="hidden" name="objavaId" value="@Model.Id" />
            <button type="submit" class="btn reaction-button @(Model.KorisnikJeReagovao ? "btn-primary" : "btn-outline")" style="display: flex; gap: 0.5rem; align-items: center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-hand-thumbs-up" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M8.864.046C7.908-.193 7.02.53 6.956 1.466c-.072 1.051-.23 2.016-.428 2.59-.125.36-.479 1.013-1.04 1.639-.557.623-1.282 1.178-2.131 1.41C2.685 7.288 2 7.87 2 8.72v4.001c0 .845.682 1.464 1.448 1.545 1.07.114 1.564.415 2.068.723l.048.03c.272.165.578.348.97.484.397.136.861.217 1.466.217h3.5c.937 0 1.599-.477 1.934-1.064a1.86 1.86 0 0 0 .254-.912c0-.152-.023-.312-.077-.464.201-.263.38-.578.488-.901.11-.33.172-.762.004-1.149.069-.13.12-.269.159-.403.077-.27.113-.568.113-.857 0-.288-.036-.585-.113-.856a2.144 2.144 0 0 0-.138-.362 1.9 1.9 0 0 0 .234-1.734c-.206-.592-.682-1.1-1.2-1.272-.847-.282-1.803-.276-2.516-.211a9.84 9.84 0 0 0-.443.05 9.365 9.365 0 0 0-.062-4.509A1.38 1.38 0 0 0 9.125.111L8.864.046zM11.5 14.721H8c-.51 0-.863-.069-1.14-.164-.281-.097-.506-.228-.776-.393l-.04-.024c-.555-.339-1.198-.731-2.49-.868-.333-.036-.554-.29-.554-.55V8.72c0-.254.226-.543.62-.65 1.095-.3 1.977-.996 2.614-1.708.635-.71 1.064-1.475 1.238-1.978.243-.7.407-1.768.482-2.85.025-.362.36-.594.667-.518l.262.066c.16.04.258.143.288.255a8.34 8.34 0 0 1-.145 4.725.5.5 0 0 0 .595.644l.003-.001.014-.003.058-.014a8.908 8.908 0 0 1 1.036-.157c.663-.06 1.457-.054 2.11.164.175.058.45.3.57.65.107.308.087.67-.266 1.022l-.353.353.353.354c.043.043.105.141.154.315.048.167.075.37.075.581 0 .212-.027.414-.075.582-.05.174-.111.272-.154.315l-.353.353.353.354c.047.047.109.177.005.488a2.224 2.224 0 0 1-.505.805l-.353.353.353.354c.006.005.041.05.041.17a.866.866 0 0 1-.121.416c-.165.288-.503.56-1.066.56z"/>
                </svg>
                <span class="badge" style="background: rgba(255,255,255,0.2);">@Model.BrojReakcija</span>
            </button>
        </form>
    </div>
</div>

<div class="comments-section">
    <h3>Komentari (@Model.Komentari.Count)</h3>

    @if (!Model.Zakljucana)
    {
        <div class="card comment-form-card" style="margin-bottom: 2rem; padding: 1.5rem;">
            <form asp-action="PostComment" method="post">
                <input type="hidden" name="ObjavaId" value="@Model.Id" />
                <div class="form-group" style="margin-bottom: 1rem;">
                    <textarea name="Sadrzaj" class="form-control" rows="3" placeholder="Dodaj komentar..." required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Objavi komentar</button>
            </form>
        </div>
    }
    else
    {
        <div class="alert alert-warning" style="margin-bottom: 2rem;">
            Ova diskusija je zaključana. Nije moguće dodavati nove komentare.
        </div>
    }

    <div class="comments-list" style="display: flex; flex-direction: column; gap: 1rem;">
        @if (!Model.Komentari.Any())
        {
            <p style="color: var(--sl-muted);">Još nema komentara.</p>
        }
        else
        {
            foreach (var k in Model.Komentari)
            {
                <div class="card comment-card" style="padding: 1.2rem;">
                    <div class="comment-meta" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                        <div>
                            <strong>@k.AutorIme</strong> (@k.AutorUloga) - @k.DatumKreiranja.ToString("dd.MM.yyyy HH:mm")
                        </div>
                        <div style="display: flex; gap: 0.5rem;">
                            @if (jeOsoblje)
                            {
                                <form asp-action="DeleteComment" method="post"
                                      onsubmit="return confirm('Ukloniti ovaj komentar?');">
                                    <input type="hidden" name="komentarId" value="@k.Id" />
                                    <input type="hidden" name="objavaId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm" title="Ukloni neadekvatan komentar">🗑 Ukloni</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="ReportComment" method="post"
                                      onsubmit="return confirm('Prijaviti ovaj komentar kao neadekvatan?');">
                                    <input type="hidden" name="komentarId" value="@k.Id" />
                                    <input type="hidden" name="objavaId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-outline btn-sm" title="Prijavi neadekvatan komentar">🚩 Prijavi</button>
                                </form>
                            }
                        </div>
                    </div>
                    <div class="comment-body" style="white-space: pre-wrap;">@k.Sadrzaj</div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('reactionForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const form = e.target;
            
            try {
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });
                
                if (response.ok) {
                    const data = await response.json();
                    if (data.success) {
                        const btn = form.querySelector('button');
                        const badge = btn.querySelector('.badge');
                        
                        badge.textContent = data.count;
                        
                        if (data.reacted) {
                            btn.classList.remove('btn-outline');
                            btn.classList.add('btn-primary');
                        } else {
                            btn.classList.remove('btn-primary');
                            btn.classList.add('btn-outline');
                        }
                    }
                } else {
                    form.submit();
                }
            } catch (err) {
                form.submit();
            }
        });
    </script>
}
