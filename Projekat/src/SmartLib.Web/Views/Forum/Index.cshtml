@model SmartLib.Core.DTOs.ForumIndexViewModel
@{
    ViewData["Title"] = "Forum";
}

<style>
    .forum-container {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 2rem;
        margin-top: 2rem;
    }

    .forum-title {
        color: var(--sl-text);
    }

    .forum-subtitle {
        color: var(--sl-muted);
    }

    .forum-sidebar {
        background: var(--sl-card-solid);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        border: 1px solid var(--sl-border);
        height: fit-content;
    }

    .forum-sidebar h3 {
        color: var(--sl-text);
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--sl-border);
    }

    .nav-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .nav-list a {
        display: flex;
        align-items: center;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        color: var(--sl-muted);
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s ease-in-out;
    }

    .nav-list a:hover {
        background: rgba(59, 130, 246, 0.12);
        color: var(--sl-blue);
        transform: translateX(4px);
    }

    .nav-list a.active {
        background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
        color: #ffffff;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25);
    }

    .post-card {
        background: var(--sl-card);
        border: 1px solid var(--sl-border);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .post-card-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .post-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.2), 0 4px 6px -2px rgba(0, 0, 0, 0.1);
        border-color: rgba(59, 130, 246, 0.4);
    }

    .post-meta-badge {
        background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .post-title {
        color: var(--sl-text);
        font-size: 1.3rem;
        font-weight: 600;
        margin: 1rem 0 0.5rem 0;
        text-decoration: none;
        display: inline-block;
        transition: color 0.2s ease;
    }

    .post-card-link:hover .post-title {
        color: var(--sl-blue);
    }

    .post-snippet {
        color: var(--sl-muted);
        font-size: 0.98rem;
        line-height: 1.6;
    }

    .post-author {
        color: var(--sl-text);
        font-size: 0.95rem;
        font-weight: 600;
    }

    .post-author span {
        color: var(--sl-muted);
        font-weight: 500;
    }

    .post-author-bubble {
        width: 32px;
        height: 32px;
        background: rgba(15, 23, 42, 0.08);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: var(--sl-muted);
        font-size: 0.8rem;
    }

    .post-stats {
        font-size: 1rem;
        color: var(--sl-muted);
        gap: 1.1rem;
    }

    .post-stats svg {
        width: 18px;
        height: 18px;
    }

    [data-theme="dark"] .post-author-bubble {
        background: rgba(255, 255, 255, 0.08);
        color: #cbd5e1;
    }

    .empty-state {
        background: var(--sl-card);
        border: 1px dashed var(--sl-border);
        border-radius: 12px;
        padding: 4rem 2rem;
        text-align: center;
        color: var(--sl-muted);
    }

    .empty-state h2 {
        color: var(--sl-text);
        margin-bottom: 0.5rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="forum-title mb-1">Zajednica & Forum</h1>
        <p class="forum-subtitle mb-0">Pridružite se diskusijama, postavljajte pitanja i preporučite knjige.</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center gap-2" style="background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%); border: none; padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 500;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-lg" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z"/>
            </svg>
            Nova objava
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success rounded-3 shadow-sm border-0" style="background: rgba(16, 185, 129, 0.1); color: #34d399; border-left: 4px solid #10b981 !important;">
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger rounded-3 shadow-sm border-0" style="background: rgba(239, 68, 68, 0.1); color: #f87171; border-left: 4px solid #ef4444 !important;">
        @TempData["ErrorMessage"]
    </div>
}

<div class="forum-container">
    <!-- Sidebar / Kategorije -->
    <aside class="forum-sidebar">
        <h3>Kategorije</h3>
        <ul class="nav-list">
            <li>
                <a asp-action="Index" asp-route-kategorija="" 
                   class="@(string.IsNullOrEmpty(Model.AktivnaKategorija) ? "active" : "")">
                   <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-grid-fill me-2" viewBox="0 0 16 16">
                     <path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5v-3zm8 0A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5v-3zm-8 8A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5v-3zm8 0A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5v-3z"/>
                   </svg>
                   Sve objave
                </a>
            </li>
            @foreach(var k in Model.Kategorije)
            {
                <li>
                    <a asp-action="Index" asp-route-kategorija="@k" 
                       class="@(Model.AktivnaKategorija == k ? "active" : "")">
                       <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-hash me-2" viewBox="0 0 16 16">
                         <path d="M8.39 12.648a1.32 1.32 0 0 0-.015.18c0 .305.21.508.5.508.266 0 .492-.172.555-.477l.554-2.703h1.204c.421 0 .617-.234.617-.547 0-.312-.188-.53-.617-.53h-.985l.516-2.524h1.265c.43 0 .618-.227.618-.547 0-.313-.188-.524-.618-.524h-1.046l.476-2.304a1.06 1.06 0 0 0 .016-.164.51.51 0 0 0-.516-.516.54.54 0 0 0-.539.43l-.523 2.554H7.617l.477-2.304c.008-.04.015-.118.015-.164a.512.512 0 0 0-.523-.516.539.539 0 0 0-.531.43L6.53 5.484H5.414c-.43 0-.617.22-.617.532 0 .312.187.539.617.539h.906l-.515 2.523H4.609c-.421 0-.609.219-.609.531 0 .313.188.547.61.547h.976l-.516 2.492c-.008.04-.015.125-.015.18 0 .305.21.508.5.508.265 0 .492-.172.554-.477l.555-2.703h2.242l-.515 2.492zm-1-6.109h2.266l-.515 2.563H6.859l.532-2.563z"/>
                       </svg>
                       @k
                    </a>
                </li>
            }
        </ul>
    </aside>

    <!-- Lista objava -->
    <main class="forum-content">
        @if (!Model.Objave.Any())
        {
            <div class="empty-state">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-chat-square-text mb-3 text-secondary" viewBox="0 0 16 16">
                  <path d="M14 1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1h-2.5a2 2 0 0 0-1.6.8L8 14.333 6.1 11.8a2 2 0 0 0-1.6-.8H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2.5a1 1 0 0 1 .8.4l1.9 2.533a1 1 0 0 0 1.6 0l1.9-2.533a1 1 0 0 1 .8-.4H14a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/>
                  <path d="M3 3.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zM3 6a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9A.5.5 0 0 1 3 6zm0 2.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z"/>
                </svg>
                <h2>Nema objava u ovoj kategoriji</h2>
                <p>Budite prvi koji će započeti diskusiju i podijeliti svoje mišljenje!</p>
            </div>
        }
        else
        {
            <div>
                @foreach (var objava in Model.Objave)
                {
                    <a class="post-card post-card-link" asp-action="Details" asp-route-id="@objava.Id">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="post-meta-badge">@objava.Kategorija</span>
                            <div class="small d-flex align-items-center gap-2" style="color: var(--sl-muted);">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-clock" viewBox="0 0 16 16">
                                  <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
                                  <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
                                </svg>
                                @objava.DatumKreiranja.ToString("dd.MM.yyyy HH:mm")
                            </div>
                        </div>

                        <div class="post-title">@objava.Naslov</div>
                        
                        @if(objava.Zakljucana)
                        {
                            <span class="badge bg-danger ms-2" style="font-size: 0.7rem; vertical-align: middle;">🔒 Zaključano</span>
                        }
                        
                        <p class="post-snippet mt-2 mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @objava.Sadrzaj
                        </p>

                        <div class="d-flex justify-content-between align-items-center mt-3 pt-3" style="border-top: 1px solid var(--sl-border);">
                            <div class="d-flex align-items-center gap-2">
                                <div class="post-author-bubble">
                                    @(objava.AutorIme.Length > 0 ? objava.AutorIme.Substring(0, 1) : "?")
                                </div>
                                <span class="post-author">@objava.AutorIme <span>(@objava.AutorUloga)</span></span>
                            </div>
                            <div class="d-flex post-stats">
                                <span class="d-flex align-items-center gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-chat-text" viewBox="0 0 16 16">
                                      <path d="M2.678 11.894a1 1 0 0 1 .287.801 10.97 10.97 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8.06 8.06 0 0 0 8 14c3.996 0 7-2.807 7-6 0-3.192-3.004-6-7-6S1 4.808 1 8c0 1.468.617 2.83 1.678 3.894zm-.493 3.905a21.682 21.682 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a9.68 9.68 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9.06 9.06 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105z"/>
                                      <path d="M4 5.5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5zM4 8a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7A.5.5 0 0 1 4 8zm0 2.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 0 1h-4a.5.5 0 0 1-.5-.5z"/>
                                    </svg>
                                    @objava.BrojKomentara
                                </span>
                                <span class="d-flex align-items-center gap-1 @(objava.KorisnikJeReagovao ? "text-primary" : "")">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-hand-thumbs-up" viewBox="0 0 16 16">
                                      <path d="M8.864.046C7.908-.193 7.02.53 6.956 1.466c-.072 1.051-.23 2.016-.428 2.59-.125.36-.479 1.013-1.04 1.639-.557.623-1.282 1.178-2.131 1.41C2.685 7.288 2 7.87 2 8.72v4.001c0 .845.682 1.464 1.448 1.545 1.07.114 1.564.415 2.068.723l.048.03c.272.165.578.348.97.484.397.136.861.217 1.466.217h3.5c.937 0 1.599-.477 1.934-1.064a1.86 1.86 0 0 0 .254-.912c0-.152-.023-.312-.077-.464.201-.263.38-.578.488-.901.11-.33.172-.762.004-1.149.069-.13.12-.269.159-.403.077-.27.113-.568.113-.857 0-.288-.036-.585-.113-.856a2.144 2.144 0 0 0-.138-.362 1.9 1.9 0 0 0 .234-1.734c-.206-.592-.682-1.1-1.2-1.272-.847-.282-1.803-.276-2.516-.211a9.84 9.84 0 0 0-.443.05 9.365 9.365 0 0 0-.062-4.509A1.38 1.38 0 0 0 9.125.111L8.864.046zM11.5 14.721H8c-.51 0-.863-.069-1.14-.164-.281-.097-.506-.228-.776-.393l-.04-.024c-.555-.339-1.198-.731-2.49-.868-.333-.036-.554-.29-.554-.55V8.72c0-.254.226-.543.62-.65 1.095-.3 1.977-.996 2.614-1.708.635-.71 1.064-1.475 1.238-1.978.243-.7.407-1.768.482-2.85.025-.362.36-.594.667-.518l.262.066c.16.04.258.143.288.255a8.34 8.34 0 0 1-.145 4.725.5.5 0 0 0 .595.644l.003-.001.014-.003.058-.014a8.908 8.908 0 0 1 1.036-.157c.663-.06 1.457-.054 2.11.164.175.058.45.3.57.65.107.308.087.67-.266 1.022l-.353.353.353.354c.043.043.105.141.154.315.048.167.075.37.075.581 0 .212-.027.414-.075.582-.05.174-.111.272-.154.315l-.353.353.353.354c.047.047.109.177.005.488a2.224 2.224 0 0 1-.505.805l-.353.353.353.354c.006.005.041.05.041.17a.866.866 0 0 1-.121.416c-.165.288-.503.56-1.066.56z"/>
                                    </svg>
                                    @objava.BrojReakcija
                                </span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </main>
</div>
