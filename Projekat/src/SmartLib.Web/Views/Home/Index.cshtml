<!-- EVENTS -->
<section class="sec-events" id="dogadjaji">
    <div class="events-inner">
        <div class="events-head reveal">
            <div>
                <div class="events-kicker">Predstojeći događaji</div>
                <h2 class="events-title">Kalendar<br>aktivnosti</h2>
            </div>
            <a class="news-link" asp-controller="Kalendar" asp-action="Index">Svi događaji</a>
        </div>
        <div class="events-list">
            @{
                var delayClasses = new[] { "d1", "d2", "d3", "d4" };
                var bosnianMonths = new[] { "Jan", "Feb", "Mar", "Apr", "Maj", "Jun", "Jul", "Aug", "Sep", "Okt", "Nov", "Dec" };
            }
            @if (Model.UpcomingDogadjaji.Any())
            {
                for (int i = 0; i < Model.UpcomingDogadjaji.Count; i++)
                {
                    var ev = Model.UpcomingDogadjaji[i];
                    var delay = delayClasses[i % delayClasses.Length];
                    var meta = new System.Text.StringBuilder();
                    if (!string.IsNullOrEmpty(ev.Sat)) meta.Append(ev.Sat);
                    if (!string.IsNullOrEmpty(ev.Lokacija))
                    {
                        if (meta.Length > 0) meta.Append(" — ");
                        meta.Append(ev.Lokacija);
                    }
                    <div class="event-row reveal @delay">
                        <div class="event-date">
                            <span class="event-date-day">@ev.Datum.Day.ToString("D2")</span>
                            <span class="event-date-mon">@bosnianMonths[ev.Datum.Month - 1]</span>
                        </div>
                        <div class="event-content">
                            <span class="event-tag">@ev.Kategorija</span>
                            <div class="event-name">@ev.Naslov</div>
                            @if (meta.Length > 0)
                            {
                                <div class="event-meta">@meta.ToString()</div>
                            }
                        </div>
                        <div class="event-arrow">
                            <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="event-row reveal d1" style="opacity:.6;pointer-events:none;">
                    <div class="event-date">
                        <span class="event-date-day">—</span>
                        <span class="event-date-mon">—</span>
                    </div>
                    <div class="event-content">
                        <span class="event-tag">Info</span>
                        <div class="event-name">Nema predstojećih događaja</div>
                        <div class="event-meta">Pratite kalendar za nove najave</div>
                    </div>
                    <div class="event-arrow">
                        <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- NEWS -->
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,600;0,800;1,400;1,600&display=swap" rel="stylesheet">
<style>
  /* ── Home Vijesti Section ─────────────────────────────── */
  .sec-news{
    position:relative;overflow:hidden;
    background:linear-gradient(135deg,#07111f 0%,#0e2444 45%,#1B3D8F 100%);
    padding:6rem 2rem 5rem;
  }
  .hn-orb{position:absolute;border-radius:50%;pointer-events:none;}
  .hn-inner{max-width:1200px;margin:0 auto;position:relative;z-index:1;}
  .hn-header{display:grid;grid-template-columns:1fr auto;align-items:end;gap:2rem;margin-bottom:3rem;}
  .hn-kicker{display:flex;align-items:center;gap:.7rem;font-size:.76rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:#5A80C8;margin-bottom:1rem;}
  .hn-kicker::before{content:'';display:block;width:24px;height:2px;background:#5A80C8;}
  .hn-title{font-size:clamp(2.6rem,5vw,4.2rem);font-weight:800;letter-spacing:-.05em;line-height:.95;color:white;font-family:"Plus Jakarta Sans",Arial,sans-serif;}
  .hn-title em{font-style:italic;color:#5A80C8;}
  .hn-all-link{display:inline-flex;align-items:center;gap:.45rem;padding:.6rem 1.3rem;border-radius:999px;border:1.5px solid rgba(255,255,255,.22);background:rgba(255,255,255,.08);color:rgba(255,255,255,.82);font-family:"Manrope",sans-serif;font-size:.85rem;font-weight:700;text-decoration:none;white-space:nowrap;transition:background .18s,color .18s;}
  .hn-all-link:hover{background:rgba(255,255,255,.16);color:white;text-decoration:none;}
  .hn-all-link svg{width:12px;height:12px;}
  .hn-grid{display:grid;grid-template-columns:1.3fr 1fr;gap:1.2rem;}
  .hn-main{grid-row:span 2;}
  .hn-side{display:flex;flex-direction:column;gap:1.2rem;}
  .hn-card{border-radius:20px;overflow:hidden;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);display:flex;flex-direction:column;cursor:pointer;transition:transform .3s cubic-bezier(.16,1,.3,1),background .3s;}
  .hn-card:hover{transform:translateY(-4px);background:rgba(255,255,255,.08);}
  .hn-card-media{width:100%;overflow:hidden;background:#0D3373;flex-shrink:0;}
  .hn-main .hn-card-media{height:320px;}
  .hn-card-media svg,.hn-card-media img{width:100%;height:100%;display:block;object-fit:cover;}
  .hn-card-body{padding:1.6rem;flex:1;display:flex;flex-direction:column;gap:.7rem;}
  .hn-main .hn-card-body{padding:2rem;}
  .hn-card-tag{display:inline-block;padding:.22rem .65rem;border-radius:999px;background:rgba(90,128,200,.22);color:#A8C8E8;font-size:.68rem;font-weight:800;letter-spacing:.07em;text-transform:uppercase;width:fit-content;}
  .hn-card-title{font-family:"Plus Jakarta Sans",Arial,sans-serif;font-weight:800;letter-spacing:-.03em;color:white;line-height:1.2;}
  .hn-main .hn-card-title{font-size:1.4rem;}
  .hn-card-title{font-size:1rem;}
  .hn-card-date{font-size:.78rem;color:rgba(255,255,255,.32);font-weight:600;margin-top:auto;}
  .hn-card-excerpt{font-size:.88rem;color:rgba(255,255,255,.52);line-height:1.65;}
  .hn-side .hn-card{flex-direction:row;}
  .hn-side .hn-card-media{width:120px;flex-shrink:0;height:auto;min-height:100px;}
  .hn-side .hn-card-body{padding:1.1rem 1.3rem 1.1rem 0;}
  .hn-empty{text-align:center;padding:4rem 2rem;color:rgba(255,255,255,.35);}
  .hn-empty svg{width:56px;height:56px;display:block;margin:0 auto 1rem;opacity:.25;}
  @@media(max-width:860px){
    .hn-grid{grid-template-columns:1fr;}
    .hn-main{grid-row:span 1;}
    .hn-side .hn-card{flex-direction:column;}
    .hn-side .hn-card-media{width:100%;height:140px;}
    .hn-header{grid-template-columns:1fr;gap:1rem;}
  }
</style>

<section class="sec-news" id="vijesti">
  <div class="hn-orb" style="width:600px;height:600px;right:-120px;top:-180px;background:radial-gradient(circle,rgba(27,61,143,.35) 0%,transparent 70%);"></div>
  <div class="hn-orb" style="width:280px;height:280px;left:-60px;bottom:-80px;background:radial-gradient(circle,rgba(90,128,200,.2) 0%,transparent 70%);"></div>
  <div class="hn-inner">
    <div class="hn-header reveal">
      <div>
        <div class="hn-kicker">SmartLib — Novosti</div>
        <h2 class="hn-title">Vijesti<br><em>&amp; novosti</em></h2>
      </div>
      <a class="hn-all-link" asp-controller="Vijest" asp-action="Index">
        Sve vijesti
        <svg viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    @if (!Model.RecentVijesti.Any())
    {
      <div class="hn-empty reveal">
        <svg viewBox="0 0 64 64" fill="none"><rect x="8" y="12" width="48" height="40" rx="6" stroke="currentColor" stroke-width="2"/><path d="M20 24h24M20 32h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <p>Nema objavljenih vijesti.</p>
      </div>
    }
    else
    {
      var hnFeatured = Model.RecentVijesti.First();
      var hnRest = Model.RecentVijesti.Skip(1).ToList();
      string HnMediaBg(string cat) => (cat?.ToLower() ?? "") switch {
          "forum"     => "#1B3D8F",
          "edukacija" => "#060F3A",
          "događaji"  => "#173b63",
          "djeca"     => "#0D3373",
          _           => "#0D3373"
      };

      <div class="hn-grid">
        <!-- Featured card -->
        <div class="hn-main reveal">
          <a class="hn-card" asp-controller="Vijest" asp-action="Index" style="text-decoration:none;">
            <div class="hn-card-media">
              @if (!string.IsNullOrEmpty(hnFeatured.SlikaUrl))
              {
                <img src="@hnFeatured.SlikaUrl" alt="@hnFeatured.Naslov" />
              }
              else
              {
                <svg viewBox="0 0 560 320" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%">
                  <defs><pattern id="hnp0" width="14" height="14" patternUnits="userSpaceOnUse" patternTransform="rotate(30)"><line x1="0" y1="0" x2="0" y2="14" stroke="#1B3D8F" stroke-width="2"/></pattern></defs>
                  <rect width="560" height="320" fill="@HnMediaBg(hnFeatured.Kategorija)"/>
                  <rect width="560" height="320" fill="url(#hnp0)" opacity="0.22"/>
                  <ellipse cx="280" cy="160" rx="130" ry="90" fill="rgba(27,61,143,0.28)"/>
                </svg>
              }
            </div>
            <div class="hn-card-body">
              <span class="hn-card-tag">@hnFeatured.Kategorija</span>
              <div class="hn-card-title">@hnFeatured.Naslov</div>
              <p class="hn-card-excerpt">@(hnFeatured.Sadrzaj.Length > 160 ? hnFeatured.Sadrzaj.Substring(0, 160) + "…" : hnFeatured.Sadrzaj)</p>
              <div class="hn-card-date">@hnFeatured.DatumObjave.ToString("dd/MM/yyyy")</div>
            </div>
          </a>
        </div>

        <!-- Side cards -->
        <div class="hn-side">
          @for (int i = 0; i < hnRest.Count; i++)
          {
            var v = hnRest[i];
            var dCls = i == 0 ? "d1" : (i == 1 ? "d2" : "d3");
            <a class="hn-card reveal @dCls" asp-controller="Vijest" asp-action="Index" style="text-decoration:none;">
              <div class="hn-card-media">
                @if (!string.IsNullOrEmpty(v.SlikaUrl))
                {
                  <img src="@v.SlikaUrl" alt="@v.Naslov" />
                }
                else
                {
                  <svg viewBox="0 0 120 100" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%">
                    <defs><pattern id="hnps@(i)" width="10" height="10" patternUnits="userSpaceOnUse" patternTransform="rotate(-40)"><line x1="0" y1="0" x2="0" y2="10" stroke="rgba(196,217,255,0.35)" stroke-width="1.5"/></pattern></defs>
                    <rect width="120" height="100" fill="@HnMediaBg(v.Kategorija)"/>
                    <rect width="120" height="100" fill="url(#hnps@(i))" opacity="0.28"/>
                  </svg>
                }
              </div>
              <div class="hn-card-body">
                <span class="hn-card-tag">@v.Kategorija</span>
                <div class="hn-card-title">@v.Naslov</div>
                <div class="hn-card-date">@v.DatumObjave.ToString("dd/MM/yyyy")</div>
              </div>
            </a>
          }
        </div>
      </div>
    }
  </div>
</section>

<!-- FAQ -->
<section class="sec-faq" id="faq">
    <div class="faq-inner">
        <div class="faq-head">
            <div class="reveal faq-kicker">Česta pitanja</div>
            <h2 class="reveal d1 faq-title">Imate pitanja?<br>Imamo odgovore.</h2>
        </div>
        <div class="faq-list reveal d2">
            <div class="faq-item">
                <button class="faq-q" aria-expanded="false">
                    Kako se prijaviti na SmartLib?
                    <span class="faq-ico">+</span>
                </button>
                <div class="faq-ans">
                    <div class="faq-ans-inner">Nalog kreira bibliotekar ili administrator pri prvom posjetu biblioteci. Nakon toga, prijavite se sa dodijeljenim podacima klikom na "Prijava" u gornjem desnom uglu stranice.</div>
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-q" aria-expanded="false">
                    Kako pozajmiti knjigu putem platforme?
                    <span class="faq-ico">+</span>
                </button>
                <div class="faq-ans">
                    <div class="faq-ans-inner">Pronađite željenu knjigu u katalogu, provjerite dostupnost i pošaljite zahtjev za zaduženje (rezervacija). Bibliotekar će odobriti zahtjev, a vi preuzimate knjigu u biblioteci. Rok vraćanja vidite u svom profilu.</div>
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-q" aria-expanded="false">
                    Koliko knjiga mogu imati zaduženo istovremeno?
                    <span class="faq-ico">+</span>
                </button>
                <div class="faq-ans">
                    <div class="faq-ans-inner">Standardno, svaki član može imati do 3 knjige zadužene istovremeno uz rok vraćanja od 14 dana. Produženje je moguće ukoliko knjiga nije rezervisana od drugog člana.</div>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-q" aria-expanded="false">
                    Je li SmartLib dostupan na mobilnim uređajima?
                    <span class="faq-ico">+</span>
                </button>
                <div class="faq-ans">
                    <div class="faq-ans-inner">SmartLib je potpuno responzivan i prilagođen svim uređajima. Pregledajte katalog, provjerite zaduženja sa svog telefona, tableta ili računara bez instalacije ikakve aplikacije.</div>
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-q" aria-expanded="false">
                    Kako kontaktirati biblioteku?
                    <span class="faq-ico">+</span>
                </button>
                <div class="faq-ans">
                    <div class="faq-ans-inner">Bibliotekari su dostupni putem platforme za sve upite i prijedloge. Možete ih kontaktirati putem maila ili posjetiti biblioteku u radnom vremenu.</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="sec-cta">
    <div class="cta-inner">
        <h2 class="reveal cta-title">Pristupite<br><em>SmartLib sistemu</em></h2>
        <p class="reveal d1 cta-sub">Mnoštvo knjiga, moderna biblioteka i sve na jednom mjestu. Prijavite se i otkrijte svoju sljedeću omiljenu knjigu.</p>
        <div class="reveal d2 cta-btns">
            @if (!(User.Identity?.IsAuthenticated ?? false))
            {
                <a asp-controller="Auth" asp-action="Login" class="cta-primary" aria-hidden="true">Prijava</a>
            }
            <a asp-controller="Knjiga" asp-action="Index" class="cta-secondary">Pogledajte katalog</a>
            <a asp-controller="Forum" asp-action="Index" class="cta-secondary">Forum zajednice</a>
        </div>
    </div>
</section>

@section Scripts {
<script>
    /* SCROLL REVEAL */
    const _obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
            if (e.isIntersecting) { e.target.classList.add('in'); _obs.unobserve(e.target); }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => _obs.observe(el));

    /* COUNTER ANIMATION */
    function runCounter(el, target, dur) {
        let t0 = null;
        const step = (ts) => {
            if (!t0) t0 = ts;
            const p = Math.min((ts - t0) / dur, 1);
            el.textContent = Math.round((1 - Math.pow(1 - p, 3)) * target);
            if (p < 1) requestAnimationFrame(step); else el.textContent = target;
        };
        requestAnimationFrame(step);
    }
    const _ctrObs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
            if (e.isIntersecting) {
                runCounter(e.target, parseInt(e.target.dataset.target, 10), 1600);
                _ctrObs.unobserve(e.target);
            }
        });
    }, { threshold: 0.6 });
    document.querySelectorAll('.counter').forEach(el => _ctrObs.observe(el));

    /* FAQ ACCORDION */
    document.querySelectorAll('.faq-q').forEach(btn => {
        btn.addEventListener('click', () => {
            const isOpen = btn.classList.contains('open');
            document.querySelectorAll('.faq-q').forEach(b => {
                b.classList.remove('open');
                b.setAttribute('aria-expanded', 'false');
                b.nextElementSibling.classList.remove('open');
            });
            if (!isOpen) {
                btn.classList.add('open');
                btn.setAttribute('aria-expanded', 'true');
                btn.nextElementSibling.classList.add('open');
            }
        });
    });

    /* SPARKLES — subtle glowing dots, homepage only */
    (function(){
        var style = document.createElement('style');
        style.textContent =
            '@@keyframes sp-a{0%{transform:translate(0,0) scale(1);opacity:.85}25%{transform:translate(7px,-20px) scale(1.18);opacity:1}65%{transform:translate(-4px,-9px) scale(0.82);opacity:.5}100%{transform:translate(0,0) scale(1);opacity:.85}}' +
            '@@keyframes sp-b{0%{transform:translate(0,0) scale(1);opacity:.6}35%{transform:translate(-9px,-25px) scale(0.75);opacity:.95}72%{transform:translate(6px,-11px) scale(1.15);opacity:.45}100%{transform:translate(0,0) scale(1);opacity:.6}}' +
            '@@keyframes sp-c{0%{transform:translate(0,0) scale(1);opacity:.75}50%{transform:translate(5px,-30px) scale(0.68);opacity:.3}100%{transform:translate(0,0) scale(1);opacity:.75}}' +
            '@@keyframes sp-d{0%{transform:translate(0,0) scale(1);opacity:.45}40%{transform:translate(-7px,-16px) scale(1.22);opacity:.85}78%{transform:translate(8px,-6px) scale(0.88);opacity:.25}100%{transform:translate(0,0) scale(1);opacity:.45}}';
        document.head.appendChild(style);

        var anims  = ['sp-a','sp-b','sp-c','sp-d'];
        var colors = [[90,128,200],[196,217,255],[255,255,255],[27,61,143],[150,185,255]];
        var cfg = [
            {sel:'.home-hero',           n:55},
            {sel:'.ticker-wrap',         n:14},
            {sel:'.sec-reading',         n:34},
            {sel:'.sec-features',        n:24},
            {sel:'.sec-news',            n:28},
            {sel:'.home-featured-books', n:20}
        ];
        cfg.forEach(function(item){
            var s = document.querySelector(item.sel);
            if (!s) return;
            s.style.position = 'relative';
            s.style.overflow = 'hidden';
            var L = document.createElement('div');
            L.setAttribute('aria-hidden','true');
            L.style.cssText = 'position:absolute;inset:0;pointer-events:none;z-index:0;overflow:hidden;';
            s.insertBefore(L, s.firstChild);
            for (var i = 0; i < item.n; i++) {
                var el   = document.createElement('span');
                var sz   = (1.5 + Math.random() * 3.5).toFixed(1);
                var c    = colors[Math.floor(Math.random() * colors.length)];
                var op   = (0.18 + Math.random() * 0.44).toFixed(2);
                var glow = (parseFloat(sz) * 2.8).toFixed(1);
                var dur  = (7 + Math.random() * 10).toFixed(1);
                var del  = (-Math.random() * 10).toFixed(1);
                el.style.cssText = [
                    'display:block','position:absolute','border-radius:50%',
                    'width:'  + sz + 'px','height:' + sz + 'px',
                    'left:'   + (Math.random()*100).toFixed(1) + '%',
                    'top:'    + (Math.random()*100).toFixed(1) + '%',
                    'opacity:' + op,
                    'background:rgba(' + c[0] + ',' + c[1] + ',' + c[2] + ',' + op + ')',
                    'box-shadow:0 0 ' + glow + 'px ' + glow + 'px rgba(' + c[0] + ',' + c[1] + ',' + c[2] + ',' + (parseFloat(op)*0.38).toFixed(2) + ')',
                    'animation:' + anims[Math.floor(Math.random()*3)] + ' ' + dur + 's ' + del + 's infinite ease-in-out',
                    'will-change:transform,opacity'
                ].join(';');
                L.appendChild(el);
            }
        });
    })();
</script>
}
