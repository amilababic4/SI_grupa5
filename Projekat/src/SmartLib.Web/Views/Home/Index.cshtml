@{
    ViewData["Title"] = "SmartLib";
    ViewData["BodyClass"] = "home-page";
    ViewData["MainClass"] = "page-shell page-shell--full";
}

<section class="home-hero" aria-labelledby="smartlib-title">
    <img class="home-hero-image" src="~/images/smartlib-hero-books.png" alt="" aria-hidden="true" />
    <div class="home-hero-shine" aria-hidden="true"></div>

    <div class="home-hero-content">
        <p class="home-eyebrow">Informacioni sistem za biblioteku</p>
        <h1 id="smartlib-title">SmartLib</h1>
        <p class="home-lead">
            Moderna platforma za biblioteku koja omogućava jednostavno upravljanje knjigama, članovima i zaduženjima na jednom mjestu.
        </p>
        @* Dugme se prikazuje samo ako korisnik NIJE autentifikovan *@
        @if (!(User.Identity?.IsAuthenticated ?? false))
        {
            <a asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-hero">Prijava u sistem</a>
        }
    </div>
</section>

<section class="home-features" aria-label="Funkcionalnosti sistema">
    <div class="home-features-inner">
        <p class="home-features-eyebrow">Šta nudi SmartLib?</p>
        <h2 class="home-features-title">Sve na jednom mjestu</h2>
        <p class="home-features-lead">
            SmartLib je informacioni sistem za biblioteke koji omogućava digitalno upravljanje
            knjigama, primjercima, članovima, članarinama i evidencijom zaduživanja.
        </p>
        <div class="home-features-grid">
            <div class="home-feature-card">
                <span class="home-feature-num">01</span>
                <h3>Katalog knjiga</h3>
                <p>Pretraga i pregled svih knjiga u fondu sa statusom dostupnosti primjeraka.</p>
            </div>
            <div class="home-feature-card">
                <span class="home-feature-num">02</span>
                <h3>Upravljanje clanovima</h3>
                <p>Registracija clanova, pregled profila i pracenje statusa naloga.</p>
            </div>
            <div class="home-feature-card">
                <span class="home-feature-num">03</span>
                <h3>Evidencija zaduzenja</h3>
                <p>Zaduzivanje i vracanje knjiga uz automatski rok i pregled aktivnih zaduzenja.</p>
            </div>
            <div class="home-feature-card">
                <span class="home-feature-num">04</span>
                <h3>Pracenje clanarina</h3>
                <p>Upravljanje clanарinama i provjera prava na zaduzivanje knjiga.</p>
            </div>
        </div>
    </div>
</section>
