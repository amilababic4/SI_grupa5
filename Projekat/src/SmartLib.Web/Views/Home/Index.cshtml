                    <rect width="600" height="590" fill="#D0E3FF"/><rect width="600" height="590" fill="url(#gp1)" opacity="0.14"/>
                    <text x="300" y="290" text-anchor="middle" dominant-baseline="middle" font-family="monospace" font-size="12" fill="#081F5C" opacity="0.45">main library hall · photo</text>
                </svg>
            </div>
            <div class="g-item reveal d1">
