                <svg viewBox="0 0 300 290" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:none">
                    <defs><pattern id="gp3" width="10" height="10" patternUnits="userSpaceOnUse" patternTransform="rotate(60)"><line x1="0" y1="0" x2="0" y2="10" stroke="#334EAC" stroke-width="1"/></pattern></defs>
                    <rect width="300" height="290" fill="#F7F2EB"/><rect width="300" height="290" fill="url(#gp3)" opacity="0.17"/>
                    <text x="150" y="143" text-anchor="middle" dominant-baseline="middle" font-family="monospace" font-size="10" fill="#081F5C" opacity="0.4">reading room · photo</text>
                </svg>
            </div>
            <div class="g-item reveal d3">
