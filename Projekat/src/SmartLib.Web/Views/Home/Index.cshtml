@model SmartLib.Web.Models.HomeViewModel
@{
    ViewData["Title"] = "SmartLib";
    ViewData["BodyClass"] = "home-page";
    ViewData["MainClass"] = "page-shell page-shell--full";
}

<section class="home-hero" aria-labelledby="smartlib-title">
    <img class="home-hero-image" src="~/images/smartlib-hero-books.png" alt="" aria-hidden="true" />
    <div class="home-hero-shine" aria-hidden="true"></div>

    <div class="home-hero-content">
        <p class="home-eyebrow">Informacioni sistem za biblioteku</p>
        <h1 id="smartlib-title">SmartLib</h1>
        <p class="home-lead">
            Moderna platforma za biblioteku koja omogućava jednostavno upravljanje knjigama, članovima i zaduženjima na jednom mjestu.
        </p>
        <div class="home-search-container">
            <form asp-controller="Knjiga" asp-action="Index" method="get" class="hero-search-form">
                <input type="text" name="naslov" class="hero-search-input" placeholder="Pretražite katalog knjiga..." />
                <button type="submit" class="hero-search-btn">Traži</button>
            </form>
        </div>
        <div class="home-hero-actions">
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a asp-controller="Knjiga" asp-action="Index" class="btn btn-secondary btn-home-secondary">Pregledaj katalog</a>
            }
            @if (!(User.Identity?.IsAuthenticated ?? false))
            {
                <a asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-hero">Prijava u sistem</a>
            }
        </div>
    </div>
</section>

@if (Model.RecommendedKnjige.Any())
{
    <section class="home-featured-books recommended-section" aria-label="Preporučeno za vas" style="background: var(--bg-alt);">
        <div class="container">
            <div class="featured-header">
                <h2>Preporučeno za vas</h2>
                <p style="color: var(--text-muted); font-size: 0.9rem;">Na osnovu vaše historije čitanja</p>
            </div>
            <div class="books-grid">
                @foreach (var knjiga in Model.RecommendedKnjige)
                {
                    <a asp-controller="Knjiga" asp-action="Details" asp-route-id="@knjiga.Id" class="book-card">
                        <div class="book-cover-wrapper">
                            <img src="@Url.Action("Korice", "Knjiga", new { isbn = knjiga.Isbn, size = "L" })" alt="@knjiga.Naslov" loading="lazy" />
                            <div class="book-overlay">
                                <span class="view-details-icon">
                                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                                </span>
                                <span class="view-details-text">Detalji</span>
                            </div>
                        </div>
                        <div class="book-info">
                            <span class="book-title">@knjiga.Naslov</span>
                            <span class="book-year">@knjiga.GodinaIzdanja.</span>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>
}

@if (Model.RandomKnjige.Any())
{
    <section class="home-featured-books" aria-label="Nasumični naslovi">
        <div class="container">
            <div class="featured-header">
                <h2>Nasumični naslovi</h2>
                <a asp-controller="Knjiga" asp-action="Index" class="browse-more">vidi sve...</a>
            </div>
            <div class="books-grid">
                @foreach (var knjiga in Model.RandomKnjige)
                {
                    <a asp-controller="Knjiga" asp-action="Details" asp-route-id="@knjiga.Id" class="book-card">
                        <div class="book-cover-wrapper">
                            <img src="@Url.Action("Korice", "Knjiga", new { isbn = knjiga.Isbn, size = "L" })" alt="@knjiga.Naslov" loading="lazy" />
                            <div class="book-overlay">
                                <span class="view-details-icon">
                                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                                </span>
                                <span class="view-details-text">Detalji</span>
                            </div>
                        </div>
                        <div class="book-info">
                            <span class="book-title">@knjiga.Naslov</span>
                            <span class="book-year">@knjiga.GodinaIzdanja.</span>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>
}

<!-- TICKER -->
<div class="ticker-wrap" aria-hidden="true">
    <div class="ticker-track">
        <span class="tick-item"><span class="tick-dot"></span>Katalog knjiga</span>
        <span class="tick-item"><span class="tick-dot"></span>Forum zajednice</span>
        <span class="tick-item"><span class="tick-dot"></span>Sistem zaduženja</span>
        <span class="tick-item"><span class="tick-dot"></span>Upravljanje bibliotekom</span>
        <span class="tick-item"><span class="tick-dot"></span>Preporuke naslova</span>
        <span class="tick-item"><span class="tick-dot"></span>Fizičke knjige</span>
        <span class="tick-item"><span class="tick-dot"></span>Zajednica čitača</span>
        <span class="tick-item"><span class="tick-dot"></span>Pretrage i filteri</span>
        <span class="tick-item"><span class="tick-dot"></span>Katalog knjiga</span>
        <span class="tick-item"><span class="tick-dot"></span>Forum zajednice</span>
        <span class="tick-item"><span class="tick-dot"></span>Sistem zaduženja</span>
        <span class="tick-item"><span class="tick-dot"></span>Upravljanje bibliotekom</span>
        <span class="tick-item"><span class="tick-dot"></span>Preporuke naslova</span>
        <span class="tick-item"><span class="tick-dot"></span>Fizičke knjige</span>
        <span class="tick-item"><span class="tick-dot"></span>Zajednica čitača</span>
        <span class="tick-item"><span class="tick-dot"></span>Pretrage i filteri</span>
    </div>
</div>

<!-- ABOUT -->
<section class="sec-about" id="o-nama">
    <div class="about-inner">
        <div>
            <div class="reveal about-kicker">O platformi</div>
            <h2 class="reveal d1 about-title">Vaša biblioteka,<br><em>digitalizovana.</em></h2>
            <p class="reveal d2 about-body">SmartLib je savremena platforma koja spaja čitaoce, knjige i bibliotekare u jednom digitalnom prostoru. Upravljajte katalogom, pratite zaduženja i učestvujte u forumima — sve na jednom mjestu, dostupno sa bilo kojeg uređaja.</p>
            <div class="reveal d3 about-stats">
                <div class="stat-item">
                    <span class="stat-num"><span class="counter" data-target="50">0</span><sup>+</sup></span>
                    <span class="stat-label">Knjiga u katalogu</span>
                </div>
                <div class="stat-item">
                    <span class="stat-num"><span class="counter" data-target="20">0</span><sup>+</sup></span>
                    <span class="stat-label">Aktivnih članova</span>
                </div>
                <div class="stat-item">
                    <span class="stat-num"><span class="counter" data-target="12">0</span><sup>+</sup></span>
                    <span class="stat-label">Forumskih tema</span>
                </div>
            </div>
        </div>
        <div class="about-photos reveal d2">
            <div class="photo-slot photo-tall">
                <img src="~/images/booooks.png" alt="Biblioteka" />
            </div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="sec-features" id="funkcionalnosti">
    <div class="features-inner">
        <div class="features-sticky reveal">
            <div class="feat-kicker">Šta nudimo</div>
            <h2 class="feat-title">Sve što vaša<br>biblioteka <em>treba.</em></h2>
            <p class="feat-body">SmartLib objedinjuje sve segmente bibliotečkog poslovanja u jednu intuitivnu platformu — od upravljanja katalogom do angažmana zajednice čitača.</p>
        </div>
        <div class="feat-list">
            <div class="feat-item reveal d1">
                <span class="feat-n">01</span>
                <div>
                    <div class="feat-name">Digitalni katalog knjiga</div>
                    <div class="feat-text">Pregledajte hiljade naslova. Pretražujte po autoru, naslovu, ISBN-u ili žanru. Svaka knjiga ima detaljan opis i status dostupnosti u realnom vremenu.</div>
                </div>
            </div>
            <div class="feat-item reveal d2">
                <span class="feat-n">02</span>
                <div>
                    <div class="feat-name">Sistem zaduženja i povrata</div>
                    <div class="feat-text">Automatsko praćenje pozajmljenih knjiga, rokova vraćanja i historije transakcija. Podsjetnici za članove — ništa ne ostaje nezabilježeno.</div>
                </div>
            </div>
            <div class="feat-item reveal d3">
                <span class="feat-n">03</span>
                <div>
                    <div class="feat-name">Praćenje članarina</div>
                    <div class="feat-text">Upravljanje članarinama i provjera prava na zaduživanje knjiga. Pregled statusa i historije plaćanja na jednom mjestu.</div>
                </div>
            </div>
            <div class="feat-item reveal d4">
                <span class="feat-n">04</span>
                <div>
                    <div class="feat-name">Alati za bibliotekare</div>
                    <div class="feat-text">Potpuni pregled nad katalogom, članovima i transakcijama. Dodajte naslove, upravljajte primjercima i korisničkim profilima iz jedne kontrolne table.</div>
                </div>
            </div>
            <div class="feat-item reveal d5">
                <span class="feat-n">05</span>
                <div>
                    <div class="feat-name">Pametne preporuke</div>
                    <div class="feat-text">Otkrijte svoju sljedeću omiljenu knjigu kroz sistem preporuka zasnovan na žanrovskim preferencijama i historiji čitanja — kao vaš lični bibliotekar.</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ROLES -->
<section class="sec-roles" id="korisnici">
    <div class="roles-inner">
        <div class="roles-head">
            <div class="reveal roles-kicker">Za koga je SmartLib</div>
            <h2 class="reveal d1 roles-title">Platforma dizajnirana<br>za svakoga</h2>
            <p class="reveal d2 roles-sub">Bilo da ste čitalac koji traži novu knjigu ili bibliotekar koji upravlja sistemom — SmartLib ima sve što trebate.</p>
        </div>
        <div class="roles-grid roles-grid--two">
            <div class="role-card reveal d1">
                <div class="role-icon">📖</div>
                <div>
                    <div class="role-name">Čitatelji</div>
                    <p class="role-desc">Za sve ljubitelje knjiga koji žele jednostavan pristup bibliotečkom katalogu i zajednici čitača.</p>
                </div>
                <ul class="role-perks">
                    <li class="role-perk"><span class="role-perk-dot"><svg viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="#334EAC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Pretraživanje kataloga</li>
                    <li class="role-perk"><span class="role-perk-dot"><svg viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="#334EAC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Pozajmljivanje knjiga</li>
                    <li class="role-perk"><span class="role-perk-dot"><svg viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="#334EAC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Historija čitanja</li>
                    <li class="role-perk"><span class="role-perk-dot"><svg viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="#334EAC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Pametne preporuke</li>
                </ul>
            </div>
            <div class="role-card featured reveal d2">
                <div class="role-icon">🗂️</div>
                <div>
                    <div class="role-name">Bibliotekar</div>
                    <p class="role-desc">Za profesionalce koji upravljaju bibliotečkim fondom i pružaju usluge članovima svaki dan.</p>
                </div>
                <ul class="role-perks">
                    <li class="role-perk"><span class="role-perk-dot"><svg viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Upravljanje katalogom</li>
                    <li class="role-perk"><span class="role-perk-dot"><svg viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Evidencija zaduženja</li>
                    <li class="role-perk"><span class="role-perk-dot"><svg viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Upravljanje primjercima</li>
                    <li class="role-perk"><span class="role-perk-dot"><svg viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>Uvid u članove</li>
                </ul>
            </div>
        </div>
    </div>
</section>

