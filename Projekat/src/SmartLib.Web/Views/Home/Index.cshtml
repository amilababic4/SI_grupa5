                <svg viewBox="0 0 300 200" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:none">
                    <defs><pattern id="gp5" width="10" height="10" patternUnits="userSpaceOnUse" patternTransform="rotate(-25)"><line x1="0" y1="0" x2="0" y2="10" stroke="#334EAC" stroke-width="1.5"/></pattern></defs>
