@model IEnumerable<SmartLib.Core.Models.Dogadjaj>
@{
    ViewData["Title"] = "Kalendar";
    ViewData["MainClass"] = "kalendar-page-root";
    ViewData["BodyClass"] = "kalendar-public-page";

    bool isAdmin = User.IsInRole("Bibliotekar") || User.IsInRole("Administrator");
    var now = DateTime.Now;

    var thisMonthCount = Model.Count(d => d.Datum.Year == now.Year && d.Datum.Month == now.Month);
    var upcomingCount  = Model.Count(d => d.Datum >= now.Date);
    var daysInMonth    = DateTime.DaysInMonth(now.Year, now.Month);
    var progressPct    = (int)Math.Round((double)now.Day / daysInMonth * 100);
    var todayIso       = now.ToString("yyyy-MM-dd");
    var curYear        = now.Year;
    var curMonthJs     = now.Month - 1; // 0-indexed for JS Date

    var bosnianMonths = new[] {"januar","februar","mart","april","maj","juni","juli","august","septembar","oktobar","novembar","decembar"};
    var monthNameRaw  = bosnianMonths[now.Month - 1];
    var monthName     = char.ToUpper(monthNameRaw[0]) + monthNameRaw.Substring(1);
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,600;0,800;1,400;1,600&display=swap" rel="stylesheet">

<style>
  .kalendar-page-root { padding: 0; margin: 0; }

  :root {
    --sl-dark: #07111f; --cream: #F7F2EB; --cream-2: #F2F0DE;
    --royal: #1B3D8F; --midnight: #060F3A; --china: #5A80C8;
    --dawn: #C4D9FF; --porcelain: #E8EDF8;
    --ink: #0d1b2e; --ink-mid: #3d4f70; --ink-muted: #6b7a99;
  }

  .reveal { opacity: 0; transform: translateY(28px); transition: opacity .75s cubic-bezier(.16,1,.3,1), transform .75s cubic-bezier(.16,1,.3,1); }
  .reveal.in { opacity: 1; transform: none; }
  .d1 { transition-delay: .08s } .d2 { transition-delay: .16s } .d3 { transition-delay: .24s }

  /* ── HERO ─────────────────────────────────────────────── */
  .cal-hero { position: relative; overflow: hidden; padding: 6rem 2rem 5rem; background: linear-gradient(135deg,#07111f 0%,#0e2444 50%,#1B3D8F 100%); color: white; }
  .cal-hero-orb { position: absolute; border-radius: 50%; pointer-events: none; }
  .cal-hero-inner { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .cal-hero-kicker { display: flex; align-items: center; gap: .7rem; font-size: .78rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--china); margin-bottom: 1.4rem; }
  .cal-hero-kicker::before { content: ''; display: block; width: 28px; height: 2px; background: var(--china); }
  .cal-hero-title { font-size: clamp(3.5rem,7vw,6rem); font-weight: 800; letter-spacing: -.05em; line-height: .95; color: white; margin-bottom: 1.6rem; font-family: "Plus Jakarta Sans",Arial,sans-serif; }
  .cal-hero-title em { font-style: italic; color: var(--china); }
  .cal-hero-sub { font-size: 1rem; color: rgba(255,255,255,.6); line-height: 1.76; max-width: 420px; }
  .cal-hero-right { display: flex; flex-direction: column; gap: 1.2rem; }
  .cal-stat-card { background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.1); border-radius: 18px; padding: 1.5rem 1.8rem; display: flex; align-items: center; gap: 1.5rem; backdrop-filter: blur(8px); }
  .cal-stat-num { font-family: "Plus Jakarta Sans",sans-serif; font-size: 2.8rem; font-weight: 800; letter-spacing: -.06em; color: white; line-height: 1; }
  .cal-stat-label { font-size: .85rem; font-weight: 700; color: rgba(255,255,255,.7); line-height: 1.4; }
  .cal-stat-sub { font-size: .75rem; color: rgba(255,255,255,.38); margin-top: .2rem; }
  .cal-progress-bar { height: 3px; background: rgba(255,255,255,.12); border-radius: 999px; margin-top: .8rem; overflow: hidden; }
  .cal-progress-fill { height: 100%; background: var(--china); border-radius: 999px; transition: width 1s cubic-bezier(.16,1,.3,1); }

  /* ── MAIN SECTION ─────────────────────────────────────── */
  .cal-main { background: var(--cream); padding: 5rem 2rem; }
  .cal-main-inner { max-width: 1200px; margin: 0 auto; }
  .cal-layout { display: grid; grid-template-columns: 1fr 340px; gap: 2.5rem; align-items: start; }

  /* ── CALENDAR WIDGET ──────────────────────────────────── */
  .cal-widget { background: white; border-radius: 22px; padding: 2rem; box-shadow: 0 12px 40px rgba(6,15,58,.07); border: 1px solid rgba(27,61,143,.07); }
  .cal-widget-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  .cal-month-title { font-family: "Plus Jakarta Sans",sans-serif; font-size: 1.3rem; font-weight: 800; letter-spacing: -.03em; color: var(--ink); }
  .cal-nav-btns { display: flex; gap: .4rem; }
  .cal-nav-btn { width: 34px; height: 34px; border-radius: 50%; border: 1.5px solid rgba(27,61,143,.14); background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--ink-mid); transition: all .18s; }
  .cal-nav-btn:hover { border-color: var(--royal); color: var(--royal); }
  .cal-nav-btn svg { width: 13px; height: 13px; }
  .cal-filters { display: flex; gap: .4rem; flex-wrap: wrap; margin-bottom: 1.4rem; }
  .cal-filter { padding: .3rem .75rem; border-radius: 999px; border: 1.5px solid rgba(27,61,143,.12); background: transparent; font-family: "Manrope",sans-serif; font-size: .75rem; font-weight: 700; color: var(--ink-muted); cursor: pointer; transition: all .2s; }
  .cal-filter:hover { border-color: var(--royal); color: var(--royal); }
  .cal-filter.active { background: var(--royal); border-color: var(--royal); color: white; }
  .cal-grid { display: grid; grid-template-columns: repeat(7,1fr); gap: 3px; }
  .cal-day-hdr { text-align: center; font-size: .68rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: var(--ink-muted); padding: .5rem 0 .8rem; }
  .cal-cell { border-radius: 10px; border: 1.5px solid transparent; cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; padding: .5rem .2rem; font-size: .88rem; font-weight: 700; color: var(--ink); transition: all .2s; position: relative; min-height: 52px; }
  .cal-cell:hover:not(.cal-empty) { background: var(--dawn); border-color: var(--china); }
  .cal-cell.is-today { background: var(--royal); color: white; border-color: transparent; }
  .cal-cell.is-today:hover { background: var(--midnight); }
  .cal-cell.is-selected:not(.is-today) { background: var(--dawn); border-color: var(--royal); color: var(--royal); }
  .cal-cell.is-past:not(.is-today) { color: rgba(109,121,153,.45); }
  .cal-cell.cal-empty { cursor: default; pointer-events: none; }
  .cal-dots { display: flex; gap: 2px; flex-wrap: wrap; justify-content: center; }
  .cal-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
  .dot-zajednica { background: var(--royal); }
  .dot-edukacija { background: var(--china); }
  .dot-obavještenje, .dot-obaviještenje, .dot-ostalo { background: #0D3373; }
  .dot-djeca { background: #2554B8; }
  .dot-predavanje { background: var(--midnight); }

  /* ── DAY PANEL ────────────────────────────────────────── */
  .day-panel { background: white; border-radius: 22px; padding: 1.8rem; box-shadow: 0 12px 40px rgba(6,15,58,.07); border: 1px solid rgba(27,61,143,.07); position: sticky; top: 95px; }
  .day-panel-date { font-family: "Plus Jakarta Sans",sans-serif; font-size: 1.1rem; font-weight: 800; letter-spacing: -.03em; color: var(--ink); margin-bottom: 1.4rem; padding-bottom: .9rem; border-bottom: 1px solid rgba(27,61,143,.08); }
  .day-event { display: grid; grid-template-columns: 52px 1fr; gap: .8rem; align-items: start; padding: .9rem 0; border-bottom: 1px solid rgba(27,61,143,.06); }
  .day-event:last-child { border-bottom: none; }
  .day-event-time { font-family: "Plus Jakarta Sans",sans-serif; font-size: .82rem; font-weight: 800; color: var(--royal); padding-top: 2px; }
  .day-event-name { font-size: .9rem; font-weight: 700; color: var(--ink); line-height: 1.35; margin-bottom: .3rem; }
  .day-event-loc { font-size: .78rem; color: var(--ink-muted); font-weight: 600; margin-bottom: .4rem; }
  .day-event-cat { display: inline-block; padding: .18rem .55rem; border-radius: 999px; font-size: .65rem; font-weight: 800; letter-spacing: .05em; text-transform: uppercase; }
  .day-empty { text-align: center; padding: 2rem 0; color: var(--ink-muted); }
  .day-empty-line { width: 32px; height: 2px; background: rgba(27,61,143,.15); margin: 0 auto .8rem; }
  .day-empty p { font-size: .88rem; font-weight: 600; }

  /* cat chip colours */
  .cat-dot-zajednica { background: rgba(27,61,143,.12); color: var(--royal); }
  .cat-dot-edukacija { background: rgba(90,128,200,.18); color: var(--china); }
  .cat-dot-obavještenje, .cat-dot-obaviještenje, .cat-dot-ostalo { background: rgba(13,51,115,.12); color: #0D3373; }
  .cat-dot-djeca { background: rgba(196,217,255,.55); color: var(--royal); }
  .cat-dot-predavanje { background: rgba(6,15,58,.1); color: var(--midnight); }

  /* admin event actions */
  .day-event-admin { display: flex; gap: .3rem; margin-top: .45rem; }
  .btn-ev-edit, .btn-ev-del { font-size: .68rem; font-weight: 700; padding: .22rem .6rem; border-radius: 999px; border: none; cursor: pointer; font-family: "Manrope",sans-serif; transition: opacity .18s; }
  .btn-ev-edit { background: rgba(27,61,143,.1); color: var(--royal); }
  .btn-ev-edit:hover { background: rgba(27,61,143,.2); }
  .btn-ev-del { background: rgba(180,35,24,.1); color: #b42318; }
  .btn-ev-del:hover { background: rgba(180,35,24,.2); }

  /* add-event button in day panel (admin only) */
  .adm-day-btn { width: 100%; margin-top: .9rem; padding: .68rem 1rem; border-radius: 12px; border: 2px dashed rgba(27,61,143,.22); background: rgba(27,61,143,.04); color: var(--royal); font-family: "Manrope",sans-serif; font-size: .86rem; font-weight: 700; cursor: pointer; transition: all .18s; display: flex; align-items: center; justify-content: center; gap: .5rem; }
  .adm-day-btn:hover { background: rgba(27,61,143,.09); border-color: var(--royal); }
  .adm-day-btn svg { width: 14px; height: 14px; }

  /* ── UPCOMING SECTION ─────────────────────────────────── */
  .cal-upcoming { background: var(--porcelain); padding: 7rem 2rem; }
  .cal-upcoming-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 380px 1fr; gap: 6rem; align-items: start; }
  .upcoming-head-kicker { font-size: .74rem; font-weight: 700; letter-spacing: .22em; text-transform: uppercase; color: var(--royal); margin-bottom: 1rem; display: flex; align-items: center; gap: .6rem; }
  .upcoming-head-kicker::before { content: ''; display: block; width: 22px; height: 1.5px; background: var(--royal); }
  .upcoming-head-title { font-size: clamp(2.2rem,3.5vw,3.2rem); color: var(--ink); margin-bottom: 1.4rem; font-family: "Plus Jakarta Sans",Arial,sans-serif; font-weight: 800; letter-spacing: -.04em; }
  .upcoming-head-title em { font-style: italic; color: var(--royal); }
  .upcoming-head-sub { font-size: .95rem; color: var(--ink-muted); line-height: 1.74; }
  .upcoming-list { display: flex; flex-direction: column; }
  .upcoming-row { display: grid; grid-template-columns: 38px 90px 1fr 100px 52px auto; gap: 1rem; align-items: center; padding: 1.1rem 0; border-bottom: 1px solid rgba(27,61,143,.1); transition: background .2s; border-radius: 8px; }
  .upcoming-row:first-child { border-top: 1px solid rgba(27,61,143,.1); }
  .upcoming-row:hover { background: rgba(27,61,143,.04); padding-left: .8rem; padding-right: .8rem; }
  .upnum { font-family: "Plus Jakarta Sans",sans-serif; font-size: .72rem; font-weight: 800; color: rgba(27,61,143,.28); letter-spacing: .08em; }
  .update { font-size: .82rem; font-weight: 700; color: var(--ink-mid); white-space: nowrap; }
  .upname { font-family: "Plus Jakarta Sans",sans-serif; font-size: .95rem; font-weight: 800; letter-spacing: -.025em; color: var(--ink); line-height: 1.3; }
  .upcat { padding: .2rem .6rem; border-radius: 999px; font-size: .65rem; font-weight: 800; letter-spacing: .05em; text-transform: uppercase; text-align: center; }
  .uptime { font-size: .8rem; font-weight: 700; color: var(--ink-muted); text-align: right; }
  .upcoming-admin-acts { display: flex; gap: .3rem; flex-shrink: 0; }

  /* ── ADMIN MODAL ──────────────────────────────────────── */
  .adm-overlay { position: fixed; inset: 0; z-index: 10000; background: rgba(6,15,58,.58); backdrop-filter: blur(6px); display: flex; align-items: flex-start; justify-content: center; padding: 24px; overflow-y: auto; overscroll-behavior: contain; opacity: 0; pointer-events: none; transition: opacity .3s ease; }
  .adm-overlay.open { opacity: 1; pointer-events: all; }
  .adm-drawer { position: relative; width: min(540px,100%); max-height: calc(100dvh - 48px); background: white; border-radius: 24px; overflow: hidden; display: flex; flex-direction: column; box-shadow: 0 32px 80px rgba(6,15,58,.32); transform: scale(.94) translateY(16px); opacity: 0; transition: transform .38s cubic-bezier(.16,1,.3,1), opacity .3s ease; margin: auto; }
  .adm-overlay.open .adm-drawer { transform: scale(1) translateY(0); opacity: 1; }
  .adm-hdr { padding: 1.5rem 1.8rem; background: linear-gradient(135deg,var(--midnight) 0%,#0e2878 48%,var(--royal) 100%); color: white; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
  .adm-hdr-label { font-size: .68rem; font-weight: 800; letter-spacing: .2em; text-transform: uppercase; color: rgba(255,255,255,.48); margin-bottom: .25rem; }
  .adm-hdr-title-text { font-family: "Plus Jakarta Sans",sans-serif; font-size: 1.35rem; font-weight: 800; letter-spacing: -.03em; }
  .adm-hdr-close { width: 36px; height: 36px; border-radius: 50%; border: 1.5px solid rgba(255,255,255,.22); background: rgba(255,255,255,.08); cursor: pointer; display: flex; align-items: center; justify-content: center; color: white; transition: all .18s; flex-shrink: 0; }
  .adm-hdr-close:hover { background: rgba(255,255,255,.22); }
  .adm-hdr-close svg { width: 14px; height: 14px; }
  .adm-form-body { flex: 1; overflow-y: auto; min-height: 0; padding: 1.8rem; -webkit-overflow-scrolling: touch; overscroll-behavior: contain; }
  .af { margin-bottom: 1.1rem; }
  .af label { display: block; margin-bottom: .4rem; font-size: .83rem; font-weight: 700; color: #344054; }
  .af input, .af select, .af textarea { width: 100%; min-height: 46px; padding: .7rem .85rem; border: 1.5px solid rgba(27,61,143,.14); border-radius: 12px; background: rgba(247,242,235,.6); color: var(--ink); font-size: .93rem; font-family: "Manrope",sans-serif; outline: none; transition: border-color .18s, box-shadow .18s, background .18s; resize: vertical; }
  .af input:focus, .af select:focus, .af textarea:focus { border-color: rgba(27,61,143,.42); background: white; box-shadow: 0 0 0 4px rgba(27,61,143,.07); }
  .af textarea { min-height: 100px; }
  .af-row { display: grid; grid-template-columns: 1fr 1fr; gap: .8rem; }
  .af-hint { font-size: .75rem; color: var(--ink-muted); margin-top: .28rem; }
  .af-error { border-color: rgba(180,35,24,.5) !important; }
  .adm-divider { height: 1px; background: rgba(27,61,143,.07); margin: 1.4rem 0; }
  .adm-footer-bar { padding: 1.2rem 1.8rem; border-top: 1px solid rgba(27,61,143,.08); display: flex; gap: .7rem; flex-shrink: 0; background: white; }
  .adm-cancel { padding: .68rem 1.3rem; border-radius: 999px; border: 1.5px solid rgba(27,61,143,.15); background: transparent; font-family: "Manrope",sans-serif; font-size: .88rem; font-weight: 700; color: var(--ink-mid); cursor: pointer; transition: all .18s; }
  .adm-cancel:hover { border-color: var(--royal); color: var(--royal); }
  .adm-submit { flex: 1; padding: .72rem 1.5rem; border-radius: 999px; border: none; background: linear-gradient(135deg,var(--midnight),var(--royal)); color: white; font-family: "Manrope",sans-serif; font-size: .92rem; font-weight: 700; cursor: pointer; transition: all .18s; box-shadow: 0 8px 22px rgba(27,61,143,.22); }
  .adm-submit:hover { opacity: .9; transform: translateY(-1px); }
  .adm-submit:disabled { opacity: .55; transform: none; cursor: not-allowed; }
  .adm-fab { position: fixed; bottom: 2rem; right: 2rem; z-index: 400; padding: .75rem 1.4rem; border-radius: 999px; background: linear-gradient(135deg,var(--midnight),var(--royal)); color: white; border: none; cursor: pointer; display: inline-flex; align-items: center; gap: .5rem; font-family: "Manrope",sans-serif; font-size: .88rem; font-weight: 700; box-shadow: 0 10px 28px rgba(27,61,143,.38); transition: transform .2s, box-shadow .2s; }
  .adm-fab:hover { transform: translateY(-2px); box-shadow: 0 14px 36px rgba(27,61,143,.48); color: white; }
  .adm-fab svg { width: 16px; height: 16px; }
  .adm-toast { position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(90px); background: var(--midnight); color: white; padding: .8rem 1.6rem; border-radius: 999px; font-size: .88rem; font-weight: 700; z-index: 10100; transition: transform .38s cubic-bezier(.16,1,.3,1); pointer-events: none; white-space: nowrap; box-shadow: 0 8px 24px rgba(6,15,58,.3); }
  .adm-toast.show { transform: translateX(-50%) translateY(0); }

  /* ── DARK MODE ────────────────────────────────────────── */
  [data-theme="dark"] .cal-main { background: #0d1b2e; }
  [data-theme="dark"] .cal-widget { background: #142238; border-color: rgba(90,128,200,.15); }
  [data-theme="dark"] .cal-month-title { color: rgba(255,255,255,.9); }
  [data-theme="dark"] .cal-day-hdr { color: rgba(255,255,255,.35); }
  [data-theme="dark"] .cal-cell { color: rgba(255,255,255,.8); }
  [data-theme="dark"] .cal-cell.is-past:not(.is-today) { color: rgba(255,255,255,.22); }
  [data-theme="dark"] .cal-cell:hover:not(.cal-empty):not(.is-today) { background: rgba(90,128,200,.18); border-color: rgba(90,128,200,.38); }
  [data-theme="dark"] .cal-cell.is-selected:not(.is-today) { background: rgba(90,128,200,.2); border-color: var(--china); color: var(--china); }
  [data-theme="dark"] .cal-nav-btn { border-color: rgba(90,128,200,.22); color: rgba(255,255,255,.55); }
  [data-theme="dark"] .cal-nav-btn:hover { border-color: var(--china); color: var(--china); }
  [data-theme="dark"] .cal-filter { border-color: rgba(90,128,200,.18); color: rgba(255,255,255,.55); }
  [data-theme="dark"] .cal-filter:hover { border-color: var(--china); color: var(--china); }
  [data-theme="dark"] .day-panel { background: #142238; border-color: rgba(90,128,200,.15); }
  [data-theme="dark"] .day-panel-date { color: rgba(255,255,255,.9); border-color: rgba(90,128,200,.12); }
  [data-theme="dark"] .day-event { border-color: rgba(90,128,200,.1); }
  [data-theme="dark"] .day-event-name { color: rgba(255,255,255,.85); }
  [data-theme="dark"] .day-event-loc { color: rgba(255,255,255,.45); }
  [data-theme="dark"] .day-empty { color: rgba(255,255,255,.35); }
  [data-theme="dark"] .day-empty-line { background: rgba(90,128,200,.22); }
  [data-theme="dark"] .adm-day-btn { border-color: rgba(90,128,200,.28); background: rgba(90,128,200,.07); color: var(--china); }
  [data-theme="dark"] .adm-day-btn:hover { background: rgba(90,128,200,.14); border-color: var(--china); }
  [data-theme="dark"] .cal-upcoming { background: #0a1526; }
  [data-theme="dark"] .upcoming-head-title { color: rgba(255,255,255,.9); }
  [data-theme="dark"] .upcoming-head-sub { color: rgba(255,255,255,.48); }
  [data-theme="dark"] .upcoming-row { border-color: rgba(90,128,200,.12); }
  [data-theme="dark"] .upcoming-row:hover { background: rgba(90,128,200,.06); }
  [data-theme="dark"] .upname { color: rgba(255,255,255,.85); }
  [data-theme="dark"] .update { color: rgba(255,255,255,.5); }
  [data-theme="dark"] .uptime { color: rgba(255,255,255,.32); }
  [data-theme="dark"] .adm-drawer { background: #1a2f4a; }
  [data-theme="dark"] .adm-footer-bar { background: #1a2f4a; border-color: rgba(90,128,200,.15); }
  [data-theme="dark"] .af label { color: rgba(255,255,255,.6); }
  [data-theme="dark"] .af input, [data-theme="dark"] .af select, [data-theme="dark"] .af textarea { background: rgba(90,128,200,.08); border-color: rgba(90,128,200,.2); color: rgba(255,255,255,.85); }
  [data-theme="dark"] .af input:focus, [data-theme="dark"] .af select:focus, [data-theme="dark"] .af textarea:focus { background: rgba(90,128,200,.14); }
  [data-theme="dark"] .adm-cancel { border-color: rgba(90,128,200,.22); color: rgba(255,255,255,.6); }
  [data-theme="dark"] .adm-cancel:hover { border-color: var(--china); color: var(--china); }

  /* ── RESPONSIVE ───────────────────────────────────────── */
  @@media(max-width:1000px) {
    .cal-hero-inner { grid-template-columns: 1fr; }
    .cal-hero-right { display: none; }
    .cal-layout { grid-template-columns: 1fr; }
    .day-panel { position: static; }
    .cal-upcoming-inner { grid-template-columns: 1fr; }
  }
  @@media(max-width:600px) {
    .cal-hero-title { font-size: clamp(2.8rem,12vw,4rem); }
    .cal-cell { min-height: 40px; font-size: .78rem; }
    .upcoming-row { grid-template-columns: 30px 70px 1fr; }
    .upcat, .uptime, .upcoming-admin-acts { display: none; }
    .adm-overlay { padding: 8px; }
    .adm-drawer { max-height: calc(100dvh - 16px); border-radius: 20px; width: 100%; }
    .af-row { grid-template-columns: 1fr; }
  }
</style>

<!-- HERO -->
<section class="cal-hero">
  <div class="cal-hero-orb" style="width:600px;height:600px;right:-120px;top:-180px;background:radial-gradient(circle,rgba(27,61,143,.4) 0%,transparent 70%);"></div>
  <div class="cal-hero-orb" style="width:350px;height:350px;left:-80px;bottom:-100px;background:radial-gradient(circle,rgba(90,128,200,.2) 0%,transparent 70%);"></div>
  <div class="cal-hero-inner">
    <div>
      <div class="cal-hero-kicker">SmartLib — Raspored</div>
      <h1 class="cal-hero-title">Kalendar<br><em>događaja</em></h1>
      <p class="cal-hero-sub">Radionice, predavanja, knjižni klubovi i susreti s autorima. Pratite sve što se dešava u vašoj biblioteci.</p>
    </div>
    <div class="cal-hero-right reveal d1">
      <div class="cal-stat-card">
        <span class="cal-stat-num">@thisMonthCount</span>
        <div>
          <div class="cal-stat-label">Događaja u @monthName</div>
          <div class="cal-stat-sub">Tekući mjesec</div>
          <div class="cal-progress-bar"><div class="cal-progress-fill" id="month-progress" style="width:0%"></div></div>
        </div>
      </div>
      <div class="cal-stat-card">
        <span class="cal-stat-num">@upcomingCount</span>
        <div>
          <div class="cal-stat-label">Predstojeća događanja</div>
          <div class="cal-stat-sub">Od danas nadalje</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CALENDAR MAIN -->
<section class="cal-main">
  <div class="cal-main-inner">
    <div class="cal-layout">

      <!-- Calendar Widget -->
      <div class="cal-widget reveal">
        <div class="cal-widget-header">
          <span class="cal-month-title" id="cal-month-title"></span>
          <div class="cal-nav-btns">
            <button class="cal-nav-btn" id="cal-prev" title="Prethodni mjesec">
              <svg viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="cal-nav-btn" id="cal-next" title="Sljedeći mjesec">
              <svg viewBox="0 0 14 14" fill="none"><path d="M5 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        </div>
        <div class="cal-filters">
          <button class="cal-filter active" data-cat-filter="all">Sve</button>
          <button class="cal-filter" data-cat-filter="zajednica">Zajednica</button>
          <button class="cal-filter" data-cat-filter="edukacija">Edukacija</button>
          <button class="cal-filter" data-cat-filter="djeca">Djeca</button>
          <button class="cal-filter" data-cat-filter="predavanje">Predavanja</button>
        </div>
        <div class="cal-grid" id="cal-grid"></div>
      </div>

      <!-- Day Panel -->
      <div class="day-panel reveal d1">
        <div class="day-panel-date" id="day-panel-date"></div>
        <div id="day-panel-events"></div>
        @if (isAdmin)
        {
          <button class="adm-day-btn" id="adm-day-btn">
            <svg viewBox="0 0 14 14" fill="none"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            Dodaj događaj za ovaj dan
          </button>
        }
      </div>

    </div>
  </div>
</section>

<!-- UPCOMING SECTION -->
<section class="cal-upcoming">
  <div class="cal-upcoming-inner">
    <div class="reveal">
      <div class="upcoming-head-kicker">Predstojeći događaji</div>
      <h2 class="upcoming-head-title">Šta<br>nas<br><em>čeka</em></h2>
      <p class="upcoming-head-sub">Sve planirane aktivnosti biblioteke od danas pa nadalje — radionice, predavanja, susreti i posebna dešavanja.</p>
    </div>
    <div class="upcoming-list reveal d1" id="upcoming-list"></div>
  </div>
</section>

@if (isAdmin)
{
  <!-- Admin Modal -->
  <div class="adm-overlay" id="adm-overlay">
    <div class="adm-drawer" id="adm-drawer" role="dialog" aria-modal="true" onclick="event.stopPropagation()">
      <div class="adm-hdr">
        <div>
          <div class="adm-hdr-label">Admin panel</div>
          <div class="adm-hdr-title-text" id="adm-hdr-title-text">Novi događaj</div>
        </div>
        <button class="adm-hdr-close" id="adm-close" aria-label="Zatvori">
          <svg viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
      <div class="adm-form-body">
        <form id="adm-form" novalidate>
          @Html.AntiForgeryToken()
          <input type="hidden" id="af-id" value="0">
          <div class="af">
            <label for="af-name">Naziv događaja *</label>
            <input id="af-name" type="text" placeholder="npr. Knjižni klub — nova diskusija" autocomplete="off">
          </div>
          <div class="af-row">
            <div class="af">
              <label for="af-date-display">Datum</label>
              <input id="af-date-display" type="text" placeholder="dd/MM/yyyy" autocomplete="off" maxlength="10">
              <input id="af-date" type="hidden">
            </div>
            <div class="af">
              <label for="af-time">Vrijeme</label>
              <input id="af-time" type="text" placeholder="HH:MM" maxlength="5" autocomplete="off">
            </div>
          </div>
          <div class="af">
            <label for="af-loc">Lokacija</label>
            <input id="af-loc" type="text" placeholder="npr. Čitaonica, prizemlje">
          </div>
          <div class="af">
            <label for="af-cat">Kategorija</label>
            <select id="af-cat">
              <option value="Edukacija">Edukacija</option>
              <option value="Zajednica">Zajednica</option>
              <option value="Djeca">Djeca</option>
              <option value="Predavanje">Predavanje</option>
              <option value="Obavještenje">Obavještenje</option>
            </select>
          </div>
          <div class="adm-divider"></div>
          <div class="af">
            <label for="af-desc">Opis događaja</label>
            <textarea id="af-desc" rows="4" placeholder="Kratki opis koji će biti vidljiv u panelu detalja…"></textarea>
          </div>
        </form>
      </div>
      <div class="adm-footer-bar">
        <button class="adm-cancel" id="adm-cancel">Odustani</button>
        <button class="adm-submit" id="adm-submit">Dodaj događaj</button>
      </div>
    </div>
  </div>

  <button class="adm-fab" id="adm-fab" title="Novi događaj">
    <svg viewBox="0 0 22 22" fill="none"><path d="M11 4v14M4 11h14" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
    Novi događaj
  </button>

  <div class="adm-toast" id="adm-toast">Događaj uspješno dodan!</div>
}

<!-- JSON island: all events from the database -->
<script id="dogadjajiData" type="application/json">
@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(d => new {
    id    = d.Id,
    date  = d.Datum.ToString("yyyy-MM-dd"),
    name  = d.Naslov,
    time  = d.Sat ?? "",
    loc   = d.Lokacija ?? "",
    cat   = (d.Kategorija ?? "edukacija").ToLower(),
    opis  = d.Opis ?? ""
})))
</script>

@section Scripts {
<script>
  /* ── DATA & CONSTANTS ─────────────────────────────────── */
  var EVENTS = [];
  try { EVENTS = JSON.parse(document.getElementById('dogadjajiData').textContent); } catch(e) {}

  var IS_ADMIN   = @(isAdmin ? "true" : "false");
  var TODAY_ISO  = '@todayIso';
  var todayParts = TODAY_ISO.split('-');
  var TODAY      = new Date(+todayParts[0], +todayParts[1]-1, +todayParts[2]);

  var MONTHS = ['Januar','Februar','Mart','April','Maj','Juni','Juli','August','Septembar','Oktobar','Novembar','Decembar'];
  var DAYS   = ['Pon','Uto','Sri','Čet','Pet','Sub','Ned'];

  var curYear  = @curYear;
  var curMonth = @curMonthJs;
  var activeCatFilter  = 'all';
  var selectedDateStr  = TODAY_ISO;

  function pad(n) { return String(n).padStart(2,'0'); }
  function _isoToDisp(iso) { var p=(iso||'').split('-'); return p.length===3 ? pad(+p[2])+'/'+pad(+p[1])+'/'+p[0] : ''; }
  function _dispToIso(d) { var p=(d||'').split('/'); return p.length===3 && p[2].length===4 ? p[2]+'-'+pad(+p[1])+'-'+pad(+p[0]) : ''; }
  function toDs(y,m,d) { return y + '-' + pad(m+1) + '-' + pad(d); }
  function escH(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  function getEvs(ds) {
    return EVENTS.filter(function(e) {
      return activeCatFilter === 'all' ? e.date === ds : e.date === ds && e.cat === activeCatFilter;
    });
  }

  /* ── CALENDAR RENDER ──────────────────────────────────── */
  function renderCalendar() {
    document.getElementById('cal-month-title').textContent = MONTHS[curMonth] + ' ' + curYear;

    var firstDay    = new Date(curYear, curMonth, 1);
    var daysInMonth = new Date(curYear, curMonth+1, 0).getDate();
    var offset      = firstDay.getDay() - 1;
    if (offset < 0) offset = 6;

    var grid = document.getElementById('cal-grid');
    grid.innerHTML = '';

    DAYS.forEach(function(d) {
      var h = document.createElement('div');
      h.className = 'cal-day-hdr';
      h.textContent = d;
      grid.appendChild(h);
    });

    for (var i = 0; i < offset; i++) {
      var blank = document.createElement('div');
      blank.className = 'cal-cell cal-empty';
      grid.appendChild(blank);
    }

    var todayDate = new Date(TODAY.getFullYear(), TODAY.getMonth(), TODAY.getDate());

    for (var d = 1; d <= daysInMonth; d++) {
      var ds      = toDs(curYear, curMonth, d);
      var allEvs  = EVENTS.filter(function(e) { return e.date === ds; });
      var isToday = ds === TODAY_ISO;
      var isPast  = new Date(curYear, curMonth, d) < todayDate;
      var isSel   = ds === selectedDateStr;

      var cell = document.createElement('div');
      cell.className = 'cal-cell'
        + (isToday ? ' is-today' : '')
        + (isSel && !isToday ? ' is-selected' : '')
        + (isPast && !isToday ? ' is-past' : '');
      cell.setAttribute('data-date', ds);

      var numSpan = document.createElement('span');
      numSpan.textContent = d;
      cell.appendChild(numSpan);

      if (allEvs.length) {
        var dotsEl = document.createElement('div');
        dotsEl.className = 'cal-dots';
        allEvs.slice(0,3).forEach(function(ev) {
          var dot = document.createElement('span');
          dot.className = 'cal-dot dot-' + ev.cat;
          dotsEl.appendChild(dot);
        });
        cell.appendChild(dotsEl);
      }

      (function(dateStr) {
        cell.addEventListener('click', function() { selectDay(dateStr); });
      })(ds);
      grid.appendChild(cell);
    }
  }

  /* ── DAY PANEL ────────────────────────────────────────── */
  function selectDay(ds) {
    selectedDateStr = ds;
    document.querySelectorAll('.cal-cell').forEach(function(c) {
      var isT = c.getAttribute('data-date') === TODAY_ISO;
      c.classList.remove('is-selected');
      if (c.getAttribute('data-date') === ds && !isT) c.classList.add('is-selected');
    });
    renderDayPanel(ds);
    var dateInput = document.getElementById('af-date');
    if (dateInput) dateInput.value = ds;
    var dateDisp = document.getElementById('af-date-display');
    if (dateDisp) dateDisp.value = _isoToDisp(ds);
  }

  function renderDayPanel(ds) {
    var evs    = getEvs(ds);
    var parts  = ds.split('-');
    var y = +parts[0], m = +parts[1], d = +parts[2];
    document.getElementById('day-panel-date').textContent = pad(d) + '/' + pad(m) + '/' + y;

    var panel = document.getElementById('day-panel-events');
    if (!evs.length) {
      panel.innerHTML = '<div class="day-empty"><div class="day-empty-line"></div><p>Nema planiranih događaja za ovaj dan.</p></div>';
      return;
    }
    panel.innerHTML = evs.map(function(e) {
      var adminBtns = IS_ADMIN
        ? '<div class="day-event-admin">'
            + '<button class="btn-ev-edit" onclick="admOpen(' + e.id + ')">Uredi</button>'
            + '<button class="btn-ev-del" onclick="admDelete(' + e.id + ')">Obriši</button>'
          + '</div>'
        : '';
      return '<div class="day-event">'
        + '<div class="day-event-time">' + escH(e.time || '—') + '</div>'
        + '<div class="day-event-info">'
          + '<div class="day-event-name">' + escH(e.name) + '</div>'
          + (e.loc ? '<div class="day-event-loc">' + escH(e.loc) + '</div>' : '')
          + '<span class="day-event-cat cat-dot-' + e.cat + '">' + escH(e.cat) + '</span>'
          + adminBtns
        + '</div>'
      + '</div>';
    }).join('');
  }

  /* ── UPCOMING LIST ────────────────────────────────────── */
  function renderUpcoming() {
    var upcoming = EVENTS.filter(function(e) {
      return e.date >= TODAY_ISO && (activeCatFilter === 'all' || e.cat === activeCatFilter);
    }).sort(function(a,b) { return a.date.localeCompare(b.date); });

    var list = document.getElementById('upcoming-list');
    if (!upcoming.length) {
      list.innerHTML = '<div style="color:var(--ink-muted);font-size:.9rem;padding:1rem 0;">Nema predstoječih događaja za odabrani filter.</div>';
      return;
    }
    list.innerHTML = upcoming.map(function(e, i) {
      var parts = e.date.split('-');
      var dl    = pad(+parts[2]) + '/' + pad(+parts[1]) + '/' + parts[0];
      var adminActs = IS_ADMIN
        ? '<div class="upcoming-admin-acts">'
            + '<button class="btn-ev-edit" onclick="admOpen(' + e.id + ')">Uredi</button>'
            + '<button class="btn-ev-del" onclick="admDelete(' + e.id + ')">Obriši</button>'
          + '</div>'
        : '';
      return '<div class="upcoming-row" style="animation:upRowIn .4s ease ' + (i*0.06) + 's both">'
        + '<span class="upnum">' + pad(i+1) + '</span>'
        + '<span class="update">' + dl + '</span>'
        + '<span class="upname">' + escH(e.name) + '</span>'
        + '<span class="upcat cat-dot-' + e.cat + '">' + escH(e.cat) + '</span>'
        + '<span class="uptime">' + escH(e.time) + '</span>'
        + adminActs
      + '</div>';
    }).join('');
  }

  /* ── NAVIGATION ───────────────────────────────────────── */
  document.getElementById('cal-prev').addEventListener('click', function() {
    curMonth--; if (curMonth < 0) { curMonth = 11; curYear--; }
    renderCalendar();
  });
  document.getElementById('cal-next').addEventListener('click', function() {
    curMonth++; if (curMonth > 11) { curMonth = 0; curYear++; }
    renderCalendar();
  });

  /* ── CATEGORY FILTERS ─────────────────────────────────── */
  document.querySelectorAll('.cal-filter').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.cal-filter').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      activeCatFilter = btn.getAttribute('data-cat-filter');
      renderCalendar();
      renderUpcoming();
      renderDayPanel(selectedDateStr);
    });
  });

  /* ── SCROLL REVEAL ────────────────────────────────────── */
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(function(el) { obs.observe(el); });

  /* ── UPCOMING ROW ANIMATION ───────────────────────────── */
  var aStyle = document.createElement('style');
  aStyle.textContent = '@@keyframes upRowIn{from{opacity:0;transform:translateX(-12px)}to{opacity:1;transform:none}}';
  document.head.appendChild(aStyle);

  /* ── MONTH PROGRESS BAR ───────────────────────────────── */
  setTimeout(function() {
    var fill = document.getElementById('month-progress');
    if (fill) fill.style.width = '@progressPct%';
  }, 400);

  /* ── INIT ─────────────────────────────────────────────── */
  renderCalendar();
  selectDay(selectedDateStr);
  renderUpcoming();

@if (isAdmin)
{
<text>
  /* ── ADMIN LOGIC ──────────────────────────────────────── */
  var admOverlayEl = document.getElementById('adm-overlay');
  var admTitleEl   = document.getElementById('adm-hdr-title-text');
  var admSubmitBtn = document.getElementById('adm-submit');
  var admToastEl   = document.getElementById('adm-toast');

  function admGetToken() {
    var el = document.querySelector('#adm-form [name="__RequestVerificationToken"]');
    return el ? el.value : '';
  }

  function admShowToast(msg) {
    admToastEl.textContent = msg;
    admToastEl.classList.add('show');
    setTimeout(function() { admToastEl.classList.remove('show'); }, 3000);
  }

  function admOpen(id) {
    document.getElementById('af-id').value = id;
    document.getElementById('af-name').classList.remove('af-error');

    if (id === 0) {
      admTitleEl.textContent = 'Novi događaj';
      document.getElementById('af-name').value = '';
      document.getElementById('af-date').value = selectedDateStr;
      document.getElementById('af-date-display').value = _isoToDisp(selectedDateStr);
      document.getElementById('af-time').value = '17:00';
      document.getElementById('af-loc').value  = '';
      document.getElementById('af-cat').value  = 'Edukacija';
      document.getElementById('af-desc').value = '';
      admSubmitBtn.textContent = 'Dodaj događaj';
    } else {
      var ev = EVENTS.find(function(e) { return e.id === id; });
      if (!ev) return;
      admTitleEl.textContent = 'Uredi događaj';
      document.getElementById('af-name').value = ev.name || '';
      document.getElementById('af-date').value = ev.date || '';
      document.getElementById('af-date-display').value = _isoToDisp(ev.date || '');
      document.getElementById('af-time').value = ev.time || '';
      document.getElementById('af-loc').value  = ev.loc  || '';
      var catCap = (ev.cat || 'edukacija');
      catCap = catCap.charAt(0).toUpperCase() + catCap.slice(1);
      document.getElementById('af-cat').value  = catCap;
      document.getElementById('af-desc').value = ev.opis || '';
      admSubmitBtn.textContent = 'Sačuvaj izmjene';
    }

    admSubmitBtn.disabled = false;
    admOverlayEl.classList.add('open');
  }

  function admClose() {
    admOverlayEl.classList.remove('open');
  }

  admSubmitBtn.addEventListener('click', function() {
    var id     = parseInt(document.getElementById('af-id').value, 10) || 0;
    var naslov = document.getElementById('af-name').value.trim();
    if (!naslov) {
      document.getElementById('af-name').classList.add('af-error');
      document.getElementById('af-name').focus();
      return;
    }

    var dateVal = document.getElementById('af-date').value;
    if (!dateVal) {
      document.getElementById('af-date-display').classList.add('af-error');
      document.getElementById('af-date-display').focus();
      return;
    }

    var timeVal = document.getElementById('af-time').value.trim();
    var locVal  = document.getElementById('af-loc').value.trim();
    var catVal  = document.getElementById('af-cat').value;
    var descVal = document.getElementById('af-desc').value.trim();
    var catLow  = catVal.toLowerCase();

    var fd = new FormData();
    fd.append('__RequestVerificationToken', admGetToken());
    if (id > 0) fd.append('Id', id);
    fd.append('Naslov',     naslov);
    fd.append('Datum',      dateVal);
    fd.append('Sat',        timeVal);
    fd.append('Lokacija',   locVal);
    fd.append('Kategorija', catVal);
    fd.append('Opis',       descVal);

    var url = id > 0 ? '/Kalendar/Edit/' + id : '/Kalendar/Create';
    admSubmitBtn.disabled    = true;
    admSubmitBtn.textContent = 'Čekaj…';

    fetch(url, {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest' },
      body: fd
    })
    .then(function(r) { if (!r.ok) throw new Error(r.status); return r.json(); })
    .then(function(data) {
      if (!data.success) {
        admSubmitBtn.disabled    = false;
        admSubmitBtn.textContent = id > 0 ? 'Sačuvaj izmjene' : 'Dodaj događaj';
        return;
      }
      admClose();
      admShowToast(id > 0 ? 'Događaj uspješno ažuriran!' : 'Događaj uspješno dodan!');

      if (id === 0) {
        EVENTS.push({ id: data.id, date: data.datum, name: naslov, time: timeVal, loc: locVal, cat: catLow, opis: descVal });
      } else {
        for (var i = 0; i < EVENTS.length; i++) {
          if (EVENTS[i].id === id) {
            EVENTS[i].name = naslov;
            EVENTS[i].date = dateVal;
            EVENTS[i].time = timeVal;
            EVENTS[i].loc  = locVal;
            EVENTS[i].cat  = catLow;
            EVENTS[i].opis = descVal;
            break;
          }
        }
      }

      renderCalendar();
      selectDay(selectedDateStr);
      renderUpcoming();
    })
    .catch(function() {
      admSubmitBtn.disabled    = false;
      admSubmitBtn.textContent = id > 0 ? 'Sačuvaj izmjene' : 'Dodaj događaj';
    });
  });

  function admDelete(id) {
    if (!confirm('Sigurno obrisati ovaj događaj?')) return;
    var fd = new FormData();
    fd.append('__RequestVerificationToken', admGetToken());
    fetch('/Kalendar/Delete/' + id, {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest' },
      body: fd
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        for (var i = EVENTS.length - 1; i >= 0; i--) {
          if (EVENTS[i].id === id) { EVENTS.splice(i, 1); break; }
        }
        admShowToast('Događaj obrisan.');
        renderCalendar();
        selectDay(selectedDateStr);
        renderUpcoming();
      }
    })
    .catch(function(err) { console.error(err); });
  }

  document.getElementById('adm-fab').addEventListener('click', function() { admOpen(0); });
  var admDayBtn = document.getElementById('adm-day-btn');
  if (admDayBtn) admDayBtn.addEventListener('click', function() { admOpen(0); });
  document.getElementById('adm-close').addEventListener('click', admClose);
  document.getElementById('adm-cancel').addEventListener('click', admClose);
  admOverlayEl.addEventListener('click', admClose);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && admOverlayEl.classList.contains('open')) admClose();
  });
  document.getElementById('af-name').addEventListener('input', function() { this.classList.remove('af-error'); });
  document.getElementById('af-date-display').addEventListener('input', function() {
    document.getElementById('af-date').value = _dispToIso(this.value.trim());
    this.classList.remove('af-error');
  });
</text>
}
</script>
}
