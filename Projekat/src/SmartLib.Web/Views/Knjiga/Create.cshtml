@* TODO: @model KnjigaCreateDto *@
@{
    ViewData["Title"] = "Nova knjiga";
}

<h2>Dodaj novu knjigu</h2>

<div class="card" style="max-width: 600px;">
    <form asp-controller="Knjiga" asp-action="Create" method="post">
        <div class="form-group">
            <label>Naslov</label>
            <input type="text" name="Naslov" required />
        </div>
        <div class="form-group">
            <label>Autor</label>
            <input type="text" name="Autor" required />
        </div>
        <div class="form-group">
            <label>ISBN</label>
            <input type="text" name="Isbn" required />
        </div>
        <div class="form-group">
            <label>Kategorija</label>
            @* TODO: <select asp-for="KategorijaId" asp-items="ViewBag.Kategorije"></select> *@
            <select name="KategorijaId"><option>TODO: Učitaj kategorije</option></select>
        </div>
        <div class="form-group">
            <label>Izdavač</label>
            <input type="text" name="Izdavac" />
        </div>
        <div class="form-group">
            <label>Godina izdanja</label>
            <input type="number" name="GodinaIzdanja" />
        </div>
        <div class="form-group">
            <label>Broj primjeraka</label>
            <input type="number" name="BrojPrimjeraka" value="1" min="1" />
        </div>

        <button type="submit" class="btn btn-primary">Dodaj knjigu</button>
        <a asp-action="Index" class="btn btn-secondary">Odustani</a>
    </form>
</div>
