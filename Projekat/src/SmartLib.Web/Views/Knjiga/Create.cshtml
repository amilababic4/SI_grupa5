@model SmartLib.Core.DTOs.KnjigaCreateDto
@{
    ViewData["Title"] = "Nova knjiga";
}

<div class="katalog-header" style="justify-content: center; position: relative;">
    <h2>Dodaj novu knjigu</h2>
    <a asp-action="Index" class="btn btn-secondary" style="position: absolute; left: 0;">← Nazad na katalog</a>
</div>

<div class="card book-form-card">
    <form asp-controller="Knjiga" asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-message" style="margin-bottom: 1rem;"></div>

        <div class="form-group">
            <label asp-for="Naslov">Naslov</label>
            <input asp-for="Naslov" placeholder="Unesite naslov knjige" />
            <span asp-validation-for="Naslov" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Autor">Autor</label>
            <input asp-for="Autor" placeholder="Ime i prezime autora" />
            <span asp-validation-for="Autor" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Isbn">ISBN</label>
            <input asp-for="Isbn" placeholder="npr. 9780451524935 ili 978-0-451-52493-5" />
            <small class="form-help">Unesite 10 ili 13-cifreni ISBN (crtice su opcionalne).</small>
            <span asp-validation-for="Isbn" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="KategorijaId">Kategorija</label>
            <select asp-for="KategorijaId" asp-items="ViewBag.Kategorije">
                <option value="0">— Odaberite kategoriju —</option>
            </select>
            <span asp-validation-for="KategorijaId" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Izdavac">Izdavač</label>
            <input asp-for="Izdavac" placeholder="Naziv izdavača (opciono)" />
            <span asp-validation-for="Izdavac" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="GodinaIzdanja">Godina izdanja</label>
            <input asp-for="GodinaIzdanja" type="number" min="1000" max="2100" placeholder="npr. 2023" />
            <span asp-validation-for="GodinaIzdanja" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="BrojPrimjeraka">Broj primjeraka</label>
            <input asp-for="BrojPrimjeraka" type="number" min="0" />
            <small class="form-help">Unesite 0 ako knjiga još nema fizičkih primjeraka.</small>
            <span asp-validation-for="BrojPrimjeraka" class="validation-message"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Dodaj u katalog</button>
            <a asp-action="Index" class="btn btn-secondary">Odustani</a>
        </div>
    </form>
</div>
