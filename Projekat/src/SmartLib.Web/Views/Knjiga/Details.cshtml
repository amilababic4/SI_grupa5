@model SmartLib.Core.DTOs.KnjigaDto
@using SmartLib.Core.Models
@{
    ViewData["Title"] = Model.Naslov;
    var primjerci = ViewBag.Primjerci as List<Primjerak> ?? new List<Primjerak>();
    bool jeOsoblje = User.IsInRole("Bibliotekar") || User.IsInRole("Administrator");
}

<div class="details-topbar">
    <a asp-controller="Knjiga" asp-action="Index" class="btn btn-secondary">← Nazad na katalog</a>
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success">@successMsg</div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-error">@errorMsg</div>
}

<div class="card">
    <div class="details-book-layout">
        <div class="details-cover-wrapper">
            <img src="@Url.Action("Korice", "Knjiga", new { isbn = Model.Isbn, size = "L" })"
                 alt="@Model.Naslov"
                 class="details-cover-img" />
        </div>

        <div class="details-info-content">
            <div class="details-header">
                <div>
                    <h2>@Model.Naslov</h2>
                    <p class="details-autor">@Model.Autor</p>
                </div>
                @if (jeOsoblje)
                {
                    <div class="details-actions">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Uredi</a>
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                              onsubmit="return confirm('Jeste li sigurni da želite obrisati knjigu: @Model.Naslov?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">Obriši</button>
                        </form>
                    </div>
                }
            </div>

            <div class="details-grid">
                <div class="details-item">
                    <span class="details-label">ISBN</span>
                    <span class="details-value katalog-isbn">@Model.Isbn</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Kategorija</span>
                    <span>
                        @if (Model.Kategorija != null)
                        {
                            <span class="katalog-badge">@Model.Kategorija</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </span>
                </div>
                <div class="details-item">
                    <span class="details-label">Izdavač</span>
                    <span class="details-value">@(Model.Izdavac ?? "—")</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Godina izdanja</span>
                    <span class="details-value">@(Model.GodinaIzdanja?.ToString() ?? "—")</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Ukupno primjeraka</span>
                    <span class="details-value details-value--center">@Model.BrojPrimjeraka</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Dostupno</span>
                    <span class="@(Model.BrojDostupnih > 0 ? "status-dostupan" : "status-nedostupan") details-value--center">
                        @Model.BrojDostupnih
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card examples-card">
    <div class="examples-header">
        <h3 class="examples-title">
            Primjerci
            <span class="primjerci-count-badge">@primjerci.Count</span>
        </h3>
        @if (jeOsoblje)
        {
            <button class="btn btn-primary btn-sm" id="btn-dodaj-primjerak" type="button"
                    onclick="document.getElementById('forma-dodaj-primjerak').classList.toggle('hidden')">
                + Dodaj primjerak
            </button>
        }
    </div>

    @if (jeOsoblje)
    {
        <div id="forma-dodaj-primjerak" class="primjerak-add-form hidden">
            <form asp-controller="Primjerak" asp-action="Dodaj" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="knjigaId" value="@Model.Id" />
                <div class="primjerak-add-row">
                    <div class="form-group" style="margin-bottom:0; flex:1;">
                        <label for="brojNovih">Broj novih primjeraka</label>
                        <input type="number" id="brojNovih" name="brojNovih" value="1" min="1" max="50" />
                        <span class="form-help">Svaki primjerak dobija jedinstveni inventarni broj automatski.</span>
                    </div>
                    <div class="primjerak-add-actions">
                        <button type="submit" class="btn btn-primary">Dodaj</button>
                        <button type="button" class="btn btn-secondary"
                                onclick="document.getElementById('forma-dodaj-primjerak').classList.add('hidden')">
                            Otkaži
                        </button>
                    </div>
                </div>
            </form>
        </div>
    }

    @if (!primjerci.Any())
    {
        <p class="empty-note">Ova knjiga trenutno nema unesenih primjeraka.</p>
    }
    else
    {
        <div class="katalog-table-wrap">
            <table class="katalog-table primjerci-table">
                <thead>
                    <tr>
                        <th>Inventarni broj</th>
                        <th>Status</th>
                        <th>Datum nabave</th>
                        @if (jeOsoblje)
                        {
                            <th>Akcije</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in primjerci)
                    {
                        var jeDeaktiviran = p.Status == "deaktiviran";
                        var statusKlasa = p.Status switch
                        {
                            "dostupan" => "status-dostupan",
                            "zaduzen" => "status-zaduzen",
                            "deaktiviran" => "status-deaktiviran",
                            _ => "status-nedostupan"
                        };

                        if (jeOsoblje && !jeDeaktiviran)
                        {
                            <!-- Klikabilni red — isti pattern kao lista članova -->
                            <tr class="members-row-link"
                                onclick="window.location='@Url.Action("ZaduzenjaPrimjerka", "Zaduzenje", new { primjerakId = p.Id })'"
                                title="Pogledaj zaduženja — @p.InventarniBroj">
                                <td data-label="Inventarni broj">
                                    <span class="inv-broj members-name">@p.InventarniBroj</span>
                                </td>
                                <td data-label="Status">
                                    <span class="@statusKlasa">@p.Status</span>
                                </td>
                                <td data-label="Datum nabave">
                                    @(p.DatumNabave.HasValue? p.DatumNabave.Value.ToString("dd.MM.yyyy") : "—")
                                </td>
                                <td data-label="Akcije" class="katalog-actions" onclick="event.stopPropagation()">
                                    <form asp-controller="Primjerak" asp-action="Deaktiviraj" method="post"
                                          onsubmit="return confirm('Deaktivirati primjerak @p.InventarniBroj?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Deaktiviraj</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        else if (jeOsoblje && jeDeaktiviran)
                        {
                            <!-- Deaktiviran red — nije klikabilan -->
                            <tr class="row-deaktiviran">
                                <td data-label="Inventarni broj">
                                    <span class="inv-broj inv-broj--deaktiviran">@p.InventarniBroj</span>
                                </td>
                                <td data-label="Status">
                                    <span class="@statusKlasa">@p.Status</span>
                                </td>
                                <td data-label="Datum nabave">
                                    @(p.DatumNabave.HasValue? p.DatumNabave.Value.ToString("dd.MM.yyyy") : "—")
                                </td>
                                <td data-label="Akcije" class="katalog-actions">
                                    <span class="deaktiviran-label">Deaktiviran</span>
                                </td>
                            </tr>
                        }
                        else
                        {
                            <!-- Clan — samo čita, nema klikanja ni akcija -->
                            <tr>
                                <td data-label="Inventarni broj">
                                    <span class="inv-broj">@p.InventarniBroj</span>
                                </td>
                                <td data-label="Status">
                                    <span class="@statusKlasa">@p.Status</span>
                                </td>
                                <td data-label="Datum nabave">
                                    @(p.DatumNabave.HasValue? p.DatumNabave.Value.ToString("dd.MM.yyyy") : "—")
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="primjerci-legenda">
            @if (jeOsoblje)
            {
                <span class="legenda-item primjerci-legenda-hint">
                    💡 Kliknite na primjerak za pregled svih zaduženja
                </span>
            }
            <span class="legenda-item"><span class="status-dostupan">dostupan</span> = slobodan za zaduživanje</span>
            <span class="legenda-item"><span class="status-zaduzen">zadužen</span> = trenutno kod člana</span>
            <span class="legenda-item"><span class="status-deaktiviran">deaktiviran</span> = oštećen / izgubljen</span>
        </div>
    }
</div>
