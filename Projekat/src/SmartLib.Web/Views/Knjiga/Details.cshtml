@model SmartLib.Core.DTOs.KnjigaDto
@using SmartLib.Core.Models
@{
    ViewData["Title"] = Model.Naslov;
    var primjerci = ViewBag.Primjerci as List<Primjerak> ?? new List<Primjerak>();
    bool jeOsoblje = User.IsInRole("Bibliotekar") || User.IsInRole("Administrator");
    bool jeClan = User.IsInRole("Član");
    bool imaAktivnuRezervaciju = ViewBag.ImaAktivnuRezervaciju is true;
}

<div class="details-topbar">
    <a asp-controller="Knjiga" asp-action="Index" class="btn btn-secondary">← Nazad na katalog</a>
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success">@successMsg</div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-error">@errorMsg</div>
}

<div class="card">
    <div class="details-book-layout">
        <div class="details-cover-wrapper" style="cursor: pointer;" onclick="openImageModal()" title="Klikni za prikaz">
            <img src="@Url.Action("Korice", "Knjiga", new { isbn = Model.Isbn, size = "L", v = 3 })"
                 alt="@Model.Naslov"
                 class="details-cover-img" id="mainCoverImage" />
        </div>

        <div class="details-info-content">
            <div class="details-header">
                <div>
                    <h2>@Model.Naslov</h2>
                    <p class="details-autor">@Model.Autor</p>
                    @if (jeClan && ViewBag.Procitana is true)
                    {
                        <span class="details-read-badge">✓ Pročitano</span>
                    }
                </div>
                @if (jeOsoblje)
                {
                    <div class="details-actions">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Uredi</a>
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                              onsubmit="return confirm('Jeste li sigurni da želite obrisati knjigu: @Model.Naslov?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">Obriši</button>
                        </form>
                    </div>
                }
                @if (jeClan && Model.BrojDostupnih == 0)
                {
                    <div class="details-actions">
                        @if (imaAktivnuRezervaciju)
                        {
                            <button class="btn btn-secondary" disabled title="Već imate aktivnu rezervaciju za ovu knjigu">
                                Rezervisano
                            </button>
                        }
                        else
                        {
                            <form asp-controller="Rezervacija" asp-action="Create" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="knjigaId" value="@Model.Id" />
                                <button type="submit" class="btn btn-primary"
                                        onclick="return confirm('Rezervisati knjigu: @Model.Naslov?')">
                                    Rezerviši
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Opis))
            {
                <div class="details-description" style="margin-top: 1.5rem; margin-bottom: 1.5rem; line-height: 1.6; color: var(--text-secondary);">
                    @Model.Opis
                </div>
            }

            <div class="details-grid">
                <div class="details-item">
                    <span class="details-label">ISBN</span>
                    <span class="details-value katalog-isbn">@Model.Isbn</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Kategorija</span>
                    <span>
                        @if (Model.Kategorija != null)
                        {
                            <span class="katalog-badge">@Model.Kategorija</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </span>
                </div>
                <div class="details-item">
                    <span class="details-label">Izdavač</span>
                    <span class="details-value">@(Model.Izdavac ?? "—")</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Godina izdanja</span>
                    <span class="details-value">@(Model.GodinaIzdanja?.ToString() ?? "—")</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Ukupno primjeraka</span>
                    <span class="details-value details-value--center">@Model.BrojPrimjeraka</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Dostupno</span>
                    <span class="@(Model.BrojDostupnih > 0 ? "status-dostupan" : "status-nedostupan") details-value--center">
                        @Model.BrojDostupnih
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="imageModal" class="image-modal-overlay" onclick="closeImageModal()" style="display:none;">
    <div class="image-modal-content">
        <span class="image-modal-close" onclick="closeImageModal()">&times;</span>
        <img id="modalImage" class="image-modal-img" src="" alt="Prikaz korica" />
    </div>
</div>

@section Scripts {
    <script>
        function openImageModal() {
            var modal = document.getElementById('imageModal');
            var modalImg = document.getElementById('modalImage');
            var srcImg = document.getElementById('mainCoverImage');
            
            modalImg.src = srcImg.src;
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function closeImageModal() {
            var modal = document.getElementById('imageModal');
            modal.style.display = 'none';
            document.body.style.overflow = '';
        }

        // Close on Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === "Escape") {
                closeImageModal();
            }
        });
    </script>
}

<div class="card examples-card">
    <div class="examples-header">
        <h3 class="examples-title">
            Primjerci
            <span class="primjerci-count-badge">@primjerci.Count</span>
        </h3>
        @if (jeOsoblje)
        {
            <button class="btn btn-primary btn-sm" id="btn-dodaj-primjerak" type="button"
                    onclick="document.getElementById('forma-dodaj-primjerak').classList.toggle('hidden')">
                + Dodaj primjerak
            </button>
        }
    </div>

    @if (jeOsoblje)
    {
        <div id="forma-dodaj-primjerak" class="primjerak-add-form hidden">
            <form asp-controller="Primjerak" asp-action="Dodaj" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="knjigaId" value="@Model.Id" />
                <div class="primjerak-add-row">
                    <div class="form-group" style="margin-bottom:0; flex:1;">
                        <label for="brojNovih">Broj novih primjeraka</label>
                        <input type="number" id="brojNovih" name="brojNovih" value="1" min="1" max="50" />
                        <span class="form-help">Svaki primjerak dobija jedinstveni inventarni broj automatski.</span>
                    </div>
                    <div class="primjerak-add-actions">
                        <button type="submit" class="btn btn-primary">Dodaj</button>
                        <button type="button" class="btn btn-secondary"
                                onclick="document.getElementById('forma-dodaj-primjerak').classList.add('hidden')">
                            Otkaži
                        </button>
                    </div>
                </div>
            </form>
        </div>
    }

    @if (!primjerci.Any())
    {
        <p class="empty-note">Ova knjiga trenutno nema unesenih primjeraka.</p>
    }
    else
    {
        <div class="katalog-table-wrap">
            <table class="katalog-table primjerci-table">
                <thead>
                    <tr>
                        <th>Inventarni broj</th>
                        <th>Status</th>
                        <th>Datum nabave</th>
                        @if (jeOsoblje)
                        {
                            <th>Akcije</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in primjerci)
                    {
                        var jeDeaktiviran = p.Status == "deaktiviran";
                        var statusKlasa = p.Status switch
                        {
                            "dostupan" => "status-dostupan",
                            "zaduzen" => "status-zaduzen",
                            "deaktiviran" => "status-deaktiviran",
                            _ => "status-nedostupan"
                        };

                        if (jeOsoblje && !jeDeaktiviran)
                        {
                            <!-- Klikabilni red — isti pattern kao lista članova -->
                            <tr class="members-row-link"
                                onclick="window.location='@Url.Action("ZaduzenjaPrimjerka", "Zaduzenje", new { primjerakId = p.Id })'"
                                title="Pogledaj zaduženja — @p.InventarniBroj">
                                <td data-label="Inventarni broj">
                                    <span class="inv-broj members-name">@p.InventarniBroj</span>
                                </td>
                                <td data-label="Status">
                                    <span class="@statusKlasa">@p.Status</span>
                                </td>
                                <td data-label="Datum nabave">
                                    @(p.DatumNabave.HasValue? p.DatumNabave.Value.ToString("dd.MM.yyyy") : "—")
                                </td>
                                <td data-label="Akcije" class="katalog-actions" onclick="event.stopPropagation()">
                                    <form asp-controller="Primjerak" asp-action="Deaktiviraj" method="post"
                                          onsubmit="return confirm('Deaktivirati primjerak @p.InventarniBroj?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Deaktiviraj</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        else if (jeOsoblje && jeDeaktiviran)
                        {
                            <!-- Deaktiviran red — nije klikabilan -->
                            <tr class="row-deaktiviran">
                                <td data-label="Inventarni broj">
                                    <span class="inv-broj inv-broj--deaktiviran">@p.InventarniBroj</span>
                                </td>
                                <td data-label="Status">
                                    <span class="@statusKlasa">@p.Status</span>
                                </td>
                                <td data-label="Datum nabave">
                                    @(p.DatumNabave.HasValue? p.DatumNabave.Value.ToString("dd.MM.yyyy") : "—")
                                </td>
                                <td data-label="Akcije" class="katalog-actions">
                                    <span class="deaktiviran-label">Deaktiviran</span>
                                </td>
                            </tr>
                        }
                        else
                        {
                            <!-- Clan — samo čita, nema klikanja ni akcija -->
                            <tr>
                                <td data-label="Inventarni broj">
                                    <span class="inv-broj">@p.InventarniBroj</span>
                                </td>
                                <td data-label="Status">
                                    <span class="@statusKlasa">@p.Status</span>
                                </td>
                                <td data-label="Datum nabave">
                                    @(p.DatumNabave.HasValue? p.DatumNabave.Value.ToString("dd.MM.yyyy") : "—")
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="primjerci-legenda">
            @if (jeOsoblje)
            {
                <span class="legenda-item primjerci-legenda-hint">
                    💡 Kliknite na primjerak za pregled svih zaduženja
                </span>
            }
            <span class="legenda-item"><span class="status-dostupan">dostupan</span> = slobodan za zaduživanje</span>
            <span class="legenda-item"><span class="status-zaduzen">zadužen</span> = trenutno kod člana</span>
            <span class="legenda-item"><span class="status-deaktiviran">deaktiviran</span> = oštećen / izgubljen</span>
        </div>
    }
</div>

@{
    var recenzije = ViewBag.Recenzije as IEnumerable<Recenzija> ?? new List<Recenzija>();
    var prosjek = recenzije.Any() ? recenzije.Average(r => r.Ocjena) : 0;
    var reviewSuccessMsg = TempData["ReviewSuccessMessage"] as string;
    var reviewErrorMsg = TempData["ReviewErrorMessage"] as string;
}
<div id="reviews-section" class="card" style="margin-top: 2rem;">
    <div class="examples-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; margin-bottom: 1.5rem;">
        <div>
            <h3 class="examples-title" style="margin: 0;">Recenzije čitalaca</h3>
            @if(recenzije.Any())
            {
                <div style="color: #fbbf24; font-size: 1.2rem; margin-top: 0.25rem;">
                    @prosjek.ToString("0.0") ⭐ <span style="font-size: 0.9rem; color: var(--text-muted);">(@recenzije.Count() recenzija)</span>
                </div>
            }
        </div>
        @if(!jeOsoblje)
        {
            <a asp-controller="Recenzija" asp-action="Dodaj" asp-route-knjigaId="@Model.Id" class="btn btn-outline btn-sm">Ocijeni knjigu</a>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(reviewSuccessMsg))
    {
        <div class="alert alert-success" style="margin-bottom: 1rem;">@reviewSuccessMsg</div>
    }
    @if (!string.IsNullOrWhiteSpace(reviewErrorMsg))
    {
        <div class="alert alert-error" style="margin-bottom: 1rem;">@reviewErrorMsg</div>
    }

    @if (!recenzije.Any())
    {
        <div style="text-align: center; color: var(--text-muted); padding: 2rem 0;">
            <p>Ova knjiga još nema recenzija.</p>
        </div>
    }
    else
    {
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            @foreach (var r in recenzije)
            {
                <div style="background: var(--bg-alt); padding: 1.25rem; border-radius: 8px; border: 1px solid var(--border-color);">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem;">
                        <div>
                            <strong style="color: var(--text-main);">@(r.Korisnik?.Ime) @(r.Korisnik?.Prezime)</strong>
                            <div style="color: var(--text-muted); font-size: 0.85rem;">@r.DatumKreiranja.ToLocalTime().ToString("dd.MM.yyyy")</div>
                        </div>
                        <div style="display: flex; align-items: center; gap: 0.75rem;">
                            <div style="color: #fbbf24; font-weight: bold;">
                                @r.Ocjena / 5 ⭐
                            </div>
                            @if (jeOsoblje)
                            {
                                <form asp-controller="Recenzija" asp-action="Delete" method="post"
                                      onsubmit="return confirm('Ukloniti ovu recenziju?');">
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <input type="hidden" name="knjigaId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm" title="Ukloni neadekvatnu recenziju">🗑 Ukloni</button>
                                </form>
                            }
                        </div>
                    </div>
                    @if(!string.IsNullOrWhiteSpace(r.Komentar))
                    {
                        <p style="margin: 0; color: var(--text-secondary); line-height: 1.5;">@r.Komentar</p>
                    }
                </div>
            }
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(reviewSuccessMsg) || !string.IsNullOrWhiteSpace(reviewErrorMsg))
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var section = document.getElementById('reviews-section');
            if (section) {
                section.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    </script>
}
