@model SmartLib.Core.DTOs.KatalogViewModel
@{
    ViewData["Title"] = "Katalog knjiga";
}

<div class="katalog-header">
    <h2>Katalog knjiga</h2>
    @if (User.IsInRole("Bibliotekar") || User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Nova knjiga</a>
    }
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success">@successMsg</div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-error">@errorMsg</div>
}

<!-- Pretraga -->
<div class="card katalog-search">
    <form asp-controller="Knjiga" asp-action="Index" method="get">
        <div class="search-row">
            <input type="hidden" name="page" value="1" />
            <div class="form-group" style="flex:1; margin-bottom:0;">
                <input type="text" name="naslov" value="@Model.Naslov" placeholder="Pretraga po naslovu..." />
            </div>
            <div class="form-group" style="flex:1; margin-bottom:0;">
                <input type="text" name="autor" value="@Model.Autor" placeholder="Pretraga po autoru..." />
            </div>
            <div style="display:flex; gap:0.5rem; align-items:flex-end;">
                <button type="submit" class="btn btn-primary">Traži</button>
                <a asp-controller="Knjiga" asp-action="Index" class="btn btn-secondary">Reset</a>
            </div>
        </div>
    </form>
</div>

<!-- Rezultati -->
<div class="katalog-meta">
    @if (!string.IsNullOrWhiteSpace(Model.Naslov) || !string.IsNullOrWhiteSpace(Model.Autor))
    {
        <span>Pronađeno: <strong>@Model.UkupnoStavki</strong> knjiga</span>
    }
    else
    {
        <span>Ukupno knjiga u katalogu: <strong>@Model.UkupnoStavki</strong></span>
    }
</div>

<!-- View Toggle -->
<div class="view-toggle-container">
    <div class="view-toggle">
        <button type="button" class="toggle-btn active" id="btn-list-view" title="Lista">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
        </button>
        <button type="button" class="toggle-btn" id="btn-grid-view" title="Mreža">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
        </button>
    </div>
    <div class="katalog-page-size">
        <label for="pageSizeSelect">📖 Prikaži:</label>
        <select id="pageSizeSelect" aria-label="Broj knjiga po stranici">
            <option value="8" selected="@(Model.VelicinaStrane == 8)">8 knjiga</option>
            <option value="12" selected="@(Model.VelicinaStrane == 12)">12 knjiga</option>
            <option value="16" selected="@(Model.VelicinaStrane == 16)">16 knjiga</option>
            <option value="20" selected="@(Model.VelicinaStrane == 20)">20 knjiga</option>
            <option value="24" selected="@(Model.VelicinaStrane == 24)">24 knjiga</option>
        </select>
    </div>
</div>

@if (!Model.Knjige.Any())
{
    <div class="card katalog-empty">
        <p>📚 Katalog je trenutno prazan.</p>
        @if (User.IsInRole("Bibliotekar") || User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn btn-primary">Dodaj prvu knjigu</a>
        }
    </div>
}
else
{
    <!-- LIST VIEW (Letterboxd style) -->
    <div id="katalog-list-layout" class="lb-list-layout">
        @foreach (var knjiga in Model.Knjige)
        {
            <div class="lb-list-item">
                <a asp-action="Details" asp-route-id="@knjiga.Id" class="stretched-link"></a>
                <div class="lb-cover">
                    <img src="@Url.Action("Korice", "Knjiga", new { isbn = knjiga.Isbn, size = "L", v = 3 })" 
                         alt="@knjiga.Naslov" 
                         loading="lazy" />
                </div>
                <div class="lb-body">
                    <div class="lb-body-top">
                        <h3 class="lb-title">@knjiga.Naslov</h3>
                        <span class="lb-author">@knjiga.Autor@(knjiga.GodinaIzdanja.HasValue ? $", {knjiga.GodinaIzdanja}" : "")</span>
                        
                        <div class="lb-rating-row">
                            <span class="lb-stars">
                                @for(int i = 1; i <= 5; i++)
                                {
                                    if (knjiga.BrojRecenzija > 0)
                                    {
                                        if (i <= Math.Floor(knjiga.ProsjecnaOcjena))
                                        {
                                            <span class="star full">★</span>
                                        }
                                        else if (i - knjiga.ProsjecnaOcjena < 1 && i - knjiga.ProsjecnaOcjena > 0)
                                        {
                                            <span class="star half">★</span>
                                        }
                                        else
                                        {
                                            <span class="star empty">★</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="star empty">★</span>
                                    }
                                }
                            </span>
                            @if (knjiga.BrojRecenzija > 0)
                            {
                                <span class="lb-rating-score">@knjiga.ProsjecnaOcjena.ToString("0.0")</span>
                                <span class="lb-rating-count">(@knjiga.BrojRecenzija @(knjiga.BrojRecenzija == 1 ? "recenzija" : "recenzija"))</span>
                            }
                            else
                            {
                                <span class="lb-rating-count">Nema recenzija</span>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(knjiga.Opis))
                    {
                        <p class="lb-description">@(knjiga.Opis.Length > 200 ? knjiga.Opis.Substring(0, 200) + "…" : knjiga.Opis)</p>
                    }

                    <div class="lb-body-bottom">
                        <div class="lb-tags">
                            @if (knjiga.Kategorija != null)
                            {
                                <span class="lb-tag">@knjiga.Kategorija</span>
                            }
                            <span class="lb-availability @(knjiga.BrojDostupnih > 0 ? "available" : "unavailable")">
                                @(knjiga.BrojDostupnih > 0 ? $"✓ Dostupno ({knjiga.BrojDostupnih})" : "✗ Zauzeto")
                            </span>
                        </div>
                        @if (User.IsInRole("Bibliotekar") || User.IsInRole("Administrator"))
                        {
                            <div class="lb-actions">
                                <a asp-action="Edit" asp-route-id="@knjiga.Id" class="btn btn-primary btn-sm">Uredi</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- GRID VIEW (Letterboxd poster style) -->
    <div id="katalog-grid-layout" class="lb-grid-layout hidden-layout">
        <div class="katalog-picks">
            Naše preporuke
        </div>
        @foreach (var knjiga in Model.Knjige)
        {
            <a asp-action="Details" asp-route-id="@knjiga.Id" class="lb-grid-card">
                <div class="lb-grid-poster">
                    <img src="@Url.Action("Korice", "Knjiga", new { isbn = knjiga.Isbn, size = "L" })" 
                         alt="@knjiga.Naslov" 
                         loading="lazy" />
                    <div class="lb-grid-overlay">
                        <div class="lb-grid-overlay-stars">
                            @for(int i = 1; i <= 5; i++)
                            {
                                if (knjiga.BrojRecenzija > 0 && i <= Math.Round(knjiga.ProsjecnaOcjena))
                                {
                                    <span class="star full">★</span>
                                }
                                else
                                {
                                    <span class="star empty">★</span>
                                }
                            }
                        </div>
                        @if (knjiga.BrojRecenzija > 0)
                        {
                            <span class="lb-grid-overlay-score">@knjiga.ProsjecnaOcjena.ToString("0.0")</span>
                        }
                    </div>
                    <span class="lb-grid-avail @(knjiga.BrojDostupnih > 0 ? "available" : "unavailable")">
                        @(knjiga.BrojDostupnih > 0 ? "Dostupno" : "Zauzeto")
                    </span>
                </div>
                <div class="lb-grid-info">
                    <span class="lb-grid-title">@knjiga.Naslov</span>
                    <span class="lb-grid-author">@knjiga.Autor</span>
                </div>
            </a>
        }
    </div>

    <!-- Paginacija -->
    @if (Model.UkupnoStrana > 1)
    {
        <div class="pagination">
                 @if (Model.TrenutnaStrana > 1)
            {
                <a asp-action="Index"
                     asp-route-page="@(Model.TrenutnaStrana - 1)"
                     asp-route-naslov="@Model.Naslov"
                     asp-route-autor="@Model.Autor"
                     asp-route-pageSize="@Model.VelicinaStrane"
                   class="btn btn-secondary">← Prethodna</a>
            }
            else
            {
                <span class="btn btn-secondary pagination-disabled">← Prethodna</span>
            }

            <span class="pagination-info">
                Strana <strong>@Model.TrenutnaStrana</strong> od <strong>@Model.UkupnoStrana</strong>
            </span>

            @if (Model.TrenutnaStrana < Model.UkupnoStrana)
            {
                <a asp-action="Index"
                     asp-route-page="@(Model.TrenutnaStrana + 1)"
                     asp-route-naslov="@Model.Naslov"
                     asp-route-autor="@Model.Autor"
                     asp-route-pageSize="@Model.VelicinaStrane"
                   class="btn btn-secondary">Sljedeća →</a>
            }
            else
            {
                <span class="btn btn-secondary pagination-disabled">Sljedeća →</span>
            }
        </div>
    }
}

@section Scripts {
    <script>
        const btnList = document.getElementById('btn-list-view');
        const btnGrid = document.getElementById('btn-grid-view');
        const layoutList = document.getElementById('katalog-list-layout');
        const layoutGrid = document.getElementById('katalog-grid-layout');

        btnList.addEventListener('click', () => {
            btnList.classList.add('active');
            btnGrid.classList.remove('active');
            layoutList.classList.remove('hidden-layout');
            layoutGrid.classList.add('hidden-layout');
            localStorage.setItem('katalogView', 'list');
        });

        btnGrid.addEventListener('click', () => {
            btnGrid.classList.add('active');
            btnList.classList.remove('active');
            layoutGrid.classList.remove('hidden-layout');
            layoutList.classList.add('hidden-layout');
            localStorage.setItem('katalogView', 'grid');
        });

        // Restore preference
        const savedView = localStorage.getItem('katalogView');
        if (savedView === 'grid') {
            btnGrid.click();
        }

        const pageSizeSelect = document.getElementById('pageSizeSelect');
        if (pageSizeSelect) {
            pageSizeSelect.addEventListener('change', () => {
                const params = new URLSearchParams(window.location.search);
                params.set('pageSize', pageSizeSelect.value);
                params.set('page', '1');
                const newUrl = window.location.pathname + '?' + params.toString();
                window.location.assign(newUrl);
            });
        }

        // Sync pageSizeSelect value with current model value
        if (pageSizeSelect) {
            pageSizeSelect.value = '@Model.VelicinaStrane';
        }
    </script>
}

