@model SmartLib.Core.DTOs.KatalogViewModel
@{
    ViewData["Title"] = "Katalog knjiga";
    bool jeClan = User.IsInRole("Član");
}

<div class="katalog-header">
    <h2>Katalog knjiga</h2>
    @if (User.IsInRole("Bibliotekar") || User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Nova knjiga</a>
    }
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success">@successMsg</div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-error">@errorMsg</div>
}

<!-- ═══════════════════════════════════════════════════════════════════════════
     PB-44: Pretraga i filteri
     Osnovna pretraga (naslov, autor) + collapsible panel za napredne filtere
     ═══════════════════════════════════════════════════════════════════════════ -->
<div class="card katalog-search">
    <form asp-controller="Knjiga" asp-action="Index" method="get" id="filter-form">
        <input type="hidden" name="page" value="1" />

        <!-- Osnovna pretraga — uvijek vidljiva -->
        <div class="search-row">
            <div class="form-group" style="flex:1; margin-bottom:0;">
                <input type="text" name="naslov" value="@Model.Naslov" placeholder="Pretraga po naslovu..." />
            </div>
            <div class="form-group" style="flex:1; margin-bottom:0;">
                <input type="text" name="autor" value="@Model.Autor" placeholder="Pretraga po autoru..." />
            </div>
            <div style="display:flex; gap:0.5rem; align-items:flex-end;">
                <button type="submit" class="btn btn-primary">Traži</button>
                <a asp-controller="Knjiga" asp-action="Index" class="btn btn-secondary">Reset</a>
                <!-- PB-44: Toggle dugme za napredne filtere -->
                <button type="button"
                        id="btn-advanced-toggle"
                        class="btn btn-secondary @(Model.ImaNapredniFilter ? "active-filter-btn" : "")"
                        aria-expanded="@(Model.ImaNapredniFilter ? "true" : "false")"
                        aria-controls="advanced-filters-panel"
                        title="Dodatni filteri pretrage">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
                         style="vertical-align:middle; margin-right:4px;">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z" />
                    </svg>
                    Filteri
                    @if (Model.ImaNapredniFilter)
                    {
                        <!-- Indikator aktivnih filtera -->
                        <span class="filter-badge">●</span>
                    }
                </button>
            </div>
        </div>

        <!-- PB-44: Collapsible panel za napredne filtere -->
        <div id="advanced-filters-panel"
             class="advanced-filters-panel @(Model.ImaNapredniFilter ? "filters-open" : "")">
            <div class="advanced-filters-inner">
                <div class="advanced-filters-grid">

                    <!-- US-74: Filter po kategoriji -->
                    <div class="form-group filter-group">
                        <label for="filter-kategorija">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
                                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" />
                            </svg>
                            Kategorija
                        </label>
                        <select id="filter-kategorija" name="kategorijaId" class="filter-select">
                            <option value="">— Sve kategorije —</option>
                            @foreach (var kat in Model.Kategorije)
                            {
                                <option value="@kat.Id"
                                        selected="@(Model.KategorijaId == kat.Id)">
                                    @kat.Naziv
                                </option>
                            }
                        </select>
                    </div>

                    <!-- US-75: Filter po izdavaču -->
                    <div class="form-group filter-group">
                        <label for="filter-izdavac">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
                                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                            </svg>
                            Izdavač
                        </label>
                        <select id="filter-izdavac" name="izdavac" class="filter-select">
                            <option value="">— Svi izdavači —</option>
                            @foreach (var izd in Model.Izdavaci)
                            {
                                <option value="@izd"
                                        selected="@(Model.Izdavac == izd)">
                                    @izd
                                </option>
                            }
                        </select>
                    </div>

                    <!-- US-76: Filter po godini izdanja -->
                    <div class="form-group filter-group">
                        <label for="filter-godina">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
                                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                            Godina izdanja
                        </label>
                        <select id="filter-godina" name="godinaIzdanja" class="filter-select">
                            <option value="">— Sve godine —</option>
                            @foreach (var god in Model.Godine)
                            {
                                <option value="@god"
                                        selected="@(Model.GodinaIzdanja == god)">
                                    @god
                                </option>
                            }
                        </select>
                    </div>

                    @if (jeClan)
                    {
                        <div class="form-group filter-group">
                            <label for="filter-procitane">Status citanja</label>
                            <label class="katalog-read-toggle">
                                <input id="filter-procitane" class="katalog-read-checkbox" type="checkbox" name="samoNeprocitane" value="true"
                                       @(Model.SamoNeprocitane ? "checked" : "") />
                                Samo neprocitane
                            </label>
                        </div>
                    }

                </div>
            </div>
        </div>

    </form>
</div>

<!-- Aktivni filteri — summary chips -->
@if (Model.ImaAktivnihFiltera)
{
    <div class="active-filters-bar">
        <span class="active-filters-label">Aktivni filteri:</span>
        @if (!string.IsNullOrWhiteSpace(Model.Naslov))
        {
            <span class="filter-chip">
                Naslov: <strong>@Model.Naslov</strong>
                <a asp-action="Index"
                   asp-route-autor="@Model.Autor"
                   asp-route-kategorijaId="@Model.KategorijaId"
                   asp-route-izdavac="@Model.Izdavac"
                   asp-route-godinaIzdanja="@Model.GodinaIzdanja"
                   asp-route-samoNeprocitane="@Model.SamoNeprocitane"
                   asp-route-page="1"
                   class="chip-remove" title="Ukloni filter">×</a>
            </span>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Autor))
        {
            <span class="filter-chip">
                Autor: <strong>@Model.Autor</strong>
                <a asp-action="Index"
                   asp-route-naslov="@Model.Naslov"
                   asp-route-kategorijaId="@Model.KategorijaId"
                   asp-route-izdavac="@Model.Izdavac"
                   asp-route-godinaIzdanja="@Model.GodinaIzdanja"
                   asp-route-samoNeprocitane="@Model.SamoNeprocitane"
                   asp-route-page="1"
                   class="chip-remove" title="Ukloni filter">×</a>
            </span>
        }
        @if (Model.KategorijaId.HasValue)
        {
            var katNaziv = Model.Kategorije.FirstOrDefault(k => k.Id == Model.KategorijaId)?.Naziv ?? "—";
            <span class="filter-chip">
                Kategorija: <strong>@katNaziv</strong>
                <a asp-action="Index"
                   asp-route-naslov="@Model.Naslov"
                   asp-route-autor="@Model.Autor"
                   asp-route-izdavac="@Model.Izdavac"
                   asp-route-godinaIzdanja="@Model.GodinaIzdanja"
                   asp-route-samoNeprocitane="@Model.SamoNeprocitane"
                   asp-route-page="1"
                   class="chip-remove" title="Ukloni filter">×</a>
            </span>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Izdavac))
        {
            <span class="filter-chip">
                Izdavač: <strong>@Model.Izdavac</strong>
                <a asp-action="Index"
                   asp-route-naslov="@Model.Naslov"
                   asp-route-autor="@Model.Autor"
                   asp-route-kategorijaId="@Model.KategorijaId"
                   asp-route-godinaIzdanja="@Model.GodinaIzdanja"
                   asp-route-samoNeprocitane="@Model.SamoNeprocitane"
                   asp-route-page="1"
                   class="chip-remove" title="Ukloni filter">×</a>
            </span>
        }
        @if (Model.GodinaIzdanja.HasValue)
        {
            <span class="filter-chip">
                Godina: <strong>@Model.GodinaIzdanja</strong>
                <a asp-action="Index"
                   asp-route-naslov="@Model.Naslov"
                   asp-route-autor="@Model.Autor"
                   asp-route-kategorijaId="@Model.KategorijaId"
                   asp-route-izdavac="@Model.Izdavac"
                   asp-route-samoNeprocitane="@Model.SamoNeprocitane"
                   asp-route-page="1"
                   class="chip-remove" title="Ukloni filter">×</a>
            </span>
        }
        @if (Model.SamoNeprocitane)
        {
            <span class="filter-chip">
                Samo neprocitane
                <a asp-action="Index"
                   asp-route-naslov="@Model.Naslov"
                   asp-route-autor="@Model.Autor"
                   asp-route-kategorijaId="@Model.KategorijaId"
                   asp-route-izdavac="@Model.Izdavac"
                   asp-route-godinaIzdanja="@Model.GodinaIzdanja"
                   asp-route-samoNeprocitane="false"
                   asp-route-page="1"
                   class="chip-remove" title="Ukloni filter">×</a>
            </span>
        }
    </div>
}

<!-- Rezultati -->
<div class="katalog-meta">
    @if (Model.ImaAktivnihFiltera)
    {
        <span>Pronađeno: <strong>@Model.UkupnoStavki</strong> @(Model.UkupnoStavki == 1 ? "knjiga" : "knjiga")</span>
    }
    else
    {
        <span>Ukupno knjiga u katalogu: <strong>@Model.UkupnoStavki</strong></span>
    }
    @if (jeClan)
    {
        <span style="margin-left: 0.75rem; color: var(--text-muted);">Procitano: <strong>@Model.ProcitaneUkupno</strong></span>
    }
</div>

<!-- View Toggle -->
<div class="view-toggle-container">
    <div class="view-toggle">
        <button type="button" class="toggle-btn active" id="btn-list-view" title="Lista">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
        </button>
        <button type="button" class="toggle-btn" id="btn-grid-view" title="Mreža">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
        </button>
    </div>
    <div class="katalog-page-size">
        <label for="pageSizeSelect">📖 Prikaži:</label>
        <select id="pageSizeSelect" aria-label="Broj knjiga po stranici">
            <option value="8" selected="@(Model.VelicinaStrane == 8)">8 knjiga</option>
            <option value="12" selected="@(Model.VelicinaStrane == 12)">12 knjiga</option>
            <option value="16" selected="@(Model.VelicinaStrane == 16)">16 knjiga</option>
            <option value="20" selected="@(Model.VelicinaStrane == 20)">20 knjiga</option>
            <option value="24" selected="@(Model.VelicinaStrane == 24)">24 knjiga</option>
        </select>
    </div>
</div>

@if (!Model.Knjige.Any())
{
    <!-- PB-44: "Nema rezultata" poruke po US-74 / US-75 / US-76 / US-78 -->
    <div class="card katalog-empty">
        @if (Model.ImaAktivnihFiltera)
        {
            if (Model.KategorijaId.HasValue && !Model.GodinaIzdanja.HasValue && string.IsNullOrWhiteSpace(Model.Izdavac)
            && string.IsNullOrWhiteSpace(Model.Naslov) && string.IsNullOrWhiteSpace(Model.Autor))
            {
                <!-- US-74 -->
                <p>📚 Nema rezultata za odabranu kategoriju.</p>
            }
            else if (!string.IsNullOrWhiteSpace(Model.Izdavac) && !Model.KategorijaId.HasValue && !Model.GodinaIzdanja.HasValue
            && string.IsNullOrWhiteSpace(Model.Naslov) && string.IsNullOrWhiteSpace(Model.Autor))
            {
                <!-- US-75 -->
                <p>📚 Nema knjiga za odabranog izdavača.</p>
            }
            else if (Model.GodinaIzdanja.HasValue && !Model.KategorijaId.HasValue && string.IsNullOrWhiteSpace(Model.Izdavac)
            && string.IsNullOrWhiteSpace(Model.Naslov) && string.IsNullOrWhiteSpace(Model.Autor))
            {
                <!-- US-76 -->
                <p>📚 Nema knjiga za odabranu godinu.</p>
            }
            else
            {
                <!-- US-78: Kombinacija filtera -->
                <p>📚 Nema rezultata za odabrane filtere.</p>
            }
            <a asp-action="Index" class="btn btn-secondary" style="margin-top:0.75rem;">Ukloni sve filtere</a>
        }
        else
        {
            <p>📚 Katalog je trenutno prazan.</p>
            @if (User.IsInRole("Bibliotekar") || User.IsInRole("Administrator"))
            {
                <a asp-action="Create" class="btn btn-primary">Dodaj prvu knjigu</a>
            }
        }
    </div>
}
else
{
    <!-- LIST VIEW (Letterboxd style) -->
    <div id="katalog-list-layout" class="lb-list-layout slide-animation">
        @foreach (var knjiga in Model.Knjige)
        {
            <div class="lb-list-item">
                <a asp-action="Details" asp-route-id="@knjiga.Id" class="stretched-link"></a>
                <div class="lb-cover" style="position: relative;">
                    <img src="@Url.Action("Korice", "Knjiga", new { isbn = knjiga.Isbn, size = "L", v = 3 })"
                         alt="@knjiga.Naslov"
                         loading="lazy" />
                    @if (jeClan && knjiga.Procitana)
                    {
                        <span style="position:absolute;top:10px;left:10px;background:rgba(16,185,129,0.92);color:#fff;border-radius:999px;padding:0.2rem 0.5rem;font-size:0.75rem;font-weight:600;">✓ Pročitano</span>
                    }
                </div>
                <div class="lb-body">
                    <div class="lb-body-top">
                        <h3 class="lb-title">@knjiga.Naslov</h3>
                        <span class="lb-author">@knjiga.Autor@(knjiga.GodinaIzdanja.HasValue ? $", {knjiga.GodinaIzdanja}" : "")</span>

                        <div class="lb-rating-row">
                            <span class="lb-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (knjiga.BrojRecenzija > 0)
                                    {
                                        if (i <= Math.Floor(knjiga.ProsjecnaOcjena))
                                        {
                                            <span class="star full">★</span>
                                        }
                                        else if (i - knjiga.ProsjecnaOcjena < 1 && i - knjiga.ProsjecnaOcjena > 0)
                                        {
                                            <span class="star half">★</span>
                                        }
                                        else
                                        {
                                            <span class="star empty">★</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="star empty">★</span>
                                    }
                                }
                            </span>
                            @if (knjiga.BrojRecenzija > 0)
                            {
                                <span class="lb-rating-score">@knjiga.ProsjecnaOcjena.ToString("0.0")</span>
                                <span class="lb-rating-count">(@knjiga.BrojRecenzija @(knjiga.BrojRecenzija == 1 ? "recenzija" : "recenzija"))</span>
                            }
                            else
                            {
                                <span class="lb-rating-count">Nema recenzija</span>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(knjiga.Opis))
                    {
                        <p class="lb-description">@(knjiga.Opis.Length > 200 ? knjiga.Opis.Substring(0, 200) + "…" : knjiga.Opis)</p>
                    }

                    <div class="lb-body-bottom">
                        <div class="lb-tags">
                            @if (knjiga.Kategorija != null)
                            {
                                <span class="lb-tag">@knjiga.Kategorija</span>
                            }
                            @if (jeClan && knjiga.Procitana)
                            {
                                <span class="lb-tag" style="background: rgba(16,185,129,0.12); color: #10b981;">Pročitano</span>
                            }
                            <span class="lb-availability @(knjiga.BrojDostupnih > 0 ? "available" : "unavailable")">
                                @(knjiga.BrojDostupnih > 0 ? $"✓ Dostupno ({knjiga.BrojDostupnih})" : "✗ Zauzeto")
                            </span>
                        </div>
                        @if (User.IsInRole("Bibliotekar") || User.IsInRole("Administrator"))
                        {
                            <div class="lb-actions">
                                <a asp-action="Edit" asp-route-id="@knjiga.Id" class="btn btn-primary btn-sm">Uredi</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- GRID VIEW (Letterboxd poster style) -->
    <div id="katalog-grid-layout" class="lb-grid-layout hidden-layout slide-animation">
        <div class="katalog-picks">
            Naše preporuke
        </div>
        @foreach (var knjiga in Model.Knjige)
        {
            <a asp-action="Details" asp-route-id="@knjiga.Id" class="lb-grid-card">
                <div class="lb-grid-poster" style="position: relative;">
                    <img src="@Url.Action("Korice", "Knjiga", new { isbn = knjiga.Isbn, size = "L" })"
                         alt="@knjiga.Naslov"
                         loading="lazy" />
                    @if (jeClan && knjiga.Procitana)
                    {
                        <span class="lb-grid-avail" style="left: 12px; right: auto; background: rgba(16,185,129,0.9);">Pročitano</span>
                    }
                    <div class="lb-grid-overlay">
                        <div class="lb-grid-overlay-stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (knjiga.BrojRecenzija > 0 && i <= Math.Round(knjiga.ProsjecnaOcjena))
                                {
                                    <span class="star full">★</span>
                                }
                                else
                                {
                                    <span class="star empty">★</span>
                                }
                            }
                        </div>
                        @if (knjiga.BrojRecenzija > 0)
                        {
                            <span class="lb-grid-overlay-score">@knjiga.ProsjecnaOcjena.ToString("0.0")</span>
                        }
                    </div>
                    <span class="lb-grid-avail @(knjiga.BrojDostupnih > 0 ? "available" : "unavailable")">
                        @(knjiga.BrojDostupnih > 0 ? "Dostupno" : "Zauzeto")
                    </span>
                </div>
                <div class="lb-grid-info">
                    <span class="lb-grid-title">@knjiga.Naslov</span>
                    <span class="lb-grid-author">@knjiga.Autor</span>
                </div>
            </a>
        }
    </div>

    <!-- Paginacija -->
    @if (Model.UkupnoStrana > 1)
    {
        <div class="pagination">
            @if (Model.TrenutnaStrana > 1)
            {
                <a asp-action="Index"
                   asp-route-page="@(Model.TrenutnaStrana - 1)"
                   asp-route-naslov="@Model.Naslov"
                   asp-route-autor="@Model.Autor"
                   asp-route-kategorijaId="@Model.KategorijaId"
                   asp-route-izdavac="@Model.Izdavac"
                 asp-route-godinaIzdanja="@Model.GodinaIzdanja"
                 asp-route-samoNeprocitane="@Model.SamoNeprocitane"
                   asp-route-pageSize="@Model.VelicinaStrane"
                   class="btn btn-secondary">← Prethodna</a>
            }
            else
            {
                <span class="btn btn-secondary pagination-disabled">← Prethodna</span>
            }

            <span class="pagination-info">
                Strana <strong>@Model.TrenutnaStrana</strong> od <strong>@Model.UkupnoStrana</strong>
            </span>

            @if (Model.TrenutnaStrana < Model.UkupnoStrana)
            {
                <a asp-action="Index"
                   asp-route-page="@(Model.TrenutnaStrana + 1)"
                   asp-route-naslov="@Model.Naslov"
                   asp-route-autor="@Model.Autor"
                   asp-route-kategorijaId="@Model.KategorijaId"
                   asp-route-izdavac="@Model.Izdavac"
                 asp-route-godinaIzdanja="@Model.GodinaIzdanja"
                 asp-route-samoNeprocitane="@Model.SamoNeprocitane"
                   asp-route-pageSize="@Model.VelicinaStrane"
                   class="btn btn-secondary">Sljedeća →</a>
            }
            else
            {
                <span class="btn btn-secondary pagination-disabled">Sljedeća →</span>
            }
        </div>
    }
}

@section Scripts {
    <script>
        // ── List / Grid toggle ────────────────────────────────────────────────────
        const btnList   = document.getElementById('btn-list-view');
        const btnGrid   = document.getElementById('btn-grid-view');
        const layoutList = document.getElementById('katalog-list-layout');
        const layoutGrid = document.getElementById('katalog-grid-layout');

        function switchLayout(oldLayout, newLayout) {
            oldLayout.classList.add('slide-leave');
            setTimeout(() => {
                oldLayout.classList.add('hidden-layout');
                oldLayout.classList.remove('slide-leave');
                
                newLayout.classList.remove('hidden-layout');
                newLayout.classList.add('slide-enter');
                requestAnimationFrame(() => {
                    newLayout.classList.remove('slide-enter');
                });
            }, 300);
        }

        btnList.addEventListener('click', () => {
            if (btnList.classList.contains('active')) return;
            btnList.classList.add('active');
            btnGrid.classList.remove('active');
            switchLayout(layoutGrid, layoutList);
            localStorage.setItem('katalogView', 'list');
        });

        btnGrid.addEventListener('click', () => {
            if (btnGrid.classList.contains('active')) return;
            btnGrid.classList.add('active');
            btnList.classList.remove('active');
            switchLayout(layoutList, layoutGrid);
            localStorage.setItem('katalogView', 'grid');
        });

        const savedView = localStorage.getItem('katalogView');
        if (savedView === 'grid') btnGrid.click();

        // ── Page size select ──────────────────────────────────────────────────────
        const pageSizeSelect = document.getElementById('pageSizeSelect');
        if (pageSizeSelect) {
            pageSizeSelect.value = '@Model.VelicinaStrane';
            pageSizeSelect.addEventListener('change', () => {
                const params = new URLSearchParams(window.location.search);
                params.set('pageSize', pageSizeSelect.value);
                params.set('page', '1');
                window.location.assign(window.location.pathname + '?' + params.toString());
            });
        }

        // ── PB-44: Advanced filters panel toggle ──────────────────────────────────
        const toggleBtn = document.getElementById('btn-advanced-toggle');
        const panel     = document.getElementById('advanced-filters-panel');

        if (toggleBtn && panel) {
            toggleBtn.addEventListener('click', () => {
                const isOpen = panel.classList.toggle('filters-open');
                toggleBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            });
        }

        // Ako je aktivan neki napredni filter pri page loadu — panel ostaje otvoren
        // (Kontrolirano direktno kroz Razor klasu 'filters-open' na elementu, gore.)
    </script>
}
