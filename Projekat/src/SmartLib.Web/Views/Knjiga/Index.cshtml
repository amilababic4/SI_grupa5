@* TODO: @model IEnumerable<KnjigaDto> *@
@{
    ViewData["Title"] = "Katalog";
}

<h2>Katalog knjiga</h2>

<!-- Pretraga -->
<div class="card" style="margin-top: 1rem;">
    <form asp-controller="Knjiga" asp-action="Index" method="get" style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <input type="text" name="naslov" placeholder="Pretraga po naslovu..." style="flex: 1; padding: 0.5rem;" />
        <input type="text" name="autor" placeholder="Pretraga po autoru..." style="flex: 1; padding: 0.5rem;" />
        <button type="submit" class="btn btn-primary">Traži</button>
        <a asp-controller="Knjiga" asp-action="Index" class="btn btn-secondary">Reset</a>
    </form>
</div>

