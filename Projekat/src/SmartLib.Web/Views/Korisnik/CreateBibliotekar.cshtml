@model SmartLib.Core.DTOs.KorisnikCreateDto
@{
    ViewData["Title"] = "Kreiranje bibliotekara";
}

<h2 style="text-align: center; margin-bottom: 20px;">Kreiranje naloga bibliotekara</h2>

<div class="card" style="max-width: 650px; margin: 40px auto; padding: 20px;">
    <form asp-controller="Korisnik" asp-action="CreateBibliotekar" method="post" novalidate>
        <div asp-validation-summary="ModelOnly" class="validation-message" style="margin-bottom: 1rem;"></div>

        <div class="form-group">
            <label asp-for="Ime">Ime</label>
            <input asp-for="Ime" />
            <span asp-validation-for="Ime" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Prezime">Prezime</label>
            <input asp-for="Prezime" />
            <span asp-validation-for="Prezime" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email">Email adresa</label>
            <input asp-for="Email" type="email" placeholder="ime.prezime@email.com" />
            <span asp-validation-for="Email" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Lozinka">Lozinka</label>
            <div class="password-field">
                <input asp-for="Lozinka" type="password" class="password-input" />
                <button type="button" class="password-toggle" aria-label="Prikazi lozinku" aria-pressed="false">
                    <svg class="icon-eye" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M2.5 12s3.5-6.5 9.5-6.5 9.5 6.5 9.5 6.5-3.5 6.5-9.5 6.5S2.5 12 2.5 12z" fill="none" stroke="currentColor" stroke-width="1.7" />
                        <circle cx="12" cy="12" r="3.5" fill="none" stroke="currentColor" stroke-width="1.7" />
                    </svg>
                    <svg class="icon-eye-off" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M4 4l16 16" fill="none" stroke="currentColor" stroke-width="1.7" />
                        <path d="M7.5 7.5C9 6.4 10.8 5.5 12.5 5.5c6 0 9.5 6.5 9.5 6.5a17.9 17.9 0 0 1-3.2 4.3" fill="none" stroke="currentColor" stroke-width="1.7" />
                        <path d="M15.6 15.6a3.5 3.5 0 0 1-4.95-4.95" fill="none" stroke="currentColor" stroke-width="1.7" />
                        <path d="M5.7 13.9C3.7 12 2.5 10 2.5 10s.7-1.4 2.1-3.1" fill="none" stroke="currentColor" stroke-width="1.7" />
                    </svg>
                </button>
            </div>
            <span asp-validation-for="Lozinka" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="PotvrdaLozinke">Potvrdi lozinku</label>
            <div class="password-field">
                <input asp-for="PotvrdaLozinke" type="password" class="password-input" />
                <button type="button" class="password-toggle" aria-label="Prikazi lozinku" aria-pressed="false">
                    <svg class="icon-eye" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M2.5 12s3.5-6.5 9.5-6.5 9.5 6.5 9.5 6.5-3.5 6.5-9.5 6.5S2.5 12 2.5 12z" fill="none" stroke="currentColor" stroke-width="1.7" />
                        <circle cx="12" cy="12" r="3.5" fill="none" stroke="currentColor" stroke-width="1.7" />
                    </svg>
                    <svg class="icon-eye-off" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M4 4l16 16" fill="none" stroke="currentColor" stroke-width="1.7" />
                        <path d="M7.5 7.5C9 6.4 10.8 5.5 12.5 5.5c6 0 9.5 6.5 9.5 6.5a17.9 17.9 0 0 1-3.2 4.3" fill="none" stroke="currentColor" stroke-width="1.7" />
                        <path d="M15.6 15.6a3.5 3.5 0 0 1-4.95-4.95" fill="none" stroke="currentColor" stroke-width="1.7" />
                        <path d="M5.7 13.9C3.7 12 2.5 10 2.5 10s.7-1.4 2.1-3.1" fill="none" stroke="currentColor" stroke-width="1.7" />
                    </svg>
                </button>
            </div>
            <span asp-validation-for="PotvrdaLozinke" class="validation-message"></span>
        </div>

        <button type="submit" class="btn btn-primary">Kreiraj nalog</button>
        <a asp-action="IndexBibliotekar" class="btn btn-secondary">Nazad na listu</a>
    </form>
</div>
