@model IEnumerable<SmartLib.Core.DTOs.KorisnikDto>
@{
    ViewData["Title"] = "Članovi biblioteke";
}

<div class="members-header">
    <h2>Članovi biblioteke</h2>
    <a asp-action="Create" class="btn btn-primary">Kreiraj nalog člana</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="validation-message members-feedback">@successMessage</div>
}

<div class="card members-card">
    @if (!Model.Any())
    {
        <p>Trenutno nema registrovanih članova.</p>
    }
    else
    {
        <div class="members-table-wrap">
            <table class="members-table">
                <thead>
                <tr>
                    <th>Ime i prezime</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Kreiran</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var clan in Model)
                {
                    <tr>
                        <td data-label="Ime i prezime">@clan.Ime @clan.Prezime</td>
                        <td data-label="Email" class="members-email">@clan.Email</td>
                        <td data-label="Status">
                            <span class="members-status">@clan.Status</span>
                        </td>
                        <td data-label="Kreiran">@clan.DatumKreiranja.ToString("dd.MM.yyyy HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
