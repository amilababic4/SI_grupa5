@model SmartLib.Core.Models.Korisnik
@{
    var jeMojProfil = ViewBag.JeMojProfil as bool? ?? true;
    var jeAdmin = User.IsInRole("Administrator");
    var jeBibliotekarIliAdmin = User.IsInRole("Bibliotekar") || User.IsInRole("Administrator");
    ViewData["Title"] = jeMojProfil ? "Moj profil" : $"{Model.Ime} {Model.Prezime}";

    // Odakle smo došli — za "Nazad" dugme
    var nazadController = ViewBag.NazadController as string ?? "Korisnik";
    var nazadAction = ViewBag.NazadAction as string ?? "Index";
    var nazadLabel = ViewBag.NazadLabel as string ?? "← Nazad na članove";
}

<div class="details-topbar">
    @if (jeMojProfil)
    {
        <a asp-controller="Knjiga" asp-action="Index" class="btn btn-secondary">← Nazad na katalog</a>
    }
    else
    {
        <a asp-controller="@nazadController" asp-action="@nazadAction" class="btn btn-secondary">@nazadLabel</a>
    }
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success">@successMsg</div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-error">@errorMsg</div>
}

<div class="card profil-card">
    <div class="profil-layout">

        <!-- Avatar -->
        <div class="profil-avatar-wrapper">
            <div class="profil-avatar">
                <span class="profil-avatar-inicijali">
                    @(Model.Ime.Length > 0 ? Model.Ime[0].ToString() : "")@(Model.Prezime.Length > 0 ? Model.Prezime[0].ToString() : "")
                </span>
            </div>
        </div>

        <!-- Informacije -->
        <div class="profil-info-content">
            <div class="details-header">
                <div>
                    <h2>@Model.Ime @Model.Prezime</h2>
                    <p class="details-autor">@(Model.Uloga?.Naziv ?? "—")</p>
                </div>
                <div class="details-actions">
                    @if (jeAdmin)
                    {
                        <a asp-controller="Korisnik" asp-action="Uredi" asp-route-id="@Model.Id"
                           class="btn btn-primary">
                            Uredi profil
                        </a>
                    }
                    @if (jeMojProfil)
                    {
                        <button type="button" class="btn btn-password" onclick="return false;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                            Promjena lozinke
                        </button>
                    }
                </div>
            </div>

            <div class="profil-grid">
                <div class="details-item">
                    <span class="details-label">ID korisnika</span>
                    <span class="profil-id-badge">#@Model.Id</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Ime</span>
                    <span>@Model.Ime</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Prezime</span>
                    <span>@Model.Prezime</span>
                </div>
                <div class="details-item">
                    <span class="details-label">E-mail adresa</span>
                    <span class="profil-email">@Model.Email</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Uloga</span>
                    <span>
                        @if (Model.Uloga != null)
                        {
                            <span class="katalog-badge">@Model.Uloga.Naziv</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </span>
                </div>
                <div class="details-item">
                    <span class="details-label">Status računa</span>
                    <span class="@(Model.Status == "aktivan" ? "status-dostupan" : "status-deaktiviran")">
                        @Model.Status
                    </span>
                </div>
                <div class="details-item profil-grid-full">
                    <span class="details-label">Datum kreiranja</span>
                    <span>@Model.DatumKreiranja.ToString("dd.MM.yyyy")</span>
                </div>
            </div>

            @if (jeBibliotekarIliAdmin && !jeMojProfil)
            {
                <div class="profil-zaduzenja-bar">
                    <a asp-controller="Zaduzenje" asp-action="ZaduzenjaClana"
                       asp-route-korisnikId="@Model.Id"
                       class="btn btn-zaduzenja-aktivna">
                        Aktivna zaduženja
                    </a>
                    <a asp-controller="Zaduzenje" asp-action="HistorijaClana"
                       asp-route-korisnikId="@Model.Id"
                       class="btn btn-zaduzenja-historija">
                        Historija zaduženja
                    </a>
                </div>
            }
        </div>

    </div>
</div>
