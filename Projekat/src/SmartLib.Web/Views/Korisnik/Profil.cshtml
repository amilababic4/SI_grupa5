@model SmartLib.Core.Models.Korisnik
@using SmartLib.Core.DTOs
@{
    var jeMojProfil = ViewBag.JeMojProfil as bool? ?? true;
    var jeAdmin = User.IsInRole("Administrator");
    var jeBibliotekarIliAdmin = User.IsInRole("Bibliotekar") || User.IsInRole("Administrator");
    var targetIsAdmin = string.Equals(Model.Uloga?.Naziv, "Administrator", StringComparison.OrdinalIgnoreCase);
    var statusAktivan = string.Equals(Model.Status, "aktivan", StringComparison.OrdinalIgnoreCase);
    ViewData["Title"] = jeMojProfil ? "Moj profil" : $"{Model.Ime} {Model.Prezime}";

    var nazadController = ViewBag.NazadController as string ?? "Korisnik";
    var nazadAction = ViewBag.NazadAction as string ?? "Index";
    var nazadLabel = ViewBag.NazadLabel as string ?? "← Nazad na članove";

    var clanarina = ViewBag.Clanarina as ClanarinaDto;
}

<div class="details-topbar">
    @if (jeMojProfil)
    {
        <a asp-controller="Knjiga" asp-action="Index" class="btn btn-secondary">← Nazad na katalog</a>
    }
    else
    {
        <a asp-controller="@nazadController" asp-action="@nazadAction" class="btn btn-secondary">@nazadLabel</a>
    }
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success">@successMsg</div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-error">@errorMsg</div>
}
@if (TempData["Uspjeh"] is string uspjehMsg)
{
    <div class="alert alert-success">@uspjehMsg</div>
}

<div class="card profil-card">
    <div class="profil-layout">

        <!-- Avatar -->
        <div class="profil-avatar-wrapper">
            <div class="profil-avatar">
                <span class="profil-avatar-inicijali">
                    @(Model.Ime.Length > 0 ? Model.Ime[0].ToString() : "")@(Model.Prezime.Length > 0 ? Model.Prezime[0].ToString() : "")
                </span>
            </div>
        </div>

        <!-- Informacije -->
        <div class="profil-info-content">
            <div class="details-header">
                <div>
                    <h2>@Model.Ime @Model.Prezime</h2>
                    <p class="details-autor">@(Model.Uloga?.Naziv ?? "—")</p>
                </div>
                <div class="details-actions">
                    @if (jeAdmin)
                    {
                        <a asp-controller="Korisnik" asp-action="Uredi" asp-route-id="@Model.Id"
                           class="btn btn-primary">
                            Uredi profil
                        </a>
                    }
                    @if (jeMojProfil)
                    {
                        <a asp-controller="Auth" asp-action="ChangePassword" class="btn btn-password">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                            Promjena lozinke
                        </a>
                    }
                                        @if (jeMojProfil && statusAktivan && !jeAdmin)
                    {
                        <form asp-controller="Auth" asp-action="DeaktivirajMojNalog" method="post"
                              onsubmit="return confirm('Da li ste sigurni da zelite deaktivirati nalog?');"
                              style="display:inline-block;">
                            <button type="submit" class="btn btn-danger">Deaktiviraj nalog</button>
                        </form>
                    }
                    @if (!jeMojProfil && jeBibliotekarIliAdmin)
                    {
                        if (statusAktivan)
                        {
                            if (!targetIsAdmin)
                            {
                                <form asp-controller="Korisnik" asp-action="Deaktiviraj" asp-route-id="@Model.Id"
                                      method="post"
                                      onsubmit="return confirm('Deaktivirati nalog korisnika?');"
                                      style="display:inline-block;">
                                    <button type="submit" class="btn btn-danger">Deaktiviraj nalog</button>
                                </form>
                            }
                        }
                        else
                        {
                            <form asp-controller="Korisnik" asp-action="Aktiviraj" asp-route-id="@Model.Id"
                                  method="post"
                                  onsubmit="return confirm('Reaktivirati nalog korisnika?');"
                                  style="display:inline-block;">
                                <button type="submit" class="btn btn-primary">Reaktiviraj nalog</button>
                            </form>
                        }
                    }
                </div>
            </div>

            <div class="profil-grid">
                <div class="details-item">
                    <span class="details-label">Ime</span>
                    <span class="details-value">@Model.Ime</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Prezime</span>
                    <span class="details-value">@Model.Prezime</span>
                </div>
                <div class="details-item profil-grid-full">
                    <span class="details-label">E-mail adresa</span>
                    <span class="profil-email details-value">@Model.Email</span>
                </div>
                <div class="details-item">
                    <span class="details-label">Uloga</span>
                    <span>
                        @if (Model.Uloga != null)
                        {
                            <span class="katalog-badge">@Model.Uloga.Naziv</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </span>
                </div>
                <div class="details-item">
                    <span class="details-label">Status računa</span>
                    <span class="@(Model.Status == "aktivan" ? "status-dostupan" : "status-deaktiviran") details-value--center">
                        @Model.Status
                    </span>
                </div>
                @if (!statusAktivan && Model.DatumDeaktivacije.HasValue)
                {
                    <div class="details-item">
                        <span class="details-label">Datum kreiranja</span>
                        <span class="details-value details-value--center">@Model.DatumKreiranja.ToString("dd.MM.yyyy")</span>
                    </div>
                    <div class="details-item">
                        <span class="details-label">Datum deaktivacije</span>
                        <span class="details-value details-value--center">@Model.DatumDeaktivacije.Value.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                }
                else
                {
                    <div class="details-item profil-grid-full">
                        <span class="details-label">Datum kreiranja</span>
                        <span class="details-value details-value--center">@Model.DatumKreiranja.ToString("dd.MM.yyyy")</span>
                    </div>
                }
            </div>

            @* ── SEKCIJA: ČLANARINA (US-55, US-56, US-57) ───────────────────── *@
            @if (Model.Uloga?.Id != 2)
            {
                <div class="profil-clanarina-section">

                    @* Header: naslov + dugme uvijek desno, bez obzira ima li članarine *@
                    <div class="profil-clanarina-header">
                        <span class="profil-clanarina-naslov">Članarina</span>
                        @if (jeBibliotekarIliAdmin && !jeMojProfil)
                        {
                            <a asp-controller="Clanarina"
                               asp-action="Upsert"
                               asp-route-korisnikId="@Model.Id"
                               class="btn-clanarina-upravljaj">
                                @(clanarina is not null ? "Upravljanje članarinom" : "Evidentiraj članarinu")
                            </a>
                        }
                    </div>

                    @* Tijelo: ako postoji članarina prikaži detalje, inače poruku *@
                    @if (clanarina is not null)
                    {
                        <div class="profil-grid" style="margin-top: 0.5rem;">
                            <div class="details-item">
                                <span class="details-label">Datum početka</span>
                                <span>@clanarina.DatumPocetka.ToString("dd.MM.yyyy")</span>
                            </div>
                            <div class="details-item">
                                <span class="details-label">Važi do</span>
                                <span>@clanarina.DatumIsteka.ToString("dd.MM.yyyy")</span>
                            </div>
                            <div class="details-item profil-grid-full">
                                <span class="details-label">Status članarine</span>
                                @if (clanarina.JeAktivna)
                                {
                                    <span class="status-dostupan">aktivna</span>
                                }
                                else
                                {
                                    <span class="status-deaktiviran">istekla</span>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="profil-clanarina-prazno">Članarina nije evidentirana.</p>
                    }

                </div>

                @if (jeBibliotekarIliAdmin && !jeMojProfil)
                {
                    <div class="profil-zaduzenja-bar">
                        <a asp-controller="Zaduzenje" asp-action="ZaduzenjaClana"
                           asp-route-korisnikId="@Model.Id"
                           class="btn btn-zaduzenja-aktivna">
                            Aktivna zaduženja
                        </a>
                        <a asp-controller="Zaduzenje" asp-action="HistorijaClana"
                           asp-route-korisnikId="@Model.Id"
                           class="btn btn-zaduzenja-historija">
                            Historija zaduženja
                        </a>
                    </div>
                }
            }

        </div>
    </div>
</div>
