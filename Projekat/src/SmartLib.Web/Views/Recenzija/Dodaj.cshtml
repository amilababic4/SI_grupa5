@{
    ViewData["Title"] = "Ocijeni knjigu";
    int prefillOcjena = ViewBag.PrefillOcjena is int value ? value : 0;
    string prefillKomentar = ViewBag.PrefillKomentar as string ?? string.Empty;
}

<div class="review-modal-container">
    <div class="review-modal-card">
        @if (TempData["ErrorMessage"] is string reviewError)
        {
            <div class="alert alert-error" style="margin: 1.5rem 2.5rem 0;">@reviewError</div>
        }
        <div class="review-modal-header">
            <div class="header-titles">
                <span class="modal-subtitle">Zabilježite svoje utiske</span>
                <h1>@ViewBag.KnjigaNaslov</h1>
            </div>
            <div class="header-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-edit-3"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
            </div>
        </div>

        <form asp-action="Dodaj" method="post" class="review-form">
            <input type="hidden" name="KnjigaId" value="@ViewBag.KnjigaId" />

            <div class="form-section">
                <label class="section-label">Vaša ocjena</label>
                <div class="rating-stars-wrapper">
                    <div class="rating-wrapper">
                        <input type="radio" id="star5" name="Ocjena" value="5" required @(prefillOcjena == 5 ? "checked" : "") />
                        <label for="star5" title="5 - Remek-djelo">★</label>
                        
                        <input type="radio" id="star4" name="Ocjena" value="4" @(prefillOcjena == 4 ? "checked" : "") />
                        <label for="star4" title="4 - Odlična">★</label>
                        
                        <input type="radio" id="star3" name="Ocjena" value="3" @(prefillOcjena == 3 ? "checked" : "") />
                        <label for="star3" title="3 - Dobra">★</label>
                        
                        <input type="radio" id="star2" name="Ocjena" value="2" @(prefillOcjena == 2 ? "checked" : "") />
                        <label for="star2" title="2 - Osrednja">★</label>
                        
                        <input type="radio" id="star1" name="Ocjena" value="1" @(prefillOcjena == 1 ? "checked" : "") />
                        <label for="star1" title="1 - Loša">★</label>
                    </div>
                    <span class="rating-hint">Odaberite ocjenu od 1 do 5</span>
                </div>
            </div>

            <div class="form-section">
                <label class="section-label">Recenzija (opcionalno)</label>
                <div class="textarea-wrapper">
                    <textarea name="Komentar" class="form-textarea" rows="7" placeholder="Napišite šta vam se svidjelo, a šta nije... Podijelite svoje misli s drugim čitaocima!">@prefillKomentar</textarea>
                    <div class="textarea-footer">
                        <span>Recenzije obogaćuju našu zajednicu.</span>
                    </div>
                </div>
            </div>

            <div class="form-actions-premium">
                <a asp-controller="Zaduzenje" asp-action="MojaHistorija" class="btn btn-premium-ghost">Otkaži</a>
                <button type="submit" class="btn btn-premium-submit">
                    <span>Spremi recenziju</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </button>
            </div>
        </form>
    </div>
</div>

<div id="review-toast" class="review-toast" role="status" aria-live="polite">
    <div class="review-toast-body" id="review-toast-body"></div>
    <div class="review-toast-actions" id="review-toast-actions"></div>
</div>

<style>
    /* Premium Letterboxd-style Review UI */
    .review-modal-container {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 3rem 1rem;
        min-height: calc(100vh - 150px);
    }

    .review-modal-card {
        background: var(--sl-card);
        border: 1px solid var(--sl-border);
        border-radius: 16px;
        width: 100%;
        max-width: 650px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.05);
        overflow: hidden;
        animation: modalFadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes modalFadeIn {
        from { opacity: 0; transform: translateY(20px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .review-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem 2.5rem;
        background: linear-gradient(180deg, rgba(15, 23, 42, 0.06) 0%, rgba(15, 23, 42, 0.02) 100%);
        border-bottom: 1px solid var(--sl-border);
    }

    .header-titles {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .modal-subtitle {
        color: var(--sl-muted);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 600;
    }

    .review-modal-header h1 {
        margin: 0;
        color: var(--sl-text);
        font-size: 1.75rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .header-icon {
        color: var(--sl-success);
        background: rgba(5, 150, 105, 0.1);
        padding: 1rem;
        border-radius: 50%;
    }

    .review-form {
        padding: 2.5rem;
    }

    .form-section {
        margin-bottom: 2.5rem;
    }

    .section-label {
        display: block;
        margin-bottom: 1rem;
        color: var(--sl-text);
        font-size: 1.05rem;
        font-weight: 600;
    }

    /* Rating Stars - Smooth hover effects */
    .rating-stars-wrapper {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .rating-wrapper {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }

    .rating-wrapper input {
        display: none;
    }

    .rating-wrapper label {
        cursor: pointer;
        font-size: 3rem;
        color: #94a3b8;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        line-height: 1;
        padding-right: 0.25rem;
    }

    .rating-wrapper label:hover,
    .rating-wrapper label:hover ~ label {
        color: #fbbf24; /* Amber hover */
        transform: scale(1.15) translateY(-2px);
        text-shadow: 0 0 15px rgba(251, 191, 36, 0.4);
    }

    .rating-wrapper input:checked ~ label {
        color: #f59e0b; /* Selected color */
        text-shadow: 0 0 20px rgba(245, 158, 11, 0.5);
    }

    .rating-hint {
        color: var(--sl-muted);
        font-size: 0.9rem;
        font-weight: 500;
    }

    /* Textarea styling */
    .textarea-wrapper {
        position: relative;
    }

    .form-textarea {
        width: 100%;
        padding: 1.25rem;
        border-radius: 12px;
        border: 2px solid var(--sl-border);
        background: var(--sl-card-solid);
        color: var(--sl-text);
        font-family: inherit;
        font-size: 1rem;
        line-height: 1.6;
        resize: vertical;
        transition: all 0.3s ease;
    }

    .form-textarea::placeholder {
        color: var(--sl-muted);
    }

    .form-textarea:focus {
        outline: none;
        border-color: #059669;
        background: var(--sl-card);
        box-shadow: 0 0 0 4px rgba(5, 150, 105, 0.1);
    }

    .textarea-footer {
        display: flex;
        justify-content: space-between;
        margin-top: 0.75rem;
        color: var(--sl-muted);
        font-size: 0.85rem;
        font-style: italic;
    }

    /* Buttons */
    .form-actions-premium {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 1rem;
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--sl-border);
    }

    .btn-premium-ghost {
        padding: 0.875rem 1.5rem;
        border-radius: 8px;
        color: var(--sl-muted);
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-premium-ghost:hover {
        color: var(--sl-text);
        background: rgba(15, 23, 42, 0.08);
    }

    .btn-premium-submit {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: #059669;
        color: white;
        border: none;
        padding: 0.875rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 12px rgba(5, 150, 105, 0.3);
    }

    .btn-premium-submit:hover {
        background: #047857;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(5, 150, 105, 0.4);

    [data-theme="dark"] .review-modal-card {
        background: #18181b;
        border-color: #27272a;
    }

    [data-theme="dark"] .review-modal-header {
        background: linear-gradient(180deg, #27272a 0%, #18181b 100%);
        border-bottom-color: #27272a;
    }

    [data-theme="dark"] .rating-wrapper label {
        color: #3f3f46;
    }

    [data-theme="dark"] .form-textarea {
        background: #27272a;
        border-color: #27272a;
        color: #f4f4f5;
    }

    [data-theme="dark"] .form-textarea:focus {
        background: #18181b;
    }

    [data-theme="dark"] .btn-premium-ghost:hover {
        background: #27272a;
    }
    }

    .btn-premium-submit:active {
        transform: translateY(0);
    }

    /* Toast validation */
    .review-toast {
        position: fixed;
        left: 50%;
        bottom: 2rem;
        transform: translateX(-50%) translateY(120%);
        background: #0f172a;
        color: #ffffff;
        padding: 0.9rem 1.2rem;
        border-radius: 14px;
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.35);
        max-width: min(520px, 92vw);
        width: fit-content;
        display: flex;
        gap: 1rem;
        align-items: center;
        z-index: 9999;
        transition: transform 0.25s ease;
    }

    .review-toast.show {
        transform: translateX(-50%) translateY(0);
    }

    .review-toast-body {
        font-weight: 600;
    }

    .review-toast-actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .review-toast-actions button {
        border: none;
        background: rgba(255, 255, 255, 0.18);
        color: #ffffff;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        cursor: pointer;
        font-weight: 600;
    }

    .review-toast-actions button.primary {
        background: #22c55e;
        color: #0f172a;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var form = document.querySelector('.review-form');
        var toast = document.getElementById('review-toast');
        var toastBody = document.getElementById('review-toast-body');
        var toastActions = document.getElementById('review-toast-actions');
        var commentField = document.querySelector('textarea[name="Komentar"]');
        var allowEmptyComment = false;
        var toastTimeout;

        function hideToast() {
            toast.classList.remove('show');
            toastActions.innerHTML = '';
        }

        function showToast(message, actions, autoHide) {
            toastBody.textContent = message;
            toastActions.innerHTML = '';

            if (actions && actions.length) {
                actions.forEach(function (action) {
                    var btn = document.createElement('button');
                    btn.type = 'button';
                    btn.textContent = action.label;
                    if (action.primary) btn.classList.add('primary');
                    btn.addEventListener('click', function () {
                        action.onClick();
                    });
                    toastActions.appendChild(btn);
                });
            }

            toast.classList.add('show');
            clearTimeout(toastTimeout);
            if (autoHide) {
                toastTimeout = setTimeout(hideToast, 2600);
            }
        }

        if (!form) return;

        form.addEventListener('submit', function (event) {
            var rating = form.querySelector('input[name="Ocjena"]:checked');
            var comment = commentField ? commentField.value.trim() : '';

            if (!rating) {
                event.preventDefault();
                showToast('Morate odabrati ocjenu prije spremanja.', [
                    { label: 'U redu', onClick: hideToast, primary: true }
                ], false);
                return;
            }

            if (!comment && !allowEmptyComment) {
                event.preventDefault();
                showToast('Niste napisali tekst recenzije. Želite li nastaviti bez teksta?', [
                    {
                        label: 'Nastavi',
                        primary: true,
                        onClick: function () {
                            allowEmptyComment = true;
                            hideToast();
                            if (form.requestSubmit) {
                                form.requestSubmit();
                            } else {
                                form.submit();
                            }
                        }
                    },
                    {
                        label: 'Dodaj tekst',
                        onClick: function () {
                            hideToast();
                            if (commentField) commentField.focus();
                        }
                    }
                ], false);
            }
        });
    });
</script>
