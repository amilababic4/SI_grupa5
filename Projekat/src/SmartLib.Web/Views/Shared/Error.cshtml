@{
    ViewData["Title"] = "Greška";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5 text-center">
                    <h1 class="display-6 fw-bold mb-3">Došlo je do greške</h1>
                    <p class="text-muted mb-4">
                        Trenutno postoji problem pri obradi zahtjeva. Pokušajte ponovo za nekoliko trenutaka.
                    </p>
                    <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Nazad na početnu</a>
