@using System.Security.Claims
@inject SmartLib.Core.Interfaces.INotifikacijaRepository NotifikacijaRepo
<!DOCTYPE html>
<html lang="bs" id="theme-root">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SmartLib</title>

    @* Flash-free theme: runs before first paint so there's no white flash *@
    <script>
        (function () {
            var t = localStorage.getItem('smartlib-theme');
            if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        })();
    </script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* ── Hamburger ──────────────────────────────────────── */
        .nav-brand { display: flex; align-items: center; gap: .4rem; }
        .nav-hamburger {
            width: 36px; height: 36px; border-radius: 9px;
            border: 1.5px solid transparent; background: transparent;
            cursor: pointer; display: flex; flex-direction: column;
            align-items: center; justify-content: center; gap: 5px;
            flex-shrink: 0; transition: background .18s; padding: 0;
            margin-left: -6px;
        }
        .nav-hamburger span { display: block; width: 17px; height: 1.8px; border-radius: 2px; transition: background .18s; }
        .smartlib-navbar-app .nav-hamburger span { background: #334155; }
        .smartlib-navbar-front .nav-hamburger span,
        .smartlib-navbar-dark .nav-hamburger span { background: rgba(255,255,255,.85); }
        .smartlib-navbar-app .nav-hamburger:hover { background: rgba(219,234,254,.9); }
        .smartlib-navbar-front .nav-hamburger:hover,
        .smartlib-navbar-dark .nav-hamburger:hover { background: rgba(255,255,255,.1); }
        [data-theme="dark"] .smartlib-navbar-app .nav-hamburger span { background: rgba(255,255,255,.7); }
        [data-theme="dark"] .smartlib-navbar-app .nav-hamburger:hover { background: rgba(255,255,255,.07); }

        /* ── Drawer overlay ─────────────────────────────────── */
        .nav-drawer-overlay {
            position: fixed; inset: 0; z-index: 9000;
            background: radial-gradient(circle at top left, rgba(37, 99, 235, 0.18), transparent 45%),
                        rgba(6,15,58,.6);
            backdrop-filter: blur(6px);
            opacity: 0; pointer-events: none; transition: opacity .3s ease;
        }
        .nav-drawer-overlay.open { opacity: 1; pointer-events: all; }

        /* ── Drawer panel ───────────────────────────────────── */
        .nav-drawer {
            position: fixed; top: 0; left: 0; bottom: 0; z-index: 9001;
            width: 300px; max-width: 90vw;
            background: linear-gradient(180deg, #ffffff 0%, #f5f8ff 55%, #eef2ff 100%);
            box-shadow: 12px 0 45px rgba(6,15,58,.18);
            transform: translateX(-100%);
            transition: transform .38s cubic-bezier(.16,1,.3,1);
            display: flex; flex-direction: column; overflow-y: auto;
        }
        .nav-drawer.open { transform: translateX(0); }
        [data-theme="dark"] .nav-drawer {
            background: linear-gradient(180deg, #0b1626 0%, #0f1f36 60%, #132842 100%);
        }

        .nav-drawer-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1.1rem 1.3rem;
            border-bottom: 1px solid rgba(27,61,143,.08); flex-shrink: 0;
        }
        [data-theme="dark"] .nav-drawer-header { border-color: rgba(90,128,200,.12); }

        .nav-drawer-brand {
            display: flex; align-items: center; gap: .5rem;
            font-weight: 800; font-size: 1rem; color: #1B3D8F;
            text-decoration: none; font-family: "Manrope", sans-serif;
        }
        [data-theme="dark"] .nav-drawer-brand { color: rgba(255,255,255,.9); }
        .nav-drawer-brand:hover { text-decoration: none; opacity: .85; }
        .nav-drawer-brand-icon {
            width: 28px; height: 28px; border-radius: 7px;
            background: linear-gradient(135deg, #173b63, #2563eb);
            display: flex; align-items: center; justify-content: center; font-size: .84rem;
        }

        .nav-drawer-close {
            width: 32px; height: 32px; border-radius: 50%;
            border: 1.5px solid rgba(27,61,143,.13); background: transparent;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            color: #3d4f70; transition: all .18s; flex-shrink: 0;
        }
        .nav-drawer-close:hover { background: rgba(27,61,143,.06); border-color: rgba(27,61,143,.24); }
        [data-theme="dark"] .nav-drawer-close { border-color: rgba(90,128,200,.18); color: rgba(255,255,255,.55); }
        [data-theme="dark"] .nav-drawer-close:hover { background: rgba(90,128,200,.1); }
        .nav-drawer-close svg { width: 12px; height: 12px; }

        .nav-drawer-links { list-style: none; padding: 1.5rem 0.5rem; margin: 0; }
        .nav-drawer-links li { padding: 0 0.5rem; margin-bottom: 0.6rem; }
        .nav-drawer-links li a,
        .nav-drawer-links li .nd-logout-btn {
            display: block; padding: 0.75rem 1.25rem; border-radius: 14px;
            color: #1a202c; font-size: 0.98rem; font-weight: 600;
            text-decoration: none; transition: all .2s ease;
            border: 1px solid transparent; background: transparent; cursor: pointer;
            width: 100%; text-align: left; font-family: "Manrope", sans-serif;
        }
        .nav-drawer-links li a:hover {
            background: rgba(37, 99, 235, 0.08);
            border-color: rgba(37, 99, 235, 0.18);
            color: #0f172a; transform: translateX(4px);
        }
        [data-theme="dark"] .nav-drawer-links li a,
        [data-theme="dark"] .nav-drawer-links li .nd-logout-btn { color: #cbd5e1; }
        [data-theme="dark"] .nav-drawer-links li a:hover {
            background: rgba(59, 130, 246, 0.18);
            border-color: rgba(59, 130, 246, 0.3);
            color: #f8fafc;
        }

        .nav-drawer-sep { height: 1px; background: rgba(27,61,143,.07); margin: .35rem 1.3rem; }
        [data-theme="dark"] .nav-drawer-sep { background: rgba(90,128,200,.1); }

        .nav-drawer-section {
            padding: 0 1.2rem;
            margin: 1rem 0 0.35rem;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: rgba(27,61,143,.6);
        }
        [data-theme="dark"] .nav-drawer-section { color: rgba(148,163,184,.7); }

        .nd-logout-btn { color: #b42318 !important; }
        .nd-logout-btn:hover { background: rgba(180,35,24,.05) !important; color: #b42318 !important; }
        [data-theme="dark"] .nd-logout-btn { color: #f87171 !important; }
        [data-theme="dark"] .nd-logout-btn:hover { background: rgba(248,113,113,.06) !important; }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>

@{
        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
        var action = ViewContext.RouteData.Values["action"]?.ToString();

        var isFrontPage   = controller == "Home" && action == "Index";
        var isDarkNavPage = controller == "Vijest" || controller == "Kalendar";
        var isCatalogPage = controller == "Knjiga" && action == "Index";
        var isAuthenticated = User.Identity?.IsAuthenticated == true;

        // Do not show animations for administrators and librarians.
        var isAdminOrLib = User.IsInRole("Bibliotekar") || User.IsInRole("Administrator");

        var showLoginWelcomeFromTemp = TempData["ShowWelcomeAnimation"]?.ToString() == "true";
        var welcomeNameFromTemp = TempData["WelcomeName"]?.ToString();
        var welcomeRole = User.IsInRole("Bibliotekar") || User.IsInRole("Administrator") ? "staff" : "member";

        var showCatalogWelcomeOnce = Context.Session.GetString("ShowCatalogWelcomeOnce") == "true";
        var welcomeNameFromSession = Context.Session.GetString("CatalogWelcomeName");

        // Show the login welcome immediately, and the catalog welcome once per session for members.
        var shouldShowAnimation = false;
        if (showLoginWelcomeFromTemp && isAuthenticated)
        {
            shouldShowAnimation = true;
        }

        var notifCount = 0;
        if (isAuthenticated)
        {
            var notifUserIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (int.TryParse(notifUserIdStr, out var notifUserId))
            {
                notifCount = await NotifikacijaRepo.GetUnreadCountAsync(notifUserId);
            }
        }

        string bookText       = "";
        string bookHeaderRight = "✦ DAŠAK INSPIRACIJE ✦";
        string bookFooterLeft  = "ODABERITE SVOJU PRIČU";
        string bookBtnText     = "Uđite u biblioteku ➔";

        if (showLoginWelcomeFromTemp && isAuthenticated)
        {
            var name = !string.IsNullOrEmpty(welcomeNameFromTemp) ? welcomeNameFromTemp : User.Identity?.Name ?? "Član";
            bookText = welcomeRole == "staff"
                ? $"Dobrodošli nazad, {name}! Prijava je uspješna i svi alati su spremni."
                : $"Dobrodošli nazad, {name}! Drago nam je što ste tu.";
        }
        else if (isCatalogPage && shouldShowAnimation)
        {
            var name = !string.IsNullOrEmpty(welcomeNameFromSession) ? welcomeNameFromSession : User.Identity?.Name ?? "Član";

            // Dataset of randomised catalog quotes — famous authors & original poetic lines
            var catalogQuotes = new[]
            {
                (h: "✦ VAŠA ČITAONICA ✦",    t: $"Svaka knjiga je novo putovanje, {name}. Pronađite priču koja govori baš vama.",                    f: "OTKRIJTE NOVE SVJETOVE"),
                (h: "✦ RIZNICA PRIČA ✦",     t: $"Dobrodošli u trezor mašte, {name}! Hiljade svjetova čekaju da ih otkrijete.",                      f: "ZARONITE U STRANICE"),
                (h: "✦ MUDROST DANA ✦",      t: "\"Čitalac živi hiljadu života. Onaj koji ne čita — samo jedan.\" — G.R.R. Martin",                   f: "ŽIVITE VIŠE ŽIVOTA"),
                (h: "✦ DAŠAK INSPIRACIJE ✦", t: $"Između ovih korica krije se čitav jedan svijet, {name}. Koji ćete otvoriti danas?",                 f: "BIRAJTE SVOJU AVANTURU"),
                (h: "✦ VAŠA BIBLIOTEKA ✦",   t: "\"Uvijek sam zamišljao da je Raj neka vrsta biblioteke.\" — Jorge Luis Borges",                      f: "DOBRODOŠLI U RAJ"),
                (h: "✦ PORUKA ZA VAS ✦",     t: $"Prava knjiga te mijenja zauvijek, {name}. Pronađite je upravo ovdje.",                             f: "PRONAĐITE SVOJU"),
                (h: "✦ DAŠAK MAŠTE ✦",       t: "Čitanje je sanjarenje s otvorenim očima — i vi ste upravo zakoračili u san.",                         f: "URONITE U PRIČE"),
                (h: "✦ VAŠA KARTA ✦",        t: $"{name}, ovaj katalog je vaša karta do mjesta koja niste ni zamislili.",                             f: "KRENITE NA PUT"),
                (h: "✦ MUDRE RIJEČI ✦",      t: "\"Ne sve one koji lutaju su izgubljeni.\" — J.R.R. Tolkien",                                         f: "ISTRAŽUJTE SLOBODNO"),
                (h: "✦ NOVA STRANICA ✦",     t: "Svaka stranica je novi početak. Svaka knjiga — novi pogled na svijet.",                               f: "PRELISTAJTE KATALOG"),
                (h: "✦ VAŠA PRIČA ✦",        t: $"Knjige ne završavaju — one se nastavljaju u vama, {name}.",                                         f: "NASTAVITE ČITATI"),
                (h: "✦ KNJIŽEVNA BLAGA ✦",   t: "\"Knjige su ogledala — vidimo u njima ono što već nosimo u sebi.\" — J.K. Rowling",                   f: "PRONAĐITE SEBE"),
                (h: "✦ TREZOR SNOVA ✦",      t: $"Biblioteka je trezor svih snova koje su ikad zapisali, {name}. Birajte mudro.",                      f: "ODABERITE SVOJU PRIČU"),
                (h: "✦ AVANTURA ČEKA ✦",     t: $"{name}, vaša sljedeća omiljena knjiga strpljivo čeka. Ona je tu, negdje.",                          f: "PRONAĐITE JE"),
                (h: "✦ MAGIJA STRANICA ✦",   t: "Samo dobra knjiga može te odvesti tamo gdje avion ne može.",                                          f: "LETITE RIJEČIMA"),
            };

            var pick = catalogQuotes[Random.Shared.Next(catalogQuotes.Length)];
            bookText        = pick.t;
            bookHeaderRight = pick.h;
            bookFooterLeft  = pick.f;
            bookBtnText     = "Istražite katalog ➔";
        }
}

<body class="@(ViewData["BodyClass"] as string)" data-disable-animations="@(isAdminOrLib && !shouldShowAnimation ? "true" : "false")">

    @if (shouldShowAnimation)
    {
        <!-- Book opening overlay (removed after animation or click) -->
        <div id="book-overlay" aria-hidden="true">
            <!-- Cinematic vignette — darkens edges for depth -->
            <div class="book-vignette" aria-hidden="true"></div>
            <!-- Floating ambient particles -->
            <div class="book-particles" aria-hidden="true">
                <span class="particle p1"></span>
                <span class="particle p2"></span>
                <span class="particle p3"></span>
                <span class="particle p4"></span>
                <span class="particle p5"></span>
                <span class="particle p6"></span>
                <span class="particle p7"></span>
                <span class="particle p8"></span>
                <span class="particle p9"></span>
                <span class="particle p10"></span>
                <span class="particle p11"></span>
                <span class="particle p12"></span>
                <span class="particle p13"></span>
                <span class="particle p14"></span>
            </div>
            <div class="book-container">
                <div class="book" role="img" aria-label="Opening book animation">
                    <div class="cover front">
                        <div class="cover-side outer">
                            <span class="cover-title-shimmer" aria-hidden="true"></span>
                            <span class="cover-title" aria-hidden="false">SMARTLIB</span>
                        </div>
                        <div class="cover-side inner"></div>
                    </div>
                    <div class="pages">
                        <!-- Left Page Sheet (swings open to the left with branding) -->
                        <div class="page-sheet left-page">
                            <div class="page-side outer"></div>
                            <div class="page-side inner">
                                <div class="page-content">
                                    <div class="book-page-header">✦ KUTAK ZA ČITANJE ✦</div>
                                    <div class="book-icon-container">
                                        <svg class="book-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                                        </svg>
                                    </div>
                                    <h2 class="page-title">SmartLib</h2>
                                    <div class="book-page-footer">@bookFooterLeft</div>
                                </div>
                            </div>
                        </div>
                        <!-- Right Page Sheet (stays on the right with creative text) -->
                        <div class="page-sheet right-page">
                            <div class="page-side outer">
                                <div class="page-content">
                                    <span class="page-quote-bg" aria-hidden="true">&ldquo;</span>
                                    <span class="corner-ornament corner-tl" aria-hidden="true"></span>
                                    <span class="corner-ornament corner-tr" aria-hidden="true"></span>
                                    <span class="corner-ornament corner-bl" aria-hidden="true"></span>
                                    <span class="corner-ornament corner-br" aria-hidden="true"></span>
                                    <div class="book-page-header">@bookHeaderRight</div>
                                    <p class="page-text">@bookText</p>
                                    <button id="close-overlay-btn" class="book-action-btn">@bookBtnText</button>
                                </div>
                            </div>
                            <div class="page-side inner"></div>
                        </div>
                    </div>
                    <div class="cover back"></div>
                </div>
            </div>
        </div>
    }



    <nav id="main-nav" class="smartlib-navbar @(isFrontPage ? "smartlib-navbar-front" : isDarkNavPage ? "smartlib-navbar-dark" : "smartlib-navbar-app")">
        <div class="smartlib-nav-inner">

            <div class="nav-brand">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button class="nav-hamburger" id="nav-hamburger" aria-label="Otvori meni" aria-expanded="false">
                        <span></span><span></span><span></span>
                    </button>
                }
                <a asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">📚</span>
                    <span class="brand-text">SmartLib</span>
                </a>
                <button id="menu-trigger" class="mobile-menu-btn" aria-label="Meni" style="background:none;border:none;cursor:pointer;font-size:1.5rem;display:none;">☰</button>
            </div>

            <ul class="nav-links" id="nav-menu">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("Administrator"))
                    {
                        <li><a asp-controller="Knjiga" asp-action="Index" class="katalog-nav-link">Katalog</a></li>
                        <li><a asp-controller="Zaduzenje" asp-action="Index">Zaduženja</a></li>
                        <li><a asp-controller="Rezervacija" asp-action="Index">Rezervacije</a></li>
                        <li><a asp-controller="Korisnik" asp-action="Index">Članovi</a></li>
                        <li><a asp-controller="Korisnik" asp-action="IndexBibliotekar">Bibliotekari</a></li>
                        <li><a asp-controller="Izvjestaj" asp-action="Index">Izvještaji</a></li>
                    }
                    else if (User.IsInRole("Bibliotekar"))
                    {
                        <li><a asp-controller="Knjiga" asp-action="Index" class="katalog-nav-link">Katalog</a></li>
                        <li><a asp-controller="Zaduzenje" asp-action="Index">Zaduženja</a></li>
                        <li><a asp-controller="Rezervacija" asp-action="Index">Rezervacije</a></li>
                        <li><a asp-controller="Korisnik" asp-action="Index">Članovi</a></li>
                        <li><a asp-controller="Forum" asp-action="Index">Forum</a></li>
                        <li><a asp-controller="Izvjestaj" asp-action="Index">Izvještaji</a></li>
                    }
                    else
                    {
                        <li><a asp-controller="Knjiga" asp-action="Index" class="katalog-nav-link">Katalog</a></li>
                        <li><a asp-controller="Zaduzenje" asp-action="Moja">Moja zaduženja</a></li>
                        <li><a asp-controller="Rezervacija" asp-action="Moje">Moje rezervacije</a></li>
                        <li><a asp-controller="ListaKolekcija" asp-action="Index">Kolekcije</a></li>
                    }
                    <li>
                        <a asp-controller="Notifikacija" asp-action="Index" class="nav-notif-link">
                            Obavještenja
                            @if (notifCount > 0)
                            {
                                <span class="notif-badge">@notifCount</span>
                            }
                        </a>
                    </li>
                    @if (!User.IsInRole("Član"))
                    {
                        <li class="nav-sep" role="separator"></li>
                        <li><a asp-controller="Korisnik" asp-action="Profil">Moj profil</a></li>
                        <li>
                            <form asp-controller="Auth" asp-action="Logout" method="post" style="display:contents">
                                <button type="submit" class="nav-link-btn">Odjava</button>
                            </form>
                        </li>
                    }
                }
                else
                {
                    <li><a asp-controller="Vijest" asp-action="Index">Vijesti</a></li>
                    <li><a asp-controller="Kalendar" asp-action="Index">Kalendar</a></li>     
                    <li class="menu-item">
                        <a asp-controller="Auth" asp-action="Login" class="nav-login-link">Prijava</a>
                    </li>
                }

                @* Dark mode toggle *@
                <li class="menu-item">
                    <button id="theme-toggle" class="theme-toggle-btn" aria-label="Promijeni temu" title="Promijeni temu">
                        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="5"/>
                            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                        </svg>
                        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    </button>
                </li>
            </ul>
        </div>
    </nav>

    @* ── Side drawer (authenticated only) ─────────────────────────────── *@
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="nav-drawer-overlay" id="nav-drawer-overlay" aria-hidden="true"></div>
        <nav class="nav-drawer" id="nav-drawer" aria-label="Bočni meni">
            <div class="nav-drawer-header">
                <a asp-controller="Home" asp-action="Index" class="nav-drawer-brand">
                    <span class="nav-drawer-brand-icon">📚</span>SmartLib
                </a>
                <button class="nav-drawer-close" id="nav-drawer-close" aria-label="Zatvori meni">
                    <svg viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
            </div>
            <ul class="nav-drawer-links">
                <li class="nav-drawer-section">Glavno</li>
                <li><a asp-controller="Home" asp-action="Index">Početna</a></li>
                <li><a asp-controller="Vijest" asp-action="Index">Vijesti</a></li>
                <li><a asp-controller="Kalendar" asp-action="Index">Kalendar</a></li>
                <li><a asp-controller="Knjiga" asp-action="Index" class="katalog-nav-link">Katalog</a></li>
                @if (User.IsInRole("Administrator"))
                {
                    <li class="nav-drawer-section">Upravljanje</li>
                    <li><a asp-controller="Zaduzenje" asp-action="Index">Zaduženja</a></li>
                    <li><a asp-controller="Rezervacija" asp-action="Index">Rezervacije</a></li>
                    <li><a asp-controller="Prijave" asp-action="Index">Prijave</a></li>
                    <li><a asp-controller="Korisnik" asp-action="Index">Članovi</a></li>
                    <li><a asp-controller="Korisnik" asp-action="IndexBibliotekar">Bibliotekari</a></li>
                    <li><a asp-controller="Kategorija" asp-action="Index">Kategorije</a></li>
                    <li><a asp-controller="Forum" asp-action="Index">Forum</a></li>
                    <li><a asp-controller="Izvjestaj" asp-action="Index">Izvještaji</a></li>
                    <li><a asp-controller="Admin" asp-action="AuditLog">Audit Log</a></li>
                }
                else if (User.IsInRole("Bibliotekar"))
                {
                    <li class="nav-drawer-section">Upravljanje</li>
                    <li><a asp-controller="Zaduzenje" asp-action="Index">Zaduženja</a></li>
                    <li><a asp-controller="Rezervacija" asp-action="Index">Rezervacije</a></li>
                    <li><a asp-controller="Prijave" asp-action="Index">Prijave</a></li>
                    <li><a asp-controller="Korisnik" asp-action="Index">Članovi</a></li>
                    <li><a asp-controller="Forum" asp-action="Index">Forum</a></li>
                    <li><a asp-controller="Izvjestaj" asp-action="Index">Izvještaji</a></li>
                }
                else
                {
                    <li class="nav-drawer-section">Moje</li>
                    <li><a asp-controller="Zaduzenje" asp-action="Moja">Moja zaduženja</a></li>
                    <li><a asp-controller="Rezervacija" asp-action="Moje">Moje rezervacije</a></li>
                    <li><a asp-controller="ListaKolekcija" asp-action="Index">Kolekcije</a></li>
                    <li><a asp-controller="Forum" asp-action="Index">Forum</a></li>
                    <li><a asp-controller="Knjiga" asp-action="Explore">Želiš nešto novo?</a></li>
                }
                <li class="nav-drawer-section">Nalog</li>
                <li>
                    <a asp-controller="Notifikacija" asp-action="Index" class="nav-notif-link">
                        Obavještenja
                        @if (notifCount > 0)
                        {
                            <span class="notif-badge">@notifCount</span>
                        }
                    </a>
                </li>
                <li class="nav-drawer-sep" role="separator"></li>
                <li><a asp-controller="Korisnik" asp-action="Profil">Moj profil</a></li>
                <li>
                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        <button type="submit" class="nd-logout-btn">Odjava</button>
                    </form>
                </li>
            </ul>
        </nav>
    }

    <main class="@(ViewData["MainClass"] as string ?? "page-shell")">
        @RenderBody()
    </main>

    <footer>
        <p>&copy; 2026 SmartLib — SI Grupa 5, ETF Sarajevo</p>
    </footer>

    <script src="~/js/animations.js" asp-append-version="true" defer></script>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // ── Password show/hide ───────────────────────────────────────────
            document.querySelectorAll(".password-field").forEach((field) => {
                const input = field.querySelector("input");
                const toggle = field.querySelector(".password-toggle");
                if (!input || !toggle) return;
                toggle.addEventListener("click", () => {
                    const isHidden = input.type === "password";
                    input.type = isHidden ? "text" : "password";
                    toggle.setAttribute("aria-pressed", isHidden ? "true" : "false");
                    toggle.setAttribute("aria-label", isHidden ? "Sakrij lozinku" : "Prikazi lozinku");
                });
            });

            // ── Dark mode toggle ─────────────────────────────────────────────
            const root = document.documentElement;
            const btn  = document.getElementById("theme-toggle");
            if (btn) {
                // Sync icon on load
                const updateIcon = () => {
                    const dark = root.getAttribute("data-theme") === "dark";
                    btn.querySelector(".icon-sun").style.display  = dark ? "block" : "none";
                    btn.querySelector(".icon-moon").style.display = dark ? "none"  : "block";
                };
                updateIcon();

                btn.addEventListener("click", () => {
                    const isDark = root.getAttribute("data-theme") === "dark";
                    const next   = isDark ? "light" : "dark";
                    root.setAttribute("data-theme", next);
                    localStorage.setItem("smartlib-theme", next);
                    updateIcon();
                });
            }

            // ── Side drawer ──────────────────────────────────────────────────
            const _drawer    = document.getElementById("nav-drawer");
            const _dOverlay  = document.getElementById("nav-drawer-overlay");
            const _hamburger = document.getElementById("nav-hamburger");
            const _dClose    = document.getElementById("nav-drawer-close");

            function openDrawer() {
                if (!_drawer) return;
                _drawer.classList.add("open");
                _dOverlay.classList.add("open");
                _hamburger.setAttribute("aria-expanded", "true");
                document.body.style.overflow = "hidden";
            }
            function closeDrawer() {
                if (!_drawer) return;
                _drawer.classList.remove("open");
                _dOverlay.classList.remove("open");
                if (_hamburger) _hamburger.setAttribute("aria-expanded", "false");
                document.body.style.overflow = "";
            }

            if (_hamburger) _hamburger.addEventListener("click", openDrawer);
            if (_dClose)    _dClose.addEventListener("click", closeDrawer);
            if (_dOverlay)  _dOverlay.addEventListener("click", closeDrawer);
            if (_drawer) {
                _drawer.querySelectorAll("a").forEach(a => a.addEventListener("click", closeDrawer));
                _drawer.querySelectorAll('button[type="submit"]').forEach(b => b.addEventListener("click", closeDrawer));
            }
            document.addEventListener("keydown", e => { if (e.key === "Escape") closeDrawer(); });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>