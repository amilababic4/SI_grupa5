@model ZaduzenjeViewModel
@{
    ViewData["Title"] = "Detalji zaduženja";

    var returnUrl = ViewBag.ReturnUrl as string ?? "Index";
    var korisnikId = ViewBag.KorisnikId as int?;
    var primjerakId = ViewBag.PrimjerakId as int?;

    string nazadAction, nazadLabel;
    bool trebaPrimjerak = false;
    bool trebaKorisnik = false;

    switch (returnUrl)
    {
        case "Historija":
            nazadAction = "Historija";
            nazadLabel = "← Nazad na historiju";
            break;
        case "ZaduzenjaClana":
            nazadAction = "ZaduzenjaClana";
            nazadLabel = "← Nazad na aktivna zaduženja";
            trebaKorisnik = true;
            break;
        case "HistorijaClana":
            nazadAction = "HistorijaClana";
            nazadLabel = "← Nazad na historiju člana";
            trebaKorisnik = true;
            break;
        case "ZaduzenjaPrimjerka":
            nazadAction = "ZaduzenjaPrimjerka";
            nazadLabel = "← Nazad na zaduženja primjerka";
            trebaPrimjerak = true;
            break;
        default:
            nazadAction = "Index";
            nazadLabel = "← Nazad na listu";
            break;
    }
}

<div class="details-topbar">
    @if (trebaPrimjerak && primjerakId.HasValue)
    {
        <a asp-action="@nazadAction" asp-route-primjerakId="@primjerakId"
           class="btn btn-secondary">@nazadLabel</a>
    }
    else if (trebaKorisnik && korisnikId.HasValue)
    {
        <a asp-action="@nazadAction" asp-route-korisnikId="@korisnikId"
           class="btn btn-secondary">@nazadLabel</a>
    }
    else
    {
        <a asp-action="@nazadAction" class="btn btn-secondary">@nazadLabel</a>
    }
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success">@successMsg</div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-error">@errorMsg</div>
}

<div class="card">
    <div class="details-header">
        <div>
            <h2>Zaduženje #@Model.Id</h2>
            <p class="details-autor">@Model.KnjigaNaslov</p>
        </div>
        @if (Model.Status == "aktivno")
        {
            <div class="details-actions">
                <a asp-action="VratiPotvrda" asp-route-id="@Model.Id" class="btn btn-primary">
                    Evidentiraj vraćanje
                </a>
            </div>
        }
    </div>

    <div class="details-grid">
        <div class="details-item">
            <span class="details-label">Član</span>
            <span class="details-value">@Model.KorisnikIme</span>
        </div>
        <div class="details-item">
            <span class="details-label">Email člana</span>
            <span class="details-value">@Model.KorisnikEmail</span>
        </div>
        <div class="details-item">
            <span class="details-label">Knjiga</span>
            <span class="details-value">@Model.KnjigaNaslov</span>
        </div>
        <div class="details-item">
            <span class="details-label">Inventarni broj</span>
            <span class="details-value katalog-isbn">@Model.InventarniBroj</span>
        </div>
        <div class="details-item">
            <span class="details-label">Datum zaduženja</span>
            <span class="details-value">@Model.DatumZaduzivanja.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
        </div>
        <div class="details-item">
            <span class="details-label">Rok vraćanja</span>
            <span class="details-value">@Model.DatumPlaniranogVracanja.ToLocalTime().ToString("dd.MM.yyyy")</span>
            @if (Model.JeZakasnilo && Model.Status == "aktivno")
            {
                <span class="status-kasni">Zakašnjelo</span>
            }
            else if (Model.RokSeBliži && Model.Status == "aktivno")
            {
                <span class="status-blizi">Uskoro</span>
            }
        </div>
        <div class="details-item">
            <span class="details-label">Datum vraćanja</span>
            <span class="details-value">
                @if (Model.DatumStvarnogVracanja.HasValue)
                {
                    @Model.DatumStvarnogVracanja.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                }
                else
                {
                    <span style="color:var(--sl-muted);">-</span>
                }
            </span>
        </div>
        <div class="details-item">
            <span class="details-label">Status</span>
            <span class="@(Model.Status == "aktivno" ? "status-dostupan" : "status-nedostupan")">
                @Model.Status
            </span>
        </div>
    </div>
</div>
