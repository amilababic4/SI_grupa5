@model HistorijaZaduzenjaViewModel
@{
    ViewData["Title"] = "Historija zaduženja";
}

<div class="katalog-header">
    <h2>Historija zaduženja</h2>
    <a asp-action="Index" class="btn btn-secondary">← Aktivna zaduženja</a>
</div>

<div class="card katalog-search">
    <form asp-action="Historija" method="get">
        <div class="search-row">
            <div class="form-group" style="flex:1; margin-bottom:0;">
                <input type="text" name="clan" value="@Model.Clan"
                       placeholder="Pretraga po imenu ili emailu člana..." />
            </div>
            <div style="display:flex; gap:0.5rem; align-items:flex-end;">
                <button type="submit" class="btn btn-primary">Traži</button>
                <a asp-action="Historija" class="btn btn-secondary">Reset</a>
            </div>
        </div>
    </form>
</div>

<p class="katalog-meta">
    Prikazuju se zatvorena zaduženja iz
    <strong>posljednje 3 godine</strong>
    @if (!string.IsNullOrWhiteSpace(Model.Clan))
    {
        <span> · filtriran po: <strong>@Model.Clan</strong></span>
    }
    · ukupno: <strong>@Model.Zaduzenja.Count</strong>
</p>

@if (!Model.Zaduzenja.Any())
{
    <div class="card katalog-empty">
        <p>Nema zatvorenih zaduženja@(string.IsNullOrWhiteSpace(Model.Clan) ? " u posljednje 3 godine." : " za zadani filter.")</p>
    </div>
}
else
{
    <div class="card katalog-card">
        <div class="katalog-table-wrap">
            <table class="katalog-table">
                <thead>
                    <tr>
                        <th>Član</th>
                        <th>Email</th>
                        <th>Knjiga</th>
                        <th>Inv. br.</th>
                        <th>Zaduženo</th>
                        <th>Rok vraćanja</th>
                        <th>Vraćeno</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var z in Model.Zaduzenja.OrderByDescending(x => x.DatumStvarnogVracanja))
                    {
                        <tr>
                            <td data-label="Član"><strong>@z.KorisnikIme</strong></td>
                            <td data-label="Email" class="members-email">@z.KorisnikEmail</td>
                            <td data-label="Knjiga">@z.KnjigaNaslov</td>
                            <td data-label="Inv. br." class="katalog-isbn">@z.InventarniBroj</td>
                            <td data-label="Zaduženo">@z.DatumZaduzivanja.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td data-label="Rok vraćanja">@z.DatumPlaniranogVracanja.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td data-label="Vraćeno">
                                @if (z.DatumStvarnogVracanja.HasValue)
                                {
                                    <span class="historija-vraceno">@z.DatumStvarnogVracanja.Value.ToLocalTime().ToString("dd.MM.yyyy")</span>
                                }
                                else
                                {
                                    <span class="historija-nepoznato">—</span>
                                }
                            </td>
                            <td class="katalog-actions">
                                <a asp-action="Details" asp-route-id="@z.Id" class="btn btn-secondary btn-sm">Detalji</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
