@model AktivnaZaduzenjaViewModel
@{
    ViewData["Title"] = "Aktivna zaduženja";
}

<div class="katalog-header">
    <h2>Aktivna zaduženja</h2>
    <a asp-action="Create" class="btn btn-primary">+ Novo zaduživanje</a>
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success">@successMsg</div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-error">@errorMsg</div>
}

<div class="card katalog-search">
    <form asp-action="Index" method="get">
        <div class="search-row">
            <div class="form-group" style="flex:1; margin-bottom:0;">
                <input type="text" name="clan" value="@Model.Clan"
                       placeholder="Pretraga po imenu ili emailu člana..." />
            </div>
            <div style="display:flex; gap:0.5rem; align-items:flex-end;">
                <button type="submit" class="btn btn-primary">Traži</button>
                <a asp-action="Index" class="btn btn-secondary">Reset</a>
            </div>
        </div>
    </form>
</div>

@if (!Model.Zaduzenja.Any())
{
    <div class="card katalog-empty">
        <p>Nema aktivnih zaduženja@(string.IsNullOrWhiteSpace(Model.Clan) ? "." : " za zadani filter.")</p>
    </div>
}
else
{
    <div class="card katalog-card">
        <div class="katalog-table-wrap">
            <table class="katalog-table">
                <thead>
                    <tr>
                        <th>Član</th>
                        <th>Email</th>
                        <th>Knjiga</th>
                        <th>Inv. br.</th>
                        <th>Zaduženo</th>
                        <th>Rok vraćanja</th>
                        <th>Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var z in Model.Zaduzenja)
                    {
                        <tr class="@(z.JeZakasnilo ? "tr-kasni" : z.RokSeBliži ? "tr-blizi" : "")">
                            <td data-label="Član"><strong>@z.KorisnikIme</strong></td>
                            <td data-label="Email" class="members-email">@z.KorisnikEmail</td>
                            <td data-label="Knjiga">@z.KnjigaNaslov</td>
                            <td data-label="Inv. br." class="katalog-isbn">@z.InventarniBroj</td>
                            <td data-label="Zaduženo">@z.DatumZaduzivanja.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td data-label="Rok vraćanja">
                                @z.DatumPlaniranogVracanja.ToLocalTime().ToString("dd.MM.yyyy")
                                @if (z.JeZakasnilo)
                                {
                                    <span class="status-kasni">Zakašnjelo</span>
                                }
                                else if (z.RokSeBliži)
                                {
                                    <span class="status-blizi">Uskoro</span>
                                }
                            </td>
                            <td data-label="Akcije" class="katalog-actions">
                                <a asp-action="Details" asp-route-id="@z.Id" class="btn btn-secondary btn-sm">Detalji</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
